    function makePanelDraggable(panel, handle) {
        let dragging = false;
        let startX = 0;
        let startY = 0;
        let originX = 0;
        let originY = 0;

        function rect() { return panel.getBoundingClientRect(); }

        function savePos(x, y) {
            localStorage.setItem(UI_KEYS.posX, String(Math.round(x)));
            localStorage.setItem(UI_KEYS.posY, String(Math.round(y)));
        }

        function setPos(x, y) {
            const r = rect();
            const maxX = Math.max(0, window.innerWidth - r.width - 4);
            const maxY = Math.max(0, window.innerHeight - r.height - 4);
            const cx = clamp(x, 4, maxX);
            const cy = clamp(y, 4, maxY);
            panel.style.left = `${cx}px`;
            panel.style.top = `${cy}px`;
            panel.style.right = 'auto';
            panel.style.bottom = 'auto';
            panel.style.transform = 'none';
            savePos(cx, cy);
        }

        handle.addEventListener('mousedown', (e) => {
            if (e.target.closest('button') && e.target !== handle) return;
            e.preventDefault();
            dragging = true;
            startX = e.clientX;
            startY = e.clientY;
            const r = rect();
            originX = r.left;
            originY = r.top;
        });

        document.addEventListener('mousemove', (e) => {
            if (!dragging) return;
            setPos(originX + (e.clientX - startX), originY + (e.clientY - startY));
        });

        document.addEventListener('mouseup', () => { dragging = false; });

        const savedX = Number(localStorage.getItem(UI_KEYS.posX));
        const savedY = Number(localStorage.getItem(UI_KEYS.posY));
        if (Number.isFinite(savedX) && Number.isFinite(savedY)) {
            requestAnimationFrame(() => setPos(savedX, savedY));
        } else {
            requestAnimationFrame(() => {
                const r = rect();
                setPos(window.innerWidth - r.width - 12, (window.innerHeight / 2) - (r.height / 2));
            });
        }
    }

