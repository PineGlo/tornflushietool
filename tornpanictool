    function saveSettingsFromInputs() {
        const rawDelayMin = Number(settingsInputs.delayMin.value);
        const rawDelayMax = Number(settingsInputs.delayMax.value);
        const delayMin = Number.isFinite(rawDelayMin) ? Math.max(0, rawDelayMin) : DEFAULTS.delayMin;
        const delayMax = Number.isFinite(rawDelayMax) ? Math.max(delayMin, rawDelayMax) : Math.max(delayMin, DEFAULTS.delayMax);

        localStorage.setItem(SETTINGS_KEYS.apiKey, settingsInputs.apiKey.value.trim());
        localStorage.setItem(SETTINGS_KEYS.delayMin, String(delayMin));
        localStorage.setItem(SETTINGS_KEYS.delayMax, String(delayMax));
        localStorage.setItem(SETTINGS_KEYS.autoCooldown, String(Math.max(0, Number(settingsInputs.autoCooldown.value) || DEFAULTS.autoCooldown)));
        localStorage.setItem(SETTINGS_KEYS.minLifeDrop, String(Math.max(1, Number(settingsInputs.minLifeDrop.value) || DEFAULTS.minLifeDrop)));
        localStorage.setItem(SETTINGS_KEYS.minCashIncrease, String(Math.max(0, Number(settingsInputs.minCashIncrease.value) || DEFAULTS.minCashIncrease)));
        localStorage.setItem(SETTINGS_KEYS.lifePollMs, String(Math.max(50, Number(settingsInputs.lifePollMs.value) || DEFAULTS.lifePollMs)));
        localStorage.setItem(SETTINGS_KEYS.cashPollMs, String(Math.max(50, Number(settingsInputs.cashPollMs.value) || DEFAULTS.cashPollMs)));
        localStorage.setItem(SETTINGS_KEYS.exactCashSelector, settingsInputs.exactCashSelector.value.trim());
