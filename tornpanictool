    function makePanelDraggable(panel, handle) {
        let dragging = false;
        let startX = 0;
        let startY = 0;
        let originX = 0;
        let originY = 0;

        function getRect() {
            return panel.getBoundingClientRect();
        }

        function savePosition(x, y) {
            localStorage.setItem(UI_KEYS.posX, String(Math.round(x)));
            localStorage.setItem(UI_KEYS.posY, String(Math.round(y)));
        }

        function setPosition(x, y) {
            const rect = getRect();
            const maxX = Math.max(0, window.innerWidth - rect.width - 4);
            const maxY = Math.max(0, window.innerHeight - rect.height - 4);

            const clampedX = clamp(x, 4, maxX);
            const clampedY = clamp(y, 4, maxY);

            panel.style.left = `${clampedX}px`;
            panel.style.top = `${clampedY}px`;
            panel.style.right = 'auto';
            panel.style.bottom = 'auto';
            panel.style.transform = 'none';

            savePosition(clampedX, clampedY);
        }

        function startDrag(clientX, clientY) {
            const rect = getRect();
            dragging = true;
            startX = clientX;
            startY = clientY;
            originX = rect.left;
            originY = rect.top;
            panel.style.opacity = '1';
        }

        function moveDrag(clientX, clientY) {
            if (!dragging) return;
            setPosition(originX + (clientX - startX), originY + (clientY - startY));
        }

        function endDrag() {
            dragging = false;
        }

        handle.addEventListener('mousedown', (e) => {
            if (e.target.closest('button') && e.target !== handle) return;
            e.preventDefault();
            startDrag(e.clientX, e.clientY);
        });

        document.addEventListener('mousemove', (e) => moveDrag(e.clientX, e.clientY));
        document.addEventListener('mouseup', endDrag);

        handle.addEventListener('touchstart', (e) => {
            const t = e.touches[0];
            if (!t) return;
            startDrag(t.clientX, t.clientY);
        }, { passive: true });

        document.addEventListener('touchmove', (e) => {
            const t = e.touches[0];
            if (!t) return;
            moveDrag(t.clientX, t.clientY);
        }, { passive: true });

        document.addEventListener('touchend', endDrag);

        window.addEventListener('resize', () => {
            const rect = getRect();
            setPosition(rect.left, rect.top);
        });

        const savedX = Number(localStorage.getItem(UI_KEYS.posX));
        const savedY = Number(localStorage.getItem(UI_KEYS.posY));

        if (Number.isFinite(savedX) && Number.isFinite(savedY)) {
            requestAnimationFrame(() => setPosition(savedX, savedY));
        } else {
            requestAnimationFrame(() => {
                const rect = getRect();
                setPosition(window.innerWidth - rect.width - 12, (window.innerHeight / 2) - (rect.height / 2));
            });
        }
    }

    function setupPanelFade(panel) {
        let fadeTimer = null;

        function wake() {
            panel.style.opacity = '1';
            if (fadeTimer) clearTimeout(fadeTimer);
            fadeTimer = setTimeout(() => {
                if (!panel.matches(':hover')) {
                    panel.style.opacity = '0.38';
                }
            }, 2200);
        }

        ['mousemove', 'mouseenter', 'touchstart', 'click'].forEach(evt => {
            panel.addEventListener(evt, wake, { passive: true });
        });

        wake();
    }

