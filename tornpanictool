// ==UserScript==
// @name         Torn Vault Panic Deposit (Simple Leader + Fixed Vault Navigation)
// @namespace    pineglow.torn.vaultpanic
// @version      5.0
// @description  Auto deposits cash when life drops or cash spikes, with simple leader lock, fixed vault navigation, cash toggle, settings panel, and better reliability
// @match        https://www.torn.com/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    const PROPERTY_ID = '5709149';
    const VAULT_HASH = `#/p=options&ID=${PROPERTY_ID}&tab=vault`;
    const VAULT_URL = `https://www.torn.com/properties.php${VAULT_HASH}`;
    const FACTION_ARMORY_URL = 'https://www.torn.com/factions.php?step=your&type=1#/tab=armoury';
    const VAULT_CAP = 1000000000;

    const KEYS = {
        autoMode: 'pineglow_auto_mode',
        cashMode: 'pineglow_cash_mode',
        pauseMode: 'pineglow_pause_mode',
        leaderMode: 'pineglow_leader_mode',
        leaderLockedTab: 'pineglow_leader_locked_tab_v1',
        lastAuto: 'pineglow_last_auto',
        leaderState: 'pineglow_simple_leader_state_v2',
        leaderDepositRequest: 'pineglow_leader_deposit_request_v2'
    };

    const UI_KEYS = {
        posX: 'pineglow_ui_pos_x',
        posY: 'pineglow_ui_pos_y',
        collapsed: 'pineglow_ui_collapsed',
        settingsCollapsed: 'pineglow_ui_settings_collapsed'
    };

    const SETTINGS_KEYS = {
        delayMin: 'pineglow_setting_delay_min',
        delayMax: 'pineglow_setting_delay_max',
        autoCooldown: 'pineglow_setting_auto_cooldown',
        minLifeDrop: 'pineglow_setting_min_life_drop',
        minCashIncrease: 'pineglow_setting_min_cash_increase',
        lifePollMs: 'pineglow_setting_life_poll_ms',
        cashPollMs: 'pineglow_setting_cash_poll_ms',
        exactCashSelector: 'pineglow_setting_exact_cash_selector',
        pauseHotkey: 'pineglow_setting_pause_hotkey'
    };

    const DEFAULTS = {
        delayMin: 25,
        delayMax: 75,
        autoCooldown: 10000,
        minLifeDrop: 1,
        minCashIncrease: 7500000,
        lifePollMs: 250,
        cashPollMs: 500,
        leaderHeartbeatMs: 1500,
        leaderStaleMs: 5000,
        exactCashSelector: '',
        pauseHotkey: ''
    };

    function getOrCreateTabId() {
        const sessionKey = 'pineglow_vaultpanic_tab_id_v1';
        const existing = sessionStorage.getItem(sessionKey);
        if (existing) return existing;
        const created = `vaultpanic_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`;
        sessionStorage.setItem(sessionKey, created);
        return created;
    }

    const TAB_ID = getOrCreateTabId();
    const bc = typeof BroadcastChannel !== 'undefined'
        ? new BroadcastChannel('pineglow_vaultpanic_leader_v2')
        : null;

    let lastLife = null;
    let lastCash = null;
    let lastCoreDomVersion = null;
    let latestCoreState = null;

    let lifeWatcherStarted = false;
    let cashWatcherStarted = false;
    let leaderWatcherStarted = false;
    let flowWatcherStarted = false;

    let uiStatusEl = null;
    let uiCashEl = null;
    let uiSettingsBody = null;
    let uiFlowEl = null;
    let uiLeaderCheckbox = null;
    let uiPauseToggleBtn = null;

    let settingsInputs = {};
    let depositing = false;
    let lastHandledRequestId = null;

    function safeJsonParse(value, fallback = null) {
        try {
            return JSON.parse(value);
        } catch {
            return fallback;
        }
    }

    function now() {
        return Date.now();
    }

    function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
    }

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function rand(min, max) {
        const settings = getSettings();
        const lo = Number.isFinite(min) ? min : settings.delayMin;
        const hi = Number.isFinite(max) ? max : settings.delayMax;
        return Math.floor(Math.random() * (hi - lo + 1)) + lo;
    }

    function tap(el) {
        if (!el) return;
        ['pointerdown', 'mousedown', 'mouseup', 'click'].forEach(type => {
            try {
                el.dispatchEvent(new MouseEvent(type, {
                    bubbles: true,
                    cancelable: true,
                    view: window
                }));
            } catch {}
        });
        try {
            el.click();
        } catch {}
    }

    function getNumberSetting(key, fallback) {
        const raw = localStorage.getItem(key);
        const val = Number(raw);
        return Number.isFinite(val) ? val : fallback;
    }

    function getTextSetting(key, fallback = '') {
        const raw = localStorage.getItem(key);
        return raw == null ? fallback : raw;
    }

    function normalizeHotkeyValue(value) {
        return String(value || '').trim().toLowerCase();
    }

    function getSettings() {
        let delayMin = getNumberSetting(SETTINGS_KEYS.delayMin, DEFAULTS.delayMin);
        let delayMax = getNumberSetting(SETTINGS_KEYS.delayMax, DEFAULTS.delayMax);

        if (delayMin < 0) delayMin = DEFAULTS.delayMin;
        if (delayMax < delayMin) delayMax = delayMin;

        return {
            delayMin,
            delayMax,
            autoCooldown: getNumberSetting(SETTINGS_KEYS.autoCooldown, DEFAULTS.autoCooldown),
            minLifeDrop: getNumberSetting(SETTINGS_KEYS.minLifeDrop, DEFAULTS.minLifeDrop),
            minCashIncrease: getNumberSetting(SETTINGS_KEYS.minCashIncrease, DEFAULTS.minCashIncrease),
            lifePollMs: getNumberSetting(SETTINGS_KEYS.lifePollMs, DEFAULTS.lifePollMs),
            cashPollMs: getNumberSetting(SETTINGS_KEYS.cashPollMs, DEFAULTS.cashPollMs),
            leaderHeartbeatMs: DEFAULTS.leaderHeartbeatMs,
            leaderStaleMs: DEFAULTS.leaderStaleMs,
            exactCashSelector: getTextSetting(SETTINGS_KEYS.exactCashSelector, DEFAULTS.exactCashSelector),
            pauseHotkey: normalizeHotkeyValue(getTextSetting(SETTINGS_KEYS.pauseHotkey, DEFAULTS.pauseHotkey))
        };
    }

    function formatMoney(num) {
        if (!Number.isFinite(num)) return 'unknown';
        return `$${num.toLocaleString()}`;
    }

    function parseMoneyText(text) {
        if (!text) return null;
        const cleaned = String(text).replace(/[^\d-]/g, '');
        if (!cleaned) return null;
        const num = parseInt(cleaned, 10);
        return Number.isFinite(num) ? num : null;
    }

    function readCoreState() {
        try {
            if (window.TornCore?.getState) {
                return window.TornCore.getState();
            }
        } catch {}

        try {
            if (window.__TORN_CORE_STATE__) {
                return window.__TORN_CORE_STATE__;
            }
        } catch {}

        return null;
    }

    function getCoreDomState() {
        const current = readCoreState();
        if (current?.dom) {
            latestCoreState = current;
            return current.dom;
        }
        return latestCoreState?.dom || null;
    }

    function isCoreConnected() {
        return Boolean(getCoreDomState());
    }

    function isCashModeEnabled() {
        return localStorage.getItem(KEYS.cashMode) === '1';
    }

    function isAutoModeEnabled() {
        return localStorage.getItem(KEYS.autoMode) === '1';
    }

    function isLeaderModeEnabled() {
        return localStorage.getItem(KEYS.leaderMode) !== '0';
    }

    function getLockedLeaderTabId() {
        return localStorage.getItem(KEYS.leaderLockedTab) || '';
    }

    function isThisTabLockedLeader() {
        return getLockedLeaderTabId() === TAB_ID;
    }

    function canThisTabRunLeaderFlow() {
        if (!isLeaderModeEnabled()) return false;
        const lockedTabId = getLockedLeaderTabId();
        if (lockedTabId && lockedTabId !== TAB_ID) return false;
        return true;
    }

    function isPaused() {
        return localStorage.getItem(KEYS.pauseMode) === '1';
    }

    function doesEventMatchPauseHotkey(event, hotkey) {
        const normalized = normalizeHotkeyValue(hotkey);
        if (!normalized) return false;
        return normalizeHotkeyValue(event.key) === normalized;
    }

    function isVaultPage() {
        return location.pathname.includes('/properties.php') &&
               location.hash.includes('/p=options') &&
               location.hash.includes(`ID=${PROPERTY_ID}`) &&
               location.hash.includes('tab=vault');
    }

    function isFactionArmoryPage() {
        return location.pathname.includes('/factions.php') &&
               location.hash.includes('/tab=armoury');
    }

    function isHospitalAreaUnavailable(scope = document) {
        const notice = Array.from(scope.querySelectorAll('.msg.right-round')).find(el => {
            const text = (el.textContent || '').replace(/\s+/g, ' ').trim().toLowerCase();
            return text.includes("this area is unavailable while you're in hospital");
        });
        return Boolean(notice);
    }

    function findMoneyLabelCash(scope = document) {
        const elements = Array.from(scope.querySelectorAll('div, span, p, li, a, strong'));

        for (const el of elements) {
            const txt = (el.textContent || '').replace(/\s+/g, ' ').trim();
            const match = txt.match(/\bMoney\b\s*:?\s*\$([\d,]+)/i);
            if (match) {
                const val = parseMoneyText(match[1]);
                if (Number.isFinite(val) && val >= 0) return val;
            }
        }

        return null;
    }

    function findVaultOnHandCash(scope = document) {
        const elements = Array.from(scope.querySelectorAll('div, span, p, li, form, strong'));

        for (const el of elements) {
            const txt = (el.textContent || '').replace(/\s+/g, ' ').trim();
            const match = txt.match(/You have\s+\$([\d,]+)\s+on you/i);
            if (match) {
                const val = parseMoneyText(match[1]);
                if (Number.isFinite(val) && val >= 0) return val;
            }
        }

        return null;
    }

    function getVaultTotal() {
        const el = document.querySelector('#vault-wvalue');
        if (!el) return null;
        const value = parseMoneyText(el.textContent || '');
        return Number.isFinite(value) && value >= 0 ? value : null;
    }

    function getCandidateMoneyNodes(scope) {
        if (!scope) return [];
        const all = Array.from(scope.querySelectorAll('*'));

        return all.filter(el => {
            if (!el || !el.textContent) return false;
            if (el.children.length > 6) return false;

            const txt = (el.textContent || '').trim();
            if (!txt.includes('$')) return false;
            if (!/\$[\d,]+/.test(txt)) return false;

            if (
                el.closest('.news-ticker-new') ||
                el.closest('#header-swiper-container') ||
                el.closest('.news-ticker-slide') ||
                el.closest('[aria-label*="headline"]')
            ) {
                return false;
            }

            return true;
        });
    }

    function chooseBestCashValue(nodes) {
        const scored = [];

        for (const el of nodes) {
            const txt = (el.textContent || '').trim();
            const matches = txt.match(/\$[\d,]+/g);
            if (!matches) continue;

            for (const raw of matches) {
                const value = parseMoneyText(raw);
                if (!Number.isFinite(value) || value < 0) continue;

                let score = 0;

                if (value >= 1000) score += 5;
                if (value >= 100000) score += 5;
                if (value >= 1000000) score += 10;

                if (txt.length <= 30) score += 10;
                else if (txt.length <= 60) score += 6;
                else if (txt.length <= 120) score += 2;
                else score -= 10;

                if (el.closest('#header-root')) score += 8;
                if (el.closest('#topHeaderBanner')) score += 8;

                if (/market|decrease|increase|week|headline|value/i.test(txt)) score -= 20;

                scored.push({ value, score });
            }
        }

        scored.sort((a, b) => b.score - a.score);
        return scored.length ? scored[0].value : null;
    }

    function getCash() {
        const coreDom = getCoreDomState();
        const coreCash = coreDom?.cash?.onHand;
        if (Number.isFinite(coreCash) && coreCash >= 0) {
            return coreCash;
        }

        const settings = getSettings();

        if (settings.exactCashSelector) {
            const exactEl = document.querySelector(settings.exactCashSelector);
            if (exactEl) {
                const exactVal = parseMoneyText(exactEl.textContent || '');
                if (Number.isFinite(exactVal) && exactVal >= 0) return exactVal;
            }
        }

        if (isVaultPage()) {
            const vaultCash = findVaultOnHandCash(document);
            if (Number.isFinite(vaultCash)) return vaultCash;

            const moneyLabelCash = findMoneyLabelCash(document);
            if (Number.isFinite(moneyLabelCash)) return moneyLabelCash;
        }

        const moneyLabelCash = findMoneyLabelCash(document);
        if (Number.isFinite(moneyLabelCash)) return moneyLabelCash;

        const headerScope =
            document.querySelector('#topHeaderBanner') ||
            document.querySelector('#header-root') ||
            document.querySelector('header');

        const headerCandidates = getCandidateMoneyNodes(headerScope);
        const headerValue = chooseBestCashValue(headerCandidates);
        if (Number.isFinite(headerValue)) return headerValue;

        const bodyCandidates = getCandidateMoneyNodes(document.body);
        const bodyValue = chooseBestCashValue(bodyCandidates);
        if (Number.isFinite(bodyValue)) return bodyValue;

        return null;
    }

    function getLife() {
        const coreDom = getCoreDomState();
        const coreLife = coreDom?.life?.current;
        if (Number.isFinite(coreLife) && coreLife >= 0) {
            return coreLife;
        }

        const el =
            document.querySelector('a[class*="life"] p[class*="bar-value"]') ||
            document.querySelector('[class*="life"] p[class*="bar-value"]');

        if (!el) return null;

        const match = el.textContent.match(/(\d[\d,]*)\s*\/\s*(\d[\d,]*)/);
        if (!match) return null;

        return parseInt(match[1].replace(/,/g, ''), 10);
    }

    function getMyLeaderPayload() {
        return {
            tabId: TAB_ID,
            href: location.href,
            isVault: isVaultPage(),
            isVisible: document.visibilityState === 'visible',
            updatedAt: now()
        };
    }

    function readLeaderState() {
        return safeJsonParse(localStorage.getItem(KEYS.leaderState), null);
    }

    function writeLeaderState(payload) {
        localStorage.setItem(KEYS.leaderState, JSON.stringify(payload));
        if (bc) {
            try {
                bc.postMessage({ type: 'leader-heartbeat', payload });
            } catch {}
        }
    }

    function isLeaderStale(leader) {
        const settings = getSettings();
        if (!leader || !leader.updatedAt) return true;
        return (now() - leader.updatedAt) > settings.leaderStaleMs;
    }

    function amLeader() {
        const leader = readLeaderState();
        return !!leader && leader.tabId === TAB_ID && !isLeaderStale(leader);
    }

    function shouldTakeLeadership(currentLeader) {
        if (!canThisTabRunLeaderFlow()) return false;

        const mine = getMyLeaderPayload();

        if (!currentLeader) return true;
        if (isLeaderStale(currentLeader)) return true;
        if (currentLeader.tabId === TAB_ID) return true;

        if (mine.isVault && !currentLeader.isVault) return true;

        return false;
    }

    function maybeClaimLeadership(force = false) {
        if (!force && !canThisTabRunLeaderFlow()) {
            updateUIStatus();
            return false;
        }

        const currentLeader = readLeaderState();
        if ((force && canThisTabRunLeaderFlow()) || shouldTakeLeadership(currentLeader)) {
            writeLeaderState(getMyLeaderPayload());
            updateUIStatus();
            return true;
        }
        updateUIStatus();
        return false;
    }

    function heartbeatLeadership() {
        if (!canThisTabRunLeaderFlow()) {
            releaseLeadershipIfOwned();
            updateUIStatus();
            return;
        }

        if (amLeader()) {
            writeLeaderState(getMyLeaderPayload());
        } else {
            maybeClaimLeadership(false);
        }
        updateUIStatus();
    }

    function releaseLeadershipIfOwned() {
        const leader = readLeaderState();
        if (leader && leader.tabId === TAB_ID) {
            localStorage.removeItem(KEYS.leaderState);
            if (bc) {
                try {
                    bc.postMessage({ type: 'leader-released', tabId: TAB_ID });
                } catch {}
            }
        }
    }

    function buildDepositRequest(source = 'manual') {
        return {
            requestId: `req_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
            source,
            target: 'vault',
            fromTabId: TAB_ID,
            createdAt: now()
        };
    }

    function setDepositRequest(payload) {
        localStorage.setItem(KEYS.leaderDepositRequest, JSON.stringify(payload));
        if (bc) {
            try {
                bc.postMessage({ type: 'deposit-request', payload });
            } catch {}
        }
    }

    function getDepositRequest() {
        return safeJsonParse(localStorage.getItem(KEYS.leaderDepositRequest), null);
    }

    function clearDepositRequest() {
        localStorage.removeItem(KEYS.leaderDepositRequest);
        if (bc) {
            try {
                bc.postMessage({ type: 'deposit-request-cleared', tabId: TAB_ID });
            } catch {}
        }
    }

    function getDepositForm() {
        return document.querySelector('form.vault-cont.right.deposit-box');
    }

    function getMaxBtn() {
        const form = getDepositForm();
        return form?.querySelector('span.input-money-symbol input.wai-btn[type="button"]') || null;
    }

    function getDepositBtn() {
        const form = getDepositForm();
        return Array.from(form?.querySelectorAll('input.torn-btn[type="submit"]') || [])
            .find(btn => (btn.value || '').trim().toUpperCase() === 'DEPOSIT') || null;
    }

    function getDepositAmountInput() {
        const form = getDepositForm();
        if (!form) return null;

        return form.querySelector('input[name="money"], input[name="amount"], input[type="text"], input[type="number"]') || null;
    }

    function getFactionMoneyGroup() {
        return document.querySelector('div.input-money-group');
    }

    function getFactionMaxBtn() {
        const group = getFactionMoneyGroup();
        return group?.querySelector('span.input-money-symbol input.wai-btn[type="button"]') || null;
    }

    function getFactionAmountInput() {
        const group = getFactionMoneyGroup();
        if (!group) return null;
        return group.querySelector('input.amount.input-money[type="text"], input.amount.input-money') || null;
    }

    function getFactionDepositBtn() {
        return Array.from(document.querySelectorAll('button.torn-btn'))
            .find(btn => (btn.textContent || '').replace(/\s+/g, ' ').trim().toUpperCase() === 'DEPOSIT MONEY') || null;
    }

    function getFactionConfirmYesBtn() {
        return Array.from(document.querySelectorAll('a.yes'))
            .find(el => (el.textContent || '').trim().toUpperCase() === 'YES') || null;
    }

    function goToVaultPage() {
        if (isVaultPage()) return true;

        if (location.pathname.includes('/properties.php')) {
            if (location.hash !== VAULT_HASH) {
                location.hash = VAULT_HASH;
            }
            return false;
        }

        location.assign(VAULT_URL);
        return false;
    }

    function goToFactionArmoryPage() {
        if (isFactionArmoryPage()) return true;
        location.assign(FACTION_ARMORY_URL);
        return false;
    }

    function waitForVaultUI(timeoutMs = 8000) {
        return new Promise(resolve => {
            const start = Date.now();

            const timer = setInterval(() => {
                const maxBtn = getMaxBtn();
                const depositBtn = getDepositBtn();

                if (maxBtn && depositBtn) {
                    clearInterval(timer);
                    resolve(true);
                    return;
                }

                if (Date.now() - start >= timeoutMs) {
                    clearInterval(timer);
                    resolve(false);
                }
            }, 200);
        });
    }

    function waitForFactionUI(timeoutMs = 8000) {
        return new Promise(resolve => {
            const start = Date.now();

            const timer = setInterval(() => {
                const maxBtn = getFactionMaxBtn();
                const depositBtn = getFactionDepositBtn();

                if (maxBtn && depositBtn) {
                    clearInterval(timer);
                    resolve(true);
                    return;
                }

                if (Date.now() - start >= timeoutMs) {
                    clearInterval(timer);
                    resolve(false);
                }
            }, 200);
        });
    }

    async function readAmountAfterMax(maxBtn, inputGetter) {
        if (!maxBtn) return 0;

        tap(maxBtn);

        const maxApplied = await new Promise(resolve => {
            const input = inputGetter();
            if (!input) {
                resolve(false);
                return;
            }

            const started = Date.now();
            const timer = setInterval(() => {
                const value = parseMoneyText(input.value);
                if (Number.isFinite(value) && value > 0) {
                    clearInterval(timer);
                    resolve(true);
                    return;
                }

                if (Date.now() - started >= 450) {
                    clearInterval(timer);
                    resolve(false);
                }
            }, 20);
        });

        if (!maxApplied) {
            await sleep(20);
        }

        const input = inputGetter();
        const amount = parseMoneyText(input?.value || '');
        return Number.isFinite(amount) ? amount : 0;
    }

    async function doDeposit() {
        const maxBtn = getMaxBtn();
        const depositBtn = getDepositBtn();

        if (!maxBtn || !depositBtn) return false;

        const amount = await readAmountAfterMax(maxBtn, getDepositAmountInput);
        if (!Number.isFinite(amount) || amount <= 0) return false;

        const freshDepositBtn = getDepositBtn();
        if (!freshDepositBtn) return false;
        if (freshDepositBtn.disabled || freshDepositBtn.classList.contains('disabled')) return false;

        tap(freshDepositBtn);
        return true;
    }

    async function doFactionDeposit() {
        const maxBtn = getFactionMaxBtn();
        const depositBtn = getFactionDepositBtn();
        if (!maxBtn || !depositBtn) return false;

        const amount = await readAmountAfterMax(maxBtn, getFactionAmountInput);
        if (!Number.isFinite(amount) || amount <= 0) return false;

        tap(depositBtn);
        await sleep(rand(60, 120));

        const yesBtn = getFactionConfirmYesBtn();
        if (yesBtn) {
            tap(yesBtn);
        }
        return true;
    }

    async function processDepositFlow() {
        if (depositing) return;
        if (!amLeader()) return;
        if (isPaused()) return;

        const request = getDepositRequest();
        if (!request) return;

        if (lastHandledRequestId === request.requestId && isVaultPage() === false) {
            // keep allowing retries after navigation, do not early exit
        }

        depositing = true;
        updateUIStatus();

        try {
            lastHandledRequestId = request.requestId;

            if (isHospitalAreaUnavailable() && request.target !== 'faction') {
                setDepositRequest({ ...request, target: 'faction' });
                if (!isFactionArmoryPage()) {
                    goToFactionArmoryPage();
                }
                return;
            }

            if (request.target === 'faction') {
                if (!isFactionArmoryPage()) {
                    goToFactionArmoryPage();
                    return;
                }

                const factionReady = await waitForFactionUI(8000);
                if (!factionReady) return;

                await sleep(rand(10, 25));
                const factionSuccess = await doFactionDeposit();
                if (factionSuccess) {
                    clearDepositRequest();
                    await sleep(rand(80, 140));
                }
                return;
            }

            if (!isVaultPage()) {
                goToVaultPage();
                return;
            }

            const ready = await waitForVaultUI(8000);
            if (!ready) return;

            const vaultTotal = getVaultTotal();
            if (!Number.isFinite(vaultTotal)) return;

            const room = Math.max(0, VAULT_CAP - vaultTotal);
            const maxBtn = getMaxBtn();
            const amount = await readAmountAfterMax(maxBtn, getDepositAmountInput);
            if (!Number.isFinite(amount) || amount <= 0) return;

            if (amount > room) {
                setDepositRequest({ ...request, target: 'faction' });
                goToFactionArmoryPage();
                return;
            }

            await sleep(rand(10, 25));
            const success = await doDeposit();
            if (success) {
                clearDepositRequest();
                await sleep(rand(80, 140));
            }
        } finally {
            depositing = false;
            updateUIStatus();
        }
    }

    async function requestDeposit(source = 'manual') {
        if (isPaused()) return;

        const payload = buildDepositRequest(source);
        setDepositRequest(payload);

        if (amLeader()) {
            await sleep(rand());
            processDepositFlow();
        }
    }

    async function maybeAutoDeposit(reason, amount = 0) {
        const settings = getSettings();

        if (isPaused()) return;
        if (!amLeader()) return;
        if (!isAutoModeEnabled()) return;

        const nowMs = Date.now();
        const last = Number(localStorage.getItem(KEYS.lastAuto) || 0);
        if (nowMs - last < settings.autoCooldown) return;

