    function watchLife() {
        if (lifeWatcherStarted) return;
        lifeWatcherStarted = true;

        setInterval(() => {
            if (!amLeader()) return;
            const life = getLife();
            if (life === null) return;

            if (lastLife === null) {
                lastLife = life;
                return;
            }

            const diff = lastLife - life;
            if (diff >= getSettings().minLifeDrop) {
                maybeAutoDeposit('life_drop', diff);
            }

            lastLife = life;
        }, Math.max(50, getSettings().lifePollMs));
    }

    function watchCash() {
        if (cashWatcherStarted) return;
        cashWatcherStarted = true;

        setInterval(() => {
            if (!amLeader()) return;

            const cash = getCash();
            updateUIStatus();
            if (cash === null) return;

            if (lastCash === null) {
                lastCash = cash;
                return;
            }

            if (!isCashModeEnabled()) {
                lastCash = cash;
                return;
            }

            const diff = cash - lastCash;
            if (diff >= getSettings().minCashIncrease) {
                lastCash = cash;
                maybeAutoDeposit('cash_spike', diff);
                return;
            }

            lastCash = cash;
        }, Math.max(50, getSettings().cashPollMs));
    }

    function watchLeadership() {
        if (leaderWatcherStarted) return;
        leaderWatcherStarted = true;

        maybeClaimLeadership(true);

        setInterval(() => heartbeatLeadership(), getSettings().leaderHeartbeatMs);

        document.addEventListener('visibilitychange', () => {
            maybeClaimLeadership(false);
            updateUIStatus();
        });

        window.addEventListener('focus', () => {
            maybeClaimLeadership(false);
            updateUIStatus();
        });

        window.addEventListener('hashchange', () => {
            setTimeout(() => {
                maybeClaimLeadership(false);
                processDepositFlow();
                updateUIStatus();
            }, 120);
        });

        window.addEventListener('beforeunload', () => releaseLeadershipIfOwned());

        window.addEventListener('storage', (e) => {
            if (
                e.key === KEYS.leaderState ||
                e.key === KEYS.leaderDepositRequest ||
                e.key === KEYS.cashMode ||
                e.key === KEYS.autoMode ||
                e.key === KEYS.mainLeaderPreferred ||
                Object.values(SETTINGS_KEYS).includes(e.key)
            ) {
                if (settingsInputs.apiKey) loadSettingsIntoInputs();
                updateUIStatus();
                if (e.key === KEYS.leaderDepositRequest && amLeader()) {
                    setTimeout(() => processDepositFlow(), rand(20, 60));
                }
            }
        });

        if (bc) {
            bc.onmessage = (event) => {
                const msg = event?.data;
                if (!msg) return;
                if (msg.type === 'deposit-request' && amLeader()) setTimeout(() => processDepositFlow(), rand(20, 60));
                if (msg.type === 'leader-released') maybeClaimLeadership(false);
                if (msg.type === 'leader-heartbeat') updateUIStatus();
            };
        }
    }

    function watchFlow() {
        if (flowWatcherStarted) return;
        flowWatcherStarted = true;

        setInterval(() => {
            if (!amLeader()) return;
            processDepositFlow();
        }, 1000);
    }

    function init() {
        createUI();
        watchLeadership();
        watchLife();
        watchCash();
        watchFlow();
        updateUIStatus();
    }

    init();
