    function evaluateLifeTrigger(life) {
        const settings = getSettings();

        if (!amLeader()) return;
        if (!Number.isFinite(life)) return;

        if (lastLife === null) {
            lastLife = life;
            return;
        }

        if (life < lastLife) {
            const diff = lastLife - life;
            if (diff >= settings.minLifeDrop) {
                const cash = getCash();
                if (!Number.isFinite(cash) || cash < settings.minCashIncrease) {
                    lastLife = life;
                    return;
                }
                maybeAutoDeposit('life_drop', diff);
            }
        }

        lastLife = life;
    }

    function evaluateCashTrigger(cash) {
        const settings = getSettings();

        if (!amLeader()) return;
        if (!Number.isFinite(cash)) return;

        updateUIStatus();

        if (lastCash === null) {
            lastCash = cash;
            return;
        }

        if (!isCashModeEnabled()) {
            lastCash = cash;
            return;
        }

        if (cash > lastCash) {
            const diff = cash - lastCash;
            if (diff >= settings.minCashIncrease) {
                lastCash = cash;
                maybeAutoDeposit('cash_spike', diff);
                return;
            }
        }

        lastCash = cash;
    }

    function consumeCoreSnapshot() {
        const dom = getCoreDomState();
        if (!dom) return false;

        const domVersion = Number(dom.domVersion);
        if (Number.isFinite(domVersion) && domVersion === lastCoreDomVersion) {
            return false;
        }

        if (Number.isFinite(domVersion)) {
            lastCoreDomVersion = domVersion;
        }

        evaluateLifeTrigger(dom.life?.current);
        evaluateCashTrigger(dom.cash?.onHand);
        updateUIStatus();
        return true;
    }

    function watchLife() {
        if (lifeWatcherStarted) return;
        lifeWatcherStarted = true;

        consumeCoreSnapshot();

        if (window.TornCore?.subscribe) {
            try {
                window.TornCore.subscribe((snapshot) => {
                    if (snapshot?.dom) {
                        latestCoreState = snapshot;
                        consumeCoreSnapshot();
                    }
                });
            } catch {}
        }

        setInterval(() => {
            const consumed = consumeCoreSnapshot();
            if (consumed) return;

            // Fallback for when Torn Core is not running yet.
            evaluateLifeTrigger(getLife());
            evaluateCashTrigger(getCash());
            updateUIStatus();
        }, Math.max(50, Math.min(getSettings().lifePollMs, getSettings().cashPollMs)));
    }

    function watchCash() {
        if (cashWatcherStarted) return;
        cashWatcherStarted = true;
    }

    function watchLeadership() {
        if (leaderWatcherStarted) return;
        leaderWatcherStarted = true;

        maybeClaimLeadership(true);

        setInterval(() => {
            heartbeatLeadership();
        }, getSettings().leaderHeartbeatMs);

        document.addEventListener('visibilitychange', () => {
            maybeClaimLeadership(false);
            updateUIStatus();
        });

        window.addEventListener('focus', () => {
            maybeClaimLeadership(false);
            updateUIStatus();
        });

        window.addEventListener('hashchange', () => {
            setTimeout(() => {
                maybeClaimLeadership(false);
                processDepositFlow();
                updateUIStatus();
            }, 100);
        });

        window.addEventListener('beforeunload', () => {
            releaseLeadershipIfOwned();
        });

        window.addEventListener('storage', (e) => {
            if (
                e.key === KEYS.leaderState ||
                e.key === KEYS.leaderDepositRequest ||
                e.key === KEYS.leaderLockedTab ||
                e.key === KEYS.pauseMode ||
                e.key === KEYS.cashMode ||
                e.key === KEYS.autoMode ||
                Object.values(SETTINGS_KEYS).includes(e.key)
            ) {
                if (e.key === KEYS.leaderLockedTab && !canThisTabRunLeaderFlow()) {
                    releaseLeadershipIfOwned();
                }

                if (uiLeaderCheckbox) {
                    uiLeaderCheckbox.checked = isThisTabLockedLeader();
                }
                refreshPauseToggleButton();

                updateUIStatus();

                if (e.key === KEYS.leaderDepositRequest && amLeader()) {
                    setTimeout(() => processDepositFlow(), rand(20, 60));
                }

                if (settingsInputs.delayMin) {
                    loadSettingsIntoInputs();
                }
            }
        });

        if (bc) {
            bc.onmessage = (event) => {
                const msg = event?.data;
                if (!msg) return;

                if (msg.type === 'deposit-request' && amLeader()) {
                    setTimeout(() => processDepositFlow(), rand(20, 60));
                }

                if (msg.type === 'leader-released') {
                    maybeClaimLeadership(false);
                }

                if (msg.type === 'leader-heartbeat') {
                    updateUIStatus();
                }
            };
        }
    }

    function watchFlow() {
        if (flowWatcherStarted) return;
        flowWatcherStarted = true;

        setInterval(() => {
            if (!amLeader()) return;
            processDepositFlow();
        }, 1000);
    }

    function watchPauseHotkey() {
        document.addEventListener('keydown', (event) => {
            if (event.defaultPrevented) return;

            const target = event.target;
            if (target && (
                target.tagName === 'INPUT' ||
                target.tagName === 'TEXTAREA' ||
                target.tagName === 'SELECT' ||
                target.isContentEditable
            )) {
                return;
            }

            const { pauseHotkey } = getSettings();
            if (!doesEventMatchPauseHotkey(event, pauseHotkey)) return;

            event.preventDefault();
            setPausedState(!isPaused());
        });
    }

    function init() {
        createUI();
        watchLeadership();
        watchLife();
        watchCash();
        watchFlow();
        watchPauseHotkey();
        updateUIStatus();
    }

    init();
})();
