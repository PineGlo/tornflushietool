            if (data?.error) {
              resolve({
                ok: false,
                factionId,
                error: data.error.error || "Faction members API error",
                errorCode: Number(data.error.code) || null,
              });
              return;
            }

            const members = data?.members || data || {};
            resolve({
              ok: true,
