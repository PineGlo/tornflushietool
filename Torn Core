    function updateDomState() {
        const t = now();
        const pageType = getPageType();

        const life = parseLifeBox();
        const cash = parseCashBox();
        const vault = parseVaultSection();
        const trade = parseTradeSection();
        const hospital = parseHospitalGlobal();
        const combat = parseAttackPage();

        const prevLife = state.prev.lifeCurrent;
        const prevCash = state.prev.cashOnHand;
        const prevVault = state.prev.vaultCash;

        const lifeDelta = (Number.isFinite(life.current) && Number.isFinite(prevLife)) ? life.current - prevLife : null;
        const lifeDrop = (Number.isFinite(lifeDelta) && lifeDelta < 0) ? Math.abs(lifeDelta) : 0;
        const lifeRise = (Number.isFinite(lifeDelta) && lifeDelta > 0) ? lifeDelta : 0;

        const cashDelta = (Number.isFinite(cash.onHand) && Number.isFinite(prevCash)) ? cash.onHand - prevCash : null;
        const cashIncrease = (Number.isFinite(cashDelta) && cashDelta > 0) ? cashDelta : 0;

        const vaultDelta = (Number.isFinite(vault.cash) && Number.isFinite(prevVault)) ? vault.cash - prevVault : null;

        const lifePct = (Number.isFinite(life.current) && Number.isFinite(life.max) && life.max > 0)
            ? (life.current / life.max) * 100
            : null;

        const href = location.href;
        const path = location.pathname;
        const hash = location.hash;

        state.core.dom.ts = t;
        state.core.dom.domVersion = ++state.version;
        state.core.dom.url = {
            href,
            path,
            hash,
            changed: href !== state.prev.href,
            pathChanged: path !== state.prev.path,
            hashChanged: hash !== state.prev.hash,
        };

        state.core.dom.page = {
            type: pageType,
            isPropertiesPage: pageType === 'properties' || pageType === 'vault',
            isVaultPage: pageType === 'vault',
            isAttackPage: pageType === 'attack',
            isTradePage: pageType === 'trade',
            isBazaarPage: pageType === 'bazaar',
            isFactionPage: pageType === 'faction',
            isProfilePage: pageType === 'profile',
        };

        state.core.dom.life = {
            current: life.current,
            max: life.max,
            pct: lifePct,
            delta: lifeDelta,
            drop: lifeDrop,
            rise: lifeRise,
            changed: Number.isFinite(lifeDelta) && lifeDelta !== 0,
            source: life.source,
        };

        state.core.dom.cash = {
            onHand: cash.onHand,
            delta: cashDelta,
            increase: cashIncrease,
            changed: Number.isFinite(cashDelta) && cashDelta !== 0,
            source: cash.source,
        };

        state.core.dom.vault = {
            cash: vault.cash,
            delta: vaultDelta,
            changed: Number.isFinite(vaultDelta) && vaultDelta !== 0,
            title: vault.title,
            input: vault.input,
        };

        state.core.dom.actions = vault.actions;
        state.core.dom.trade = trade;
        state.core.dom.hospital = hospital;
        state.core.dom.combat = {
            attackDetected: !!combat.onAttackPage || lifeDrop > 0,
            onAttackPage: !!combat.onAttackPage,
            targetHospitalDialog: combat.targetHospitalDialog,
            targetReleaseEtaText: combat.targetReleaseEtaText,
            targetUserId: combat.targetUserId,
        };

        state.prev.href = href;
        state.prev.path = path;
        state.prev.hash = hash;
        if (Number.isFinite(life.current)) state.prev.lifeCurrent = life.current;
        if (Number.isFinite(cash.onHand)) state.prev.cashOnHand = cash.onHand;
        if (Number.isFinite(vault.cash)) state.prev.vaultCash = vault.cash;
    }

    function sourceRank(source) {
        return SOURCE_PRIORITY[String(source || '').trim()] || 0;
    }

    function shouldTakePatch(existingSource, patchSource, existingAt = 0, patchAt = 0) {
        const existingRank = sourceRank(existingSource);
        const patchRank = sourceRank(patchSource);
        if (patchRank > existingRank) return true;
        if (patchRank < existingRank) return false;
        return Number(patchAt || 0) >= Number(existingAt || 0);
    }

    function mergeTruthyText(currentValue, nextValue) {
        const next = normalizeText(nextValue);
        return next || currentValue || '';
    }

    function mergeUserRecord(existing, patch = {}) {
        const merged = JSON.parse(JSON.stringify(existing));

        merged.name = mergeTruthyText(merged.name, patch.name);
        merged.links = {
            ...merged.links,
            ...(patch.links || {}),
        };

        if (patch.dom) {
            const dom = patch.dom;
            merged.dom.statusText = mergeTruthyText(merged.dom.statusText, normalizeStatusText(dom.statusText));
            merged.dom.statusClass = mergeTruthyText(merged.dom.statusClass, dom.statusClass);
            merged.dom.hospitalText = mergeTruthyText(merged.dom.hospitalText, dom.hospitalText);
            merged.dom.hospitalReason = mergeTruthyText(merged.dom.hospitalReason, dom.hospitalReason);
            merged.dom.travelText = mergeTruthyText(merged.dom.travelText, dom.travelText);
            merged.dom.travelDestination = mergeTruthyText(merged.dom.travelDestination, dom.travelDestination || parseTravelDestination(dom.travelText));
            merged.dom.roleText = mergeTruthyText(merged.dom.roleText, dom.roleText);
            merged.dom.levelText = mergeTruthyText(merged.dom.levelText, dom.levelText);
        }

        if (patch.ff) {
            const patchSource = patch.ff.source || merged.ff.source || 'unknown';
            const patchAt = Number(patch.ff.lastRefreshAt || 0);
            const existingAt = Number(merged.ff.lastRefreshAt || 0);

            merged.ff.visibleFairFight = mergeTruthyText(merged.ff.visibleFairFight, patch.ff.visibleFairFight);
            merged.ff.visibleEstimatedStats = mergeTruthyText(merged.ff.visibleEstimatedStats, patch.ff.visibleEstimatedStats);

            const hasPatchEstimate = patch.ff.estimatedStats != null || patch.ff.estimatedStatsHuman;
            if (hasPatchEstimate && shouldTakePatch(merged.ff.source, patchSource, existingAt, patchAt)) {
                if (patch.ff.estimatedStats != null) merged.ff.estimatedStats = patch.ff.estimatedStats;
                merged.ff.estimatedStatsHuman = mergeTruthyText(merged.ff.estimatedStatsHuman, patch.ff.estimatedStatsHuman);
                merged.ff.lastRefreshAt = patchAt || now();
                merged.ff.source = patchSource;
            } else if (!merged.ff.source && patchSource) {
                merged.ff.source = patchSource;
            }
        }

        if (patch.torn) {
            const patchSource = patch.torn.source || merged.torn.source || 'unknown';
            const patchAt = Number(patch.torn.lastRefreshAt || 0);
            const existingAt = Number(merged.torn.lastRefreshAt || 0);
            const canReplace = shouldTakePatch(merged.torn.source, patchSource, existingAt, patchAt);

            if (canReplace) {
                merged.torn.status = mergeTruthyText(merged.torn.status, normalizeStatusText(patch.torn.status));
                const nextUntil = Number(patch.torn.hospitalUntil || 0);
                if (Number.isFinite(nextUntil) && nextUntil > 0) {
                    merged.torn.hospitalUntil = nextUntil;
                }
                merged.torn.hospitalEtaText = mergeTruthyText(
                    merged.torn.hospitalEtaText,
                    patch.torn.hospitalEtaText || parseHospitalEtaText(patch.dom?.hospitalText)
                );
                merged.torn.lastRefreshAt = patchAt || now();
                merged.torn.source = patchSource;
            } else if (!merged.torn.source && patchSource) {
                merged.torn.source = patchSource;
            }
        }

        return merged;
    }

