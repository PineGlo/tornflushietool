    function scanProfilePage() {
        if (!state.core.dom.page.isProfilePage) return;

        const userId = parseXidFromHref(location.href);
        if (!Number.isFinite(userId)) return;

        const mainDesc = normalizeText(document.querySelector('.main-desc')?.innerText || '');
        const subDesc = normalizeText(document.querySelector('.sub-desc')?.innerText || '');

        const patch = {
            links: {
                profile: location.pathname + location.search,
            },
            dom: {},
        };

        if (/in hospital/i.test(mainDesc)) {
            patch.dom.hospitalText = mainDesc;
            patch.dom.hospitalReason = subDesc;
            patch.dom.statusText = 'Hospital';
            patch.torn = {
                status: 'Hospital',
                hospitalEtaText: parseHospitalEtaText(mainDesc),
                source: 'profile_dom',
                lastRefreshAt: now(),
            };
        } else if (/traveling to/i.test(mainDesc) || /returning to torn/i.test(mainDesc)) {
            patch.dom.travelText = mainDesc;
            patch.dom.statusText = 'Traveling';

            const m = mainDesc.match(/traveling to\s+(.+)$/i);
            if (m) {
                patch.dom.travelDestination = normalizeText(m[1]);
            }
            patch.torn = {
                status: 'Traveling',
                source: 'profile_dom',
                lastRefreshAt: now(),
            };
        } else if (/okay/i.test(mainDesc)) {
            patch.dom.statusText = 'Okay';
            patch.torn = {
                status: 'Okay',
                source: 'profile_dom',
                lastRefreshAt: now(),
            };
        }

        ensureUserRecord(userId, patch);
    }

