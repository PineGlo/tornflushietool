        const dom = state.core.dom;
        const userCount = Object.keys(state.core.users.byId).length;
        const roleClass = state.isLeader ? 'tc-good' : 'tc-warn';

        state.panelBody.innerHTML = `
            <div class="tc-section">
                <div class="tc-row"><span>Role</span><strong class="${roleClass}">${state.isLeader ? 'Leader' : 'Follower'}</strong></div>
                <div class="tc-row"><span>Page</span><strong>${dom.page.type}</strong></div>
                <div class="tc-row"><span>Users cached</span><strong>${userCount}</strong></div>
                <div class="tc-row"><span>Attack page</span><strong>${dom.page.isAttackPage ? 'Yes' : 'No'}</strong></div>
                <div class="tc-row"><span>Vault page</span><strong>${dom.page.isVaultPage ? 'Yes' : 'No'}</strong></div>
            </div>

            <div class="tc-section">
                <div class="tc-row"><span>Life</span><strong>${dom.life.current ?? '-'} / ${dom.life.max ?? '-'}</strong></div>
