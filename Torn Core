  function wirePanelEvents() {
    if (!state.panel) return;

    const head = state.panel.querySelector("#torn-core-head");
    const body = state.panel.querySelector("#torn-core-body");
    if (!head || !body) return;

    head.ondblclick = () => {
      const collapsed = body.style.display === "none";
      body.style.display = collapsed ? "" : "none";
      GM_setValue(STORAGE_KEYS.panelCollapsed, !collapsed);
    };

    let drag = null;
    head.onmousedown = (e) => {
      if (e.target.closest("button,input,textarea,label")) return;
      drag = {
        startX: e.clientX,
        startY: e.clientY,
        left: state.panel.offsetLeft,
        top: state.panel.offsetTop,
      };
      e.preventDefault();
    };

    document.addEventListener("mousemove", (e) => {
      if (!drag) return;
      const left = drag.left + (e.clientX - drag.startX);
      const top = drag.top + (e.clientY - drag.startY);
      state.panel.style.left = `${left}px`;
      state.panel.style.top = `${top}px`;
      GM_setValue(STORAGE_KEYS.panelX, left);
      GM_setValue(STORAGE_KEYS.panelY, top);
    });

    document.addEventListener("mouseup", () => {
      drag = null;
    });

    const saveBtn = state.panel.querySelector("#tc-save");
    const publishBtn = state.panel.querySelector("#tc-force-publish");
    const protectionBtn = state.panel.querySelector("#tc-refresh-protection");

    if (saveBtn) {
      saveBtn.onclick = async () => {
        state.cfg.enabled = !!state.panel.querySelector("#tc-enabled")?.checked;
        state.cfg.tornApiKey = String(state.panel.querySelector("#tc-torn-key")?.value || "").trim();
        state.cfg.ffApiKey = String(state.panel.querySelector("#tc-ff-key")?.value || "").trim();
        state.cfg.tornApiHardLimitEnabled = !!state.panel.querySelector("#tc-torn-hard-limit-enabled")?.checked;
        state.cfg.tornApiCallLimit = clamp(Number(state.panel.querySelector("#tc-torn-call-limit")?.value || 90), 1, 10000);
        state.cfg.tornApiLimitWindowMs = Math.max(1000, Number(state.panel.querySelector("#tc-torn-window-seconds")?.value || 60) * 1000);
        state.cfg.allianceProtectionEnabled = !!state.panel.querySelector("#tc-protection-enabled")?.checked;
        state.cfg.allianceSkipPollingProtected = !!state.panel.querySelector("#tc-protection-skip")?.checked;
        state.cfg.allianceHighlightBlue = !!state.panel.querySelector("#tc-protection-blue")?.checked;
        state.cfg.protectedFactionsText = String(state.panel.querySelector("#tc-protection-factions")?.value || "").trim();

        saveSettings();
        refreshApiStatus();
        publishCore(true);

        if (state.isLeader) {
          await refreshProtectedMembers(true);
        }
        renderPanel();
      };
    }

    if (publishBtn) {
      publishBtn.onclick = () => {
        refreshApiStatus();
        publishCore(true);
      };
    }

    if (protectionBtn) {
      protectionBtn.onclick = async () => {
        if (!state.isLeader) return;
        await refreshProtectedMembers(true);
        renderPanel();
      };
    }
  }

  function renderPanel() {
    if (!state.panel || isWeav3rPage()) return;
    const active = document.activeElement?.id;
    state.panel.innerHTML = buildPanelHtml();

    if (active) {
      const el = state.panel.querySelector(`#${CSS.escape(active)}`);
      if (el && (el.tagName === "INPUT" || el.tagName === "TEXTAREA")) {
        const valueLen = el.value.length;
        el.focus();
        try { el.setSelectionRange(valueLen, valueLen); } catch {}
      }
    }

    wirePanelEvents();
  }

  function exposeBridgeWindowApi(snapshot) {
    window.TornCore = {
      getState() {
        return snapshot || GM_getValue(BRIDGE_KEYS.snapshot, null);
      },
      getDomState() {
        return (snapshot || GM_getValue(BRIDGE_KEYS.snapshot, null))?.dom || null;
      },
      getUsers() {
        return (snapshot || GM_getValue(BRIDGE_KEYS.snapshot, null))?.users || { byId: {} };
      },
      getUser(userId) {
        const snap = snapshot || GM_getValue(BRIDGE_KEYS.snapshot, null);
        return snap?.users?.byId?.[String(userId)] || null;
      },
      getProtectedMembers() {
        const snap = snapshot || GM_getValue(BRIDGE_KEYS.snapshot, null);
        return snap?.protectedMembers || { byUserId: {} };
      },
      request(type, payload = {}) {
        return requestBridgeBroker(type, payload);
      },
      requestUsersFFRefresh(userIds = [], opts = {}) {
        return requestBridgeBroker("user.refresh.ff.batch", { userIds, ...opts });
      },
      requestUsersTornRefresh(userIds = [], opts = {}) {
        return requestBridgeBroker("user.refresh.torn.batch", { userIds, ...opts });
      },
      subscribe(callback) {
        if (typeof callback !== "function") return () => {};
        let lastTs = Number((snapshot || GM_getValue(BRIDGE_KEYS.snapshot, null))?.ts || 0);
        const timer = setInterval(() => {
          const next = GM_getValue(BRIDGE_KEYS.snapshot, null);
          const ts = Number(next?.ts || 0);
          if (ts && ts !== lastTs) {
            lastTs = ts;
            callback(next);
          }
        }, 1000);
        return () => clearInterval(timer);
      },
    };
  }

  function requestBridgeBroker(type, payload = {}) {
    const requestId = `bridge_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
    const queue = GM_getValue(BRIDGE_KEYS.requests, []);
    queue.push({
      id: requestId,
      type,
      payload,
      createdAt: now(),
      requester: "bridge_window_client",
    });
    GM_setValue(BRIDGE_KEYS.requests, queue.slice(-100));

    return new Promise((resolve) => {
      const started = now();
      const timer = setInterval(() => {
        const responses = GM_getValue(BRIDGE_KEYS.responses, []);
        const hit = responses.find((item) => item?.requestId === requestId);
        if (hit) {
          clearInterval(timer);
          resolve(hit.result || { ok: false, error: "Empty bridge response." });
          return;
        }
        if ((now() - started) > 7000) {
          clearInterval(timer);
          resolve({ ok: false, timeout: true, error: "Bridge request timeout." });
        }
      }, 300);
    });
  }

  function setupBridgeDomEvents() {
    window.addEventListener("torn-core-bridge-request", (event) => {
      const detail = event?.detail || {};
      const requestId = detail?.id;
      const type = String(detail?.type || "");
      const payload = detail?.payload || {};
      if (!requestId || !type) return;

      const respond = (result) => {
        window.dispatchEvent(new CustomEvent("torn-core-bridge-response", {
          detail: { id: requestId, result },
        }));
      };

      if (type === "core.getSnapshot") {
        respond({ ok: true, data: GM_getValue(BRIDGE_KEYS.snapshot, null) || null });
        return;
      }

      requestBridgeBroker(type, payload)
        .then((result) => respond(result))
        .catch((err) => respond({ ok: false, error: String(err?.message || err || "Bridge DOM request failed") }));
    });
  }

  function initBridgeClientMode() {
    const snap = GM_getValue(BRIDGE_KEYS.snapshot, null);
    exposeBridgeWindowApi(snap);
    setupBridgeDomEvents();
  }

  function installUnloadHandler() {
    window.addEventListener("beforeunload", () => {
      if (!state.isLeader) return;
      const rec = GM_getValue(STORAGE_KEYS.leader, null);
      if (rec?.tabId === state.tabId) GM_setValue(STORAGE_KEYS.leader, null);
    });
  }

  function startProtectionLoop() {
    if (state.loops.protection) clearInterval(state.loops.protection);

    state.loops.protection = setInterval(() => {
      if (!state.isLeader) return;
      refreshProtectedMembers(false).catch((err) => {
        state.core.protectedMembers.lastError = String(err?.message || err || "Protection refresh failed");
        publishCore(true);
      });
    }, Math.max(60 * 1000, Number(state.cfg.allianceRefreshMs) || (3 * 24 * 60 * 60 * 1000)));
  }

  function init() {
    if (isWeav3rPage()) {
      initBridgeClientMode();
      return;
    }

    setupBroadcastChannel();
    ensureCoreShape();

    const snap = loadSnapshot();
    if (snap && !state.isLeader) applySnapshot(snap);

    maybeBecomeLeader();
    exposeWindowApi();
    createPanel();
    installUnloadHandler();

    domTick(true);

    state.loops.leader = setInterval(() => {
      maybeBecomeLeader();
      if (state.isLeader) heartbeatLeader();
    }, Math.max(500, Number(state.cfg.leaderHeartbeatMs) || 1500));

    state.loops.bridge = setInterval(() => {
      processBridgeRequests();
    }, 800);

    startProtectionLoop();

    if (state.isLeader) {
      refreshProtectedMembers(false).catch((err) => {
        state.core.protectedMembers.lastError = String(err?.message || err || "Initial protection refresh failed");
        publishCore(true);
      });
    }
  }

  init();
})();
