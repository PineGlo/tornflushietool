    function applyUserDerivedTiming(user) {
        const t = now();
        const status = (user.dom.statusText || '').toLowerCase();
        const hospitalText = (user.dom.hospitalText || '').toLowerCase();
        const travelText = (user.dom.travelText || '').toLowerCase();

        user.derived.isOkay = status === 'okay';
        user.derived.isHospitalized = status === 'hospital' || hospitalText.includes('hospital');
        user.derived.isTraveling = status === 'traveling' || travelText.includes('traveling');
        user.derived.isReturning = travelText.includes('returning to torn');
        user.derived.isAbroad = user.derived.isTraveling || /traveling to|returning to|in [a-z]/i.test(user.dom.travelText || '');

        if (user.derived.isOkay) {
            if (!user.timing.firstSeenOkayAt) user.timing.firstSeenOkayAt = t;
            user.timing.lastSeenOkayAt = t;
        }
        if (user.derived.isHospitalized) {
            if (!user.timing.firstSeenHospitalAt) user.timing.firstSeenHospitalAt = t;
            user.timing.lastSeenHospitalAt = t;
        }
        if (user.derived.isTraveling) {
            if (!user.timing.firstSeenTravelingAt) user.timing.firstSeenTravelingAt = t;
            user.timing.lastSeenTravelingAt = t;
        }
        if (user.derived.isReturning) {
            if (!user.timing.firstSeenReturningAt) user.timing.firstSeenReturningAt = t;
            user.timing.lastSeenReturningAt = t;
        }

        if (!user.links.attack && user.userId) {
            user.links.attack = `/page.php?sid=attack&user2ID=${user.userId}`;
        }
    }

