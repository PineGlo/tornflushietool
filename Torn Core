// ==UserScript==
// @name         Torn Core v2 Rebuild + Alliance Protection
// @namespace    pineglow.torn.core
// @version      2.2.0
// @description  Shared Torn runtime core for Torn + Weav3r. Provides cached user truth, Torn API refresh, FFScouter API refresh, leader tab brokering, and alliance/protected-member caching.
// @match        https://www.torn.com/*
// @match        https://weav3r.dev/item/*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @connect      api.torn.com
// @connect      ffscouter.com
// @run-at       document-idle
// ==/UserScript==

(function () {
  "use strict";

  const CHANNEL_NAME = "torn_core_v2_channel";
  const EVENT_NAME = "torn_core_v2_update";

  const BRIDGE_KEYS = {
    snapshot: "torn_core_v2_bridge_snapshot",
    requests: "torn_core_v2_bridge_requests",
    responses: "torn_core_v2_bridge_responses",
  };

  const STORAGE_KEYS = {
    settings: "torn_core_v2_settings",
    leader: "torn_core_v2_leader",
    snapshot: "torn_core_v2_snapshot",
    panelCollapsed: "torn_core_v2_panel_collapsed",
    panelX: "torn_core_v2_panel_x",
    panelY: "torn_core_v2_panel_y",
    tabId: "torn_core_v2_tab_id",
  };

  const DEFAULT_PROTECTED_FACTIONS = [
    { id: 48635, name: "Combat Ready Rockstars" },
    { id: 2738088, name: "CR-ACK" },
    { id: 51679, name: "CRashpad" },
    { id: 51064, name: "Combat Ready Massacre" },
    { id: 44445, name: "Combat Ready HQ" },
  ];

  const DEFAULTS = {
    enabled: true,
    showPanel: true,
    debug: false,

    domPollFastMs: 500,
    domPollMediumMs: 1500,
    domPollSlowMs: 3000,

    leaderHeartbeatMs: 1500,
    leaderStaleMs: 5000,
    heartbeatPublishMs: 5000,

    tornApiKey: "",
    ffApiKey: "",
    tornApiHardLimitEnabled: true,
    tornApiCallLimit: 90,
    tornApiLimitWindowMs: 60 * 1000,

    tornBatchTtlMs: 60 * 1000,
    ffBatchTtlMs: 3 * 24 * 60 * 60 * 1000,
    visibleUserStaleMs: 120 * 1000,
    attackTruthTtlMs: 60 * 1000,
    profileTruthTtlMs: 5 * 60 * 1000,

    ffMaxBatchSize: 50,
    tornMaxBatchSize: 15,

    allianceProtectionEnabled: true,
    allianceHighlightBlue: true,
    allianceSkipPollingProtected: true,
    allianceRefreshMs: 3 * 24 * 60 * 60 * 1000,
    protectedFactionsText: DEFAULT_PROTECTED_FACTIONS.map((f) => `${f.id}|${f.name}`).join("\n"),
  };

  const SOURCE_PRIORITY = {
    unknown: 0,
    dom_visible: 1,
    profile_dom: 2,
    ff_cache_db: 3,
    torn_batch_api: 3,
    ff_batch_api: 4,
    attack_loader: 5,
    protected_members_api: 6,
  };

  const state = {
    tabId: getOrCreateTabId(),
    bc: typeof BroadcastChannel !== "undefined" ? new BroadcastChannel(CHANNEL_NAME) : null,
    cfg: loadSettings(),
    isLeader: false,

    loops: {
      dom: null,
      leader: null,
      bridge: null,
      protection: null,
    },

    brokerSeq: 0,
    brokerPending: {},

    panel: null,

    version: 0,
    lastPublishedJson: "",
    lastPublishedAt: 0,

    prev: {
      href: location.href,
      path: location.pathname,
      hash: location.hash,
      lifeCurrent: null,
      cashOnHand: null,
    },

    core: {
      ts: 0,
      schemaVersion: 2,
      coreVersion: "2.2.0",
      leaderTabId: null,

      dom: {
        ts: 0,
        domVersion: 0,
        url: {
          href: location.href,
          path: location.pathname,
          hash: location.hash,
          changed: false,
          pathChanged: false,
          hashChanged: false,
        },
        page: {
          type: "other",
          isPropertiesPage: false,
          isVaultPage: false,
          isAttackPage: false,
          isTradePage: false,
          isBazaarPage: false,
          isFactionPage: false,
          isProfilePage: false,
        },
        life: {
          current: null,
          max: null,
          pct: null,
          delta: null,
          drop: 0,
          rise: 0,
          changed: false,
          source: "",
        },
        cash: {
          onHand: null,
          delta: null,
          increase: 0,
          changed: false,
          source: "",
        },
        hospital: {
          hasGlobalHospitalIcon: false,
          label: "",
        },
        combat: {
          attackDetected: false,
          onAttackPage: false,
          targetHospitalDialog: "",
          targetReleaseEtaText: "",
          targetUserId: null,
        },
      },

      users: {
        byId: {},
      },

      api: {
        cache: {
          torn: {},
          ff: {},
        },
        inFlight: {},
        status: {
          tornApiKeyConfigured: false,
          ffApiKeyConfigured: false,
          tornLastSuccessAt: 0,
          ffLastSuccessAt: 0,
          tornLastError: "",
          ffLastError: "",
          updatedAt: 0,
          ffRateLimitLimit: null,
          ffRateLimitRemaining: null,
          ffRateLimitResetAt: null,
          tornApiCallsInWindow: 0,
          tornApiLimit: 0,
          tornApiWindowMs: 0,
          tornApiWindowStartedAt: 0,
          tornApiWindowResetAt: 0,
          tornApiHardLimitHitCount: 0,
          tornApiTotalCalls: 0,
        },
        stats: {
          lastBatchTornAt: 0,
          lastBatchFFAt: 0,
        },
      },

      protectedMembers: {
        byUserId: {},
        factionIds: [],
        lastRefreshAt: 0,
        lastError: "",
      },

      requests: {
        pending: [],
      },
    },
  };

  function getOrCreateTabId() {
    const existing = sessionStorage.getItem(STORAGE_KEYS.tabId);
    if (existing) return existing;
    const created = `core_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`;
    sessionStorage.setItem(STORAGE_KEYS.tabId, created);
    return created;
  }

  function isWeav3rPage() {
    return location.hostname === "weav3r.dev" && location.pathname.startsWith("/item/");
  }

  function loadSettings() {
    const raw = GM_getValue(STORAGE_KEYS.settings, {}) || {};
    return { ...DEFAULTS, ...raw };
  }

  function saveSettings() {
    GM_setValue(STORAGE_KEYS.settings, state.cfg);
  }

  function log(...args) {
    if (state.cfg.debug) console.log("[TORN CORE]", ...args);
  }

  function now() {
    return Date.now();
  }

  function clamp(n, min, max) {
    return Math.max(min, Math.min(max, n));
  }

  function safeJsonParse(text, fallback = null) {
    try {
      return JSON.parse(text);
    } catch {
      return fallback;
    }
  }

  function normalizeText(text) {
    return String(text || "").replace(/\s+/g, " ").trim();
  }

  function toNumber(v) {
    const n = Number(v);
    return Number.isFinite(n) ? n : null;
  }

  function parseMoney(text) {
    if (!text) return null;
    const cleaned = String(text).replace(/[^0-9.-]/g, "");
    if (!cleaned) return null;
    const n = Number(cleaned.replace(/,/g, ""));
    return Number.isFinite(n) ? n : null;
  }

  function parseUser2IdFromHref(href) {
    if (!href) return null;
    const m = String(href).match(/[?&]user2ID=(\d+)/i);
    return m ? Number(m[1]) : null;
  }

  function parseXidFromHref(href) {
    if (!href) return null;
    const m = String(href).match(/[?&]XID=(\d+)/i);
    return m ? Number(m[1]) : null;
  }

  function parseUserIdFromHref(href) {
    if (!href) return null;
    const m = String(href).match(/[?&]userId=(\d+)/i);
    return m ? Number(m[1]) : null;
  }

  function normalizeStatusText(text) {
    const s = normalizeText(text).toLowerCase();
    if (!s) return "";
    if (s === "okay") return "Okay";
    if (s.includes("hospital")) return "Hospital";
    if (s.includes("traveling") || s.includes("returning to torn")) return "Traveling";
    if (s.includes("abroad")) return "Traveling";
    return normalizeText(text);
  }

  function toEpochMs(value) {
    const n = Number(value);
    if (!Number.isFinite(n) || n <= 0) return null;
    return n < 1e12 ? n * 1000 : n;
  }

  function fmtAgo(ts) {
    if (!ts) return "-";
    const ms = now() - Number(ts);
    if (ms < 1000) return "just now";
    if (ms < 60 * 1000) return `${Math.floor(ms / 1000)}s ago`;
    if (ms < 60 * 60 * 1000) return `${Math.floor(ms / 60000)}m ago`;
    if (ms < 24 * 60 * 60 * 1000) return `${Math.floor(ms / 3600000)}h ago`;
    return `${Math.floor(ms / 86400000)}d ago`;
  }

  function fmtIn(ts) {
    if (!ts) return "-";
    const ms = Number(ts) - now();
    if (ms <= 0) return "now";
    if (ms < 60 * 1000) return `${Math.ceil(ms / 1000)}s`;
    if (ms < 60 * 60 * 1000) return `${Math.ceil(ms / 60000)}m`;
    if (ms < 24 * 60 * 60 * 1000) return `${Math.ceil(ms / 3600000)}h`;
    return `${Math.ceil(ms / 86400000)}d`;
  }

  function sourceRank(source) {
    return SOURCE_PRIORITY[String(source || "").trim()] || 0;
  }

  function shouldTakePatch(existingSource, patchSource, existingAt = 0, patchAt = 0) {
    const existingRank = sourceRank(existingSource);
    const patchRank = sourceRank(patchSource);
    if (patchRank > existingRank) return true;
    if (patchRank < existingRank) return false;
    return Number(patchAt || 0) >= Number(existingAt || 0);
  }

  function parseProtectedFactionsText(text) {
    const lines = String(text || "")
      .split(/\r?\n/)
      .map((s) => s.trim())
      .filter(Boolean);

    const out = [];
    const seen = new Set();

    for (const line of lines) {
      const parts = line.split("|");
      const id = Number(parts[0]?.trim());
      const name = normalizeText(parts.slice(1).join("|"));
      if (!Number.isFinite(id) || seen.has(id)) continue;
      seen.add(id);
      out.push({
        id,
        name: name || `Faction ${id}`,
      });
    }

    return out;
  }

  function ensureCoreShape() {
    if (!state.core.api) state.core.api = {};
    if (!state.core.api.cache) state.core.api.cache = { torn: {}, ff: {} };
    if (!state.core.api.inFlight) state.core.api.inFlight = {};
    if (!state.core.api.tornRateTracker) {
      state.core.api.tornRateTracker = {
        windowStartedAt: now(),
        callsInWindow: 0,
        totalCalls: 0,
        blockedCount: 0,
        lastBlockedAt: 0,
        lastCallAt: 0,
      };
    }
    if (!state.core.api.stats) state.core.api.stats = { lastBatchTornAt: 0, lastBatchFFAt: 0 };
    if (!state.core.api.status) {
      state.core.api.status = {
        tornApiKeyConfigured: false,
        ffApiKeyConfigured: false,
        tornLastSuccessAt: 0,
        ffLastSuccessAt: 0,
        tornLastError: "",
        ffLastError: "",
        updatedAt: 0,
        ffRateLimitLimit: null,
        ffRateLimitRemaining: null,
        ffRateLimitResetAt: null,
        tornApiCallsInWindow: 0,
        tornApiLimit: 0,
        tornApiWindowMs: 0,
        tornApiWindowStartedAt: 0,
        tornApiWindowResetAt: 0,
        tornApiHardLimitHitCount: 0,
        tornApiTotalCalls: 0,
      };
    }
    if (!state.core.protectedMembers) {
      state.core.protectedMembers = {
        byUserId: {},
        factionIds: [],
        lastRefreshAt: 0,
        lastError: "",
      };
    }
    if (!Number.isFinite(Number(state.core.api.tornRateTracker.windowStartedAt))) {
      state.core.api.tornRateTracker.windowStartedAt = now();
    }
  }

  function syncTornRateStatus() {
    ensureCoreShape();

    const tracker = state.core.api.tornRateTracker;
    const status = state.core.api.status;
    const limit = clamp(Number(state.cfg.tornApiCallLimit) || 90, 1, 10000);
    const windowMs = Math.max(1000, Number(state.cfg.tornApiLimitWindowMs) || (60 * 1000));

    status.tornApiCallsInWindow = Number(tracker.callsInWindow || 0);
    status.tornApiTotalCalls = Number(tracker.totalCalls || 0);
    status.tornApiHardLimitHitCount = Number(tracker.blockedCount || 0);
    status.tornApiLimit = limit;
    status.tornApiWindowMs = windowMs;
    status.tornApiWindowStartedAt = Number(tracker.windowStartedAt || 0);
    status.tornApiWindowResetAt = Number(tracker.windowStartedAt || 0) + windowMs;
  }

  function reserveTornApiCall() {
    ensureCoreShape();
    const tracker = state.core.api.tornRateTracker;
    const hardLimitEnabled = !!state.cfg.tornApiHardLimitEnabled;
    const limit = clamp(Number(state.cfg.tornApiCallLimit) || 90, 1, 10000);
    const windowMs = Math.max(1000, Number(state.cfg.tornApiLimitWindowMs) || (60 * 1000));
    const ts = now();

    if (!tracker.windowStartedAt || (ts - Number(tracker.windowStartedAt)) >= windowMs) {
      tracker.windowStartedAt = ts;
      tracker.callsInWindow = 0;
    }

    if (hardLimitEnabled && Number(tracker.callsInWindow || 0) >= limit) {
      tracker.blockedCount = Number(tracker.blockedCount || 0) + 1;
      tracker.lastBlockedAt = ts;
      syncTornRateStatus();
      return {
        ok: false,
        error: `Torn API hard limit reached (${limit}/${limit} calls per ${Math.round(windowMs / 1000)}s window).`,
      };
    }

    tracker.callsInWindow = Number(tracker.callsInWindow || 0) + 1;
    tracker.totalCalls = Number(tracker.totalCalls || 0) + 1;
    tracker.lastCallAt = ts;
    syncTornRateStatus();
    return { ok: true };
  }

  function makeEmptyUserRecord(userId) {
    return {
      userId: Number(userId),
      name: "",
      links: {
        profile: Number.isFinite(Number(userId)) ? `https://www.torn.com/profiles.php?XID=${Number(userId)}` : "",
        attack: Number.isFinite(Number(userId)) ? `https://www.torn.com/loader.php?sid=attack&user2ID=${Number(userId)}` : "",
        bazaar: Number.isFinite(Number(userId)) ? `https://www.torn.com/bazaar.php?userId=${Number(userId)}` : "",
      },
      dom: {
        statusText: "",
        statusClass: "",
        hospitalText: "",
        travelText: "",
        travelDestination: "",
        lastSeenAt: 0,
        source: "",
      },
      torn: {
        status: "",
        hospitalUntil: null,
        hospitalEtaText: "",
        lastRefreshAt: 0,
        source: "",
      },
      ff: {
        fairFight: null,
        estimatedStats: null,
        estimatedStatsHuman: "",
        distributionHuman: "",
        distributionLastUpdated: null,
        ffLastUpdated: null,
        lastRefreshAt: 0,
        source: "",
      },
      group: {
        factionId: null,
        factionName: "",
        isProtected: false,
        protectedLastRefreshAt: 0,
        source: "",
      },
      seen: {
        lastSeenAt: 0,
        isStale: false,
        attackTruthStale: true,
        profileTruthStale: true,
      },
    };
  }

  function ensureUserRecord(userId, patch = {}) {
    const id = Number(userId);
    if (!Number.isFinite(id)) return null;

    const key = String(id);
    const existing = state.core.users.byId[key] || makeEmptyUserRecord(id);
    const merged = JSON.parse(JSON.stringify(existing));

    if (patch.name) merged.name = normalizeText(patch.name);

    merged.links = {
      ...merged.links,
      ...(patch.links || {}),
    };

    if (patch.dom) {
      const domPatch = patch.dom;
      const domPatchAt = Number(domPatch.lastSeenAt || now());
      if (shouldTakePatch(merged.dom.source, domPatch.source, merged.dom.lastSeenAt, domPatchAt)) {
        merged.dom = {
          ...merged.dom,
          ...domPatch,
          statusText: normalizeText(domPatch.statusText || merged.dom.statusText),
          hospitalText: normalizeText(domPatch.hospitalText || merged.dom.hospitalText),
          travelText: normalizeText(domPatch.travelText || merged.dom.travelText),
          travelDestination: normalizeText(domPatch.travelDestination || merged.dom.travelDestination),
          lastSeenAt: domPatchAt,
          source: domPatch.source || merged.dom.source,
        };
      }
    }

    if (patch.torn) {
      const tornPatch = patch.torn;
      const tornPatchAt = Number(tornPatch.lastRefreshAt || now());
      if (shouldTakePatch(merged.torn.source, tornPatch.source, merged.torn.lastRefreshAt, tornPatchAt)) {
        merged.torn = {
          ...merged.torn,
          ...tornPatch,
          status: normalizeStatusText(tornPatch.status || merged.torn.status),
          lastRefreshAt: tornPatchAt,
          source: tornPatch.source || merged.torn.source,
        };
      }
    }

    if (patch.ff) {
      const ffPatch = patch.ff;
      const ffPatchAt = Number(ffPatch.lastRefreshAt || now());
      if (shouldTakePatch(merged.ff.source, ffPatch.source, merged.ff.lastRefreshAt, ffPatchAt)) {
        merged.ff = {
          ...merged.ff,
          ...ffPatch,
          lastRefreshAt: ffPatchAt,
          source: ffPatch.source || merged.ff.source,
        };
      }
    }

    if (patch.group) {
      const groupPatch = patch.group;
      const patchAt = Number(groupPatch.protectedLastRefreshAt || now());
      if (shouldTakePatch(merged.group.source, groupPatch.source, merged.group.protectedLastRefreshAt, patchAt)) {
        merged.group = {
          ...merged.group,
          ...groupPatch,
          protectedLastRefreshAt: patchAt,
          source: groupPatch.source || merged.group.source,
        };
      }
    }

    const seenAt = Math.max(
      Number(merged.dom.lastSeenAt || 0),
      Number(merged.torn.lastRefreshAt || 0),
      Number(merged.ff.lastRefreshAt || 0),
      Number(patch.seen?.lastSeenAt || 0),
    );

    merged.seen = {
      ...merged.seen,
      ...(patch.seen || {}),
      lastSeenAt: seenAt,
      isStale: false,
      attackTruthStale: !(
        merged.torn?.source === "attack_loader" &&
        Number(merged.torn?.lastRefreshAt || 0) >= (now() - state.cfg.attackTruthTtlMs)
      ),
      profileTruthStale: !(
        merged.torn?.source === "profile_dom" &&
        Number(merged.torn?.lastRefreshAt || 0) >= (now() - state.cfg.profileTruthTtlMs)
      ),
    };

    state.core.users.byId[key] = merged;
    return merged;
  }

  function getLeaderRecord() {
    return GM_getValue(STORAGE_KEYS.leader, null);
  }

  function setLeaderRecord() {
    GM_setValue(STORAGE_KEYS.leader, {
      tabId: state.tabId,
      heartbeatAt: now(),
    });
  }

  function maybeBecomeLeader() {
    const rec = getLeaderRecord();
    const t = now();
    if (!rec || !rec.tabId || (t - Number(rec.heartbeatAt || 0)) > state.cfg.leaderStaleMs) {
      state.isLeader = true;
      state.core.leaderTabId = state.tabId;
      setLeaderRecord();
      return;
    }
    state.isLeader = rec.tabId === state.tabId;
    state.core.leaderTabId = rec.tabId || null;
  }

  function heartbeatLeader() {
    if (!state.isLeader) return;
    setLeaderRecord();
    broadcast({
      type: "leader-heartbeat",
      leaderTabId: state.tabId,
    });
  }

  function broadcast(payload) {
    try {
      if (state.bc) {
        state.bc.postMessage({
          sender: state.tabId,
          at: now(),
          ...payload,
        });
      }
    } catch {}
  }

  function setupBroadcastChannel() {
    if (!state.bc) return;
    state.bc.onmessage = (event) => {
      const msg = event.data || {};
      if (msg.sender === state.tabId) return;

      if (msg.type === "leader-heartbeat") {
        state.core.leaderTabId = msg.leaderTabId || state.core.leaderTabId;
        return;
      }

      if (msg.type === "core-update" && msg.snapshot && !state.isLeader) {
        applySnapshot(msg.snapshot);
        renderPanel();
        exposeWindowApi();
        return;
      }

      if (msg.type === "request-broker" && state.isLeader) {
        handleBrokerMessage(msg);
        return;
      }

      if (msg.type === "broker-response") {
        handleBrokerResponse(msg);
      }
    };
  }

  function exposeWindowApi() {
    window.__TORN_CORE_STATE__ = state.core;
    window.TornCore = {
      getState() {
        return state.core;
      },
      getDomState() {
        return state.core.dom;
      },
      getUsers() {
        return state.core.users;
      },
      getUser(userId) {
        return state.core.users.byId[String(userId)] || null;
      },
      getProtectedMembers() {
        return state.core.protectedMembers || { byUserId: {} };
      },
      async getFreshUser(userId, opts = {}) {
        const id = Number(userId);
        if (!Number.isFinite(id)) return null;
        if (opts.ff) {
          await requestBroker("user.refresh.ff.batch", { userIds: [id], forceFresh: !!opts.forceFresh });
        }
        if (opts.torn !== false) {
          await requestBroker("user.refresh.torn.batch", {
            userIds: [id],
            forceFresh: !!opts.forceFresh,
            forceSingleApi: !!opts.forceSingleApi,
          });
        }
        return state.core.users.byId[String(id)] || null;
      },
      requestUsersFFRefresh(userIds = [], opts = {}) {
        return requestBroker("user.refresh.ff.batch", { userIds, ...opts });
      },
      requestUsersTornRefresh(userIds = [], opts = {}) {
        return requestBroker("user.refresh.torn.batch", { userIds, ...opts });
      },
      refreshProtectedMembers() {
        return requestBroker("protection.refresh", {});
      },
      subscribe(callback) {
        if (typeof callback !== "function") return () => {};
        const handler = (event) => callback(event.detail);
        window.addEventListener(EVENT_NAME, handler);
        return () => window.removeEventListener(EVENT_NAME, handler);
      },
      request(type, payload = {}) {
        return requestBroker(type, payload);
      },
    };
  }

  function dispatchWindowUpdate() {
    try {
      window.dispatchEvent(new CustomEvent(EVENT_NAME, { detail: state.core }));
    } catch {}
  }

  function snapshotCore() {
    return JSON.parse(JSON.stringify(state.core));
  }

  function applySnapshot(snapshot) {
    if (!snapshot || typeof snapshot !== "object") return;
    state.core = snapshot;
    ensureCoreShape();
  }

  function persistSnapshot(snapshot) {
    try {
      localStorage.setItem(STORAGE_KEYS.snapshot, JSON.stringify(snapshot));
    } catch {}
  }

  function loadSnapshot() {
    const raw = localStorage.getItem(STORAGE_KEYS.snapshot);
    return safeJsonParse(raw, null);
  }

  function publishBridgeSnapshot(snapshot) {
    try {
      GM_setValue(BRIDGE_KEYS.snapshot, {
        ts: Number(snapshot?.ts || now()),
        leaderTabId: snapshot?.leaderTabId || null,
        dom: snapshot?.dom || null,
        users: snapshot?.users || { byId: {} },
        protectedMembers: snapshot?.protectedMembers || { byUserId: {} },
        api: {
          stats: snapshot?.api?.stats || {},
          status: snapshot?.api?.status || {},
        },
      });
    } catch (err) {
      log("Failed to publish bridge snapshot", err);
    }
  }

  function publishCore(force = false) {
    ensureCoreShape();
    const snapshot = snapshotCore();
    const json = JSON.stringify(snapshot);
    const heartbeatDue = (now() - state.lastPublishedAt) >= state.cfg.heartbeatPublishMs;

    if (!force && json === state.lastPublishedJson && !heartbeatDue) return false;

    state.lastPublishedJson = json;
    state.lastPublishedAt = now();

    persistSnapshot(snapshot);
    publishBridgeSnapshot(snapshot);
    broadcast({ type: "core-update", snapshot });

    exposeWindowApi();
    dispatchWindowUpdate();
    renderPanel();
    return true;
  }

  function appendBridgeResponse(item) {
    try {
      const raw = GM_getValue(BRIDGE_KEYS.responses, []);
      const responses = Array.isArray(raw) ? raw : [];
      responses.push(item);
      GM_setValue(BRIDGE_KEYS.responses, responses.slice(-200));
    } catch (err) {
      log("Failed to append bridge response", err);
    }
  }

  function processBridgeRequests() {
    if (!state.isLeader) return;

    const rawRequests = GM_getValue(BRIDGE_KEYS.requests, []);
    const requests = Array.isArray(rawRequests) ? rawRequests : [];
    if (!requests.length) return;

    const rawResponses = GM_getValue(BRIDGE_KEYS.responses, []);
    const responses = Array.isArray(rawResponses) ? rawResponses : [];
    const responded = new Set(responses.map((r) => r?.requestId).filter(Boolean));

    requests.forEach((req) => {
      if (!req?.id || responded.has(req.id)) return;
      Promise.resolve(handleBrokerRequest({
        id: req.id,
        type: req.type,
        payload: req.payload || {},
        requesterTabId: req.requester || "bridge",
        requestedAt: Number(req.createdAt) || now(),
      }))
        .then((result) => appendBridgeResponse({ requestId: req.id, at: now(), result }))
        .catch((err) => appendBridgeResponse({
          requestId: req.id,
          at: now(),
          result: { ok: false, error: String(err?.message || err || "Bridge broker execution failed") },
        }));
    });

    if (requests.length > 200) {
      GM_setValue(BRIDGE_KEYS.requests, requests.slice(-200));
    }
  }

  function handleBrokerMessage(msg) {
    const req = msg.request;
    if (!req) return;

    Promise.resolve(handleBrokerRequest(req))
      .then((result) => {
        if (!req.requesterTabId || req.requesterTabId === state.tabId) return;
        broadcast({
          type: "broker-response",
          requestId: req.id,
          requesterTabId: req.requesterTabId,
          result,
        });
      })
      .catch((err) => {
        if (!req.requesterTabId || req.requesterTabId === state.tabId) return;
        broadcast({
          type: "broker-response",
          requestId: req.id,
          requesterTabId: req.requesterTabId,
          result: { ok: false, error: String(err?.message || err || "Broker execution failed") },
        });
      });
  }

  function handleBrokerResponse(msg) {
    if (!msg || msg.requesterTabId !== state.tabId) return;
    const pending = state.brokerPending[msg.requestId];
    if (!pending) return;
    clearTimeout(pending.timeout);
    delete state.brokerPending[msg.requestId];
    pending.resolve(msg.result || { ok: false, error: "Empty broker response" });
  }

  function requestBroker(type, payload = {}) {
    const requestId = `req_${Date.now()}_${++state.brokerSeq}_${Math.random().toString(36).slice(2, 8)}`;
    const req = {
      id: requestId,
      type,
      payload,
      requesterTabId: state.tabId,
      requestedAt: now(),
    };

    if (state.isLeader) return handleBrokerRequest(req);

    broadcast({ type: "request-broker", request: req });

    return new Promise((resolve) => {
      const timeout = setTimeout(() => {
        delete state.brokerPending[requestId];
        resolve({
          ok: false,
          brokered: true,
          timeout: true,
          message: "Broker response timed out waiting for leader.",
          request: req,
        });
      }, 7000);

      state.brokerPending[requestId] = { resolve, timeout };
    });
  }

  function makeCacheKey(type, payload) {
    return `${type}:${JSON.stringify(payload || {})}`;
  }

  function isFresh(entry, ttlMs) {
    return !!entry && (now() - Number(entry.ts || 0)) < ttlMs;
  }

  function refreshApiStatus() {
    ensureCoreShape();
    state.core.api.status.tornApiKeyConfigured = !!String(state.cfg.tornApiKey || "").trim();
    state.core.api.status.ffApiKeyConfigured = !!String(state.cfg.ffApiKey || "").trim();
    syncTornRateStatus();
    state.core.api.status.updatedAt = now();
  }

  function requestTornProfileApi(userId, forceFresh = false) {
    return new Promise((resolve) => {
      const key = String(state.cfg.tornApiKey || "").trim();
      if (!key) {
        resolve({ ok: false, userId, error: "Missing Torn API key in Torn Core settings." });
        return;
      }

      const allowance = reserveTornApiCall();
      if (!allowance.ok) {
        resolve({ ok: false, userId, error: allowance.error, errorCode: "hard_limit" });
        return;
      }

      let url = `https://api.torn.com/user/${Number(userId)}?selections=profile&key=${encodeURIComponent(key)}&comment=torn_core_batch`;
      if (forceFresh) url += `&timestamp=${Date.now()}`;

      GM_xmlhttpRequest({
        method: "GET",
        url,
        onload: (response) => {
          try {
            const data = JSON.parse(response.responseText || "{}");
            if (data.error) {
              resolve({
                ok: false,
                userId,
                error: data.error.error || "API error",
                errorCode: Number(data.error.code) || null,
              });
              return;
            }

            const status = data.status || {};
            const statusText = normalizeStatusText(status.state || status.description || "");
            const hospitalUntil = toEpochMs(status.until);

            resolve({
              ok: true,
              userId,
              status: statusText,
              hospitalUntil,
              hospitalEtaText: "",
              fetchedAt: now(),
            });
          } catch {
            resolve({ ok: false, userId, error: "Parse error" });
          }
        },
        onerror: () => resolve({ ok: false, userId, error: "Network error" }),
        ontimeout: () => resolve({ ok: false, userId, error: "Timeout" }),
      });
    });
  }

  function parseResponseHeaders(headerText) {
    const out = {};
    String(headerText || "")
      .split(/\r?\n/)
      .forEach((line) => {
        const idx = line.indexOf(":");
        if (idx <= 0) return;
        const key = line.slice(0, idx).trim().toLowerCase();
        const value = line.slice(idx + 1).trim();
        if (key) out[key] = value;
      });
    return out;
  }

  function requestFFBatchApi(userIds, forceFresh = false) {
    return new Promise((resolve) => {
      const key = String(state.cfg.ffApiKey || "").trim();
      if (!key) {
        resolve({ ok: false, error: "Missing FF Scouter API key in Torn Core settings.", rows: [] });
        return;
      }

      const uniqueIds = Array.from(new Set((userIds || []).map(Number).filter(Number.isFinite)));
      if (!uniqueIds.length) {
        resolve({ ok: true, rows: [], rateHeaders: {} });
        return;
      }

      const maxBatch = clamp(Number(state.cfg.ffMaxBatchSize) || 50, 1, 100);
      const ids = uniqueIds.slice(0, maxBatch);
      let url = `https://ffscouter.com/api/v1/get-stats?key=${encodeURIComponent(key)}&targets=${ids.join(",")}`;
      if (forceFresh) url += `&timestamp=${Date.now()}`;

      GM_xmlhttpRequest({
        method: "GET",
        url,
        onload: (response) => {
          try {
            if (!response) {
              resolve({ ok: false, error: "Empty FF response.", rows: [] });
              return;
            }

            if (response.status !== 200) {
              let err = `FF API request failed with status ${response.status}`;
              try {
                const parsed = JSON.parse(response.responseText || "{}");
                if (parsed?.error) err = `${parsed.error}${parsed.code ? ` (code ${parsed.code})` : ""}`;
              } catch {}
              resolve({ ok: false, error: err, rows: [] });
              return;
            }

            const parsed = JSON.parse(response.responseText || "[]");
            if (parsed?.error) {
              resolve({ ok: false, error: parsed.error, rows: [] });
              return;
            }

            const threeDays = 3 * 24 * 60 * 60 * 1000;
            const expiry = now() + threeDays;
            const rows = Array.isArray(parsed) ? parsed.map((result) => {
              if (!result || !result.player_id) return null;

              if (result.fair_fight === null) {
                return {
                  player_id: Number(result.player_id),
                  no_data: true,
                  expiry,
                };
              }

              return {
                player_id: Number(result.player_id),
                value: Number(result.fair_fight),
                last_updated: result.last_updated || null,
                expiry,
                bs_estimate: Number.isFinite(Number(result.bs_estimate)) ? Number(result.bs_estimate) : null,
                bs_estimate_human: result.bs_estimate_human || "",
                distribution_human: result.distribution?.distribution_human ?? "",
                distribution_last_updated: result.distribution?.last_updated ?? null,
              };
            }).filter(Boolean) : [];

            resolve({
              ok: true,
              rows,
              rateHeaders: parseResponseHeaders(response.responseHeaders || ""),
            });
          } catch {
            resolve({ ok: false, error: "FF API parse error.", rows: [] });
          }
        },
        onerror: () => resolve({ ok: false, error: "FF API network error.", rows: [] }),
        ontimeout: () => resolve({ ok: false, error: "FF API timeout.", rows: [] }),
      });
    });
  }

  function requestFactionMembersApi(factionId) {
    return new Promise((resolve) => {
      const key = String(state.cfg.tornApiKey || "").trim();
      if (!key) {
        resolve({ ok: false, factionId, error: "Missing Torn API key in Torn Core settings." });
        return;
      }

      const allowance = reserveTornApiCall();
      if (!allowance.ok) {
