                normalizeText(anchor.textContent || '');

            ensureUserRecord(userId, {
                name,
                links: {
                    profile: anchor.getAttribute('href') || '',
                },
            });
        }
    }

    function pruneStaleUsers() {
        const staleMs = state.cfg.visibleUserStaleMs;
        const cutoff = now() - staleMs;
        const attackTruthCutoff = now() - state.cfg.attackTruthTtlMs;
        const profileTruthCutoff = now() - state.cfg.profileTruthTtlMs;

        for (const [key, user] of Object.entries(state.core.users.byId)) {
            if (Number(user.seen.lastSeenAt || 0) < cutoff) {
                // Keep cached but mark stale instead of deleting for now.
                user.seen.isStale = true;
            } else {
                user.seen.isStale = false;
            }

            user.seen.attackTruthStale = !(
                user.torn?.source === 'attack_loader' &&
                Number(user.torn?.lastRefreshAt || 0) >= attackTruthCutoff
            );
            user.seen.profileTruthStale = !(
                user.torn?.source === 'profile_dom' &&
                Number(user.torn?.lastRefreshAt || 0) >= profileTruthCutoff
            );
            state.core.users.byId[key] = user;
        }
    }

    function runPageAdapters() {
        updateDomState();
        scanGenericProfileLinks();
        scanFactionRows();
        scanProfilePage();
        scanAttackPageTarget();
        pruneStaleUsers();

        state.core.ts = now();
    }

    function computeDomPollMs() {
        const dom = state.core.dom;
        if (dom.page.isVaultPage || dom.page.isAttackPage) return state.cfg.domPollFastMs;
        if (dom.page.isFactionPage || dom.page.isTradePage || dom.page.isProfilePage) return state.cfg.domPollMediumMs;
        return state.cfg.domPollSlowMs;
    }

    function restartDomLoop() {
        if (state.loops.dom) clearInterval(state.loops.dom);
        const delay = clamp(Number(computeDomPollMs()) || state.cfg.domPollMediumMs, 100, 10000);
        state.loops.dom = setInterval(domTick, delay);
    }

    function domTick(force = false) {
        if (!state.cfg.enabled) return;

        maybeBecomeLeader();
        runPageAdapters();

        if (state.isLeader) {
            publishCore(force);
        } else {
            renderPanel();
            exposeWindowApi();
        }

        restartDomLoop();
    }

    function createPanel() {
        if (!state.cfg.showPanel) return;

        GM_addStyle(`
            #torn-core-panel {
