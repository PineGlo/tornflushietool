    function getPageType() {
        const href = location.href.toLowerCase();
        const path = location.pathname.toLowerCase();
        const bodyText = normalizeText(document.body?.innerText || '');

        const hasVaultTitle = bodyText.toLowerCase().includes('extra large vault');
        const hasPropertiesTitle = normalizeText(document.querySelector('#skip-to-content')?.innerText || '').toLowerCase() === 'all properties';
        const hasAttackTitle = normalizeText(document.querySelector('h4')?.innerText || '').toLowerCase() === 'attacking';

        if (href.includes('sid=attack') || hasAttackTitle) return 'attack';
        if (hasVaultTitle || (path.includes('/properties.php') && bodyText.toLowerCase().includes('stored in the vault'))) return 'vault';
        if (hasPropertiesTitle || path.includes('/properties.php')) return 'properties';
        if (path.includes('/factions.php')) return 'faction';
        if (path.includes('/profiles.php')) return 'profile';
        if (path.includes('/bazaar.php')) return 'bazaar';
        if (path.includes('/trade.php')) return 'trade';
        return 'other';
    }

