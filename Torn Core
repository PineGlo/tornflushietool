  function openIndexedDb(dbName) {
    return new Promise((resolve, reject) => {
      try {
        const req = indexedDB.open(dbName, 1);

        req.onupgradeneeded = () => {
          const db = req.result;
          if (!db.objectStoreNames.contains("cache")) {
            const store = db.createObjectStore("cache", { keyPath: "player_id" });
            store.createIndex("expiry", ["expiry"], { unique: false });
          }
        };

        req.onerror = () => reject(req.error || new Error(`Failed to open DB ${dbName}`));
        req.onsuccess = () => resolve(req.result);
      } catch (err) {
        reject(err);
      }
    });
  }

  function readAllRows(db, storeName) {
    return new Promise((resolve, reject) => {
      try {
        const tx = db.transaction(storeName, "readonly");
        const store = tx.objectStore(storeName);
        const req = store.getAll();
        req.onerror = () => reject(req.error || new Error("getAll failed"));
        req.onsuccess = () => resolve(req.result || []);
      } catch (err) {
        reject(err);
      }
    });
  }

  async function loadFFRowsByUserIds(userIds) {
    const wanted = new Set((userIds || []).map(Number).filter(Number.isFinite));
    if (!wanted.size) return {};

    let db = null;
    try {
      db = await openIndexedDb("ffscouter-cache");
      const rows = await readAllRows(db, "cache");
      const out = {};

      for (const row of rows) {
        const id = Number(row?.player_id);
        if (!Number.isFinite(id) || !wanted.has(id)) continue;
        if (Number(row?.expiry || 0) > now()) out[String(id)] = row;
      }
      return out;
    } catch (err) {
      log("FF cache read failed", err);
      return {};
    } finally {
      try { db?.close(); } catch {}
    }
  }

  async function writeFFRowsToCache(rows) {
    if (!Array.isArray(rows) || !rows.length) return false;

    let db = null;
    try {
      db = await openIndexedDb("ffscouter-cache");
      await new Promise((resolve, reject) => {
        const tx = db.transaction("cache", "readwrite");
        const store = tx.objectStore("cache");
        tx.onerror = () => reject(tx.error || new Error("cache write failed"));
        tx.oncomplete = () => resolve();

        rows.forEach((row) => store.put(row));
      });
      return true;
    } catch (err) {
      log("FF cache write failed", err);
      return false;
    } finally {
      try { db?.close(); } catch {}
    }
  }

  async function brokerFFBatch(userIds, cacheKey, payload = {}) {
    const uniqueIds = Array.from(new Set((userIds || []).map(Number).filter(Number.isFinite)));
    if (!uniqueIds.length) {
      return { ok: true, source: "policy", data: { userIds: [], mergedUserIds: [], found: 0, missing: 0, status: "ok" } };
    }

    const cached = state.core.api.cache.ff[cacheKey];
    if (!payload.forceFresh && isFresh(cached, state.cfg.ffBatchTtlMs)) {
      return { ok: true, source: "cache", data: cached.data };
    }

    if (state.core.api.inFlight[cacheKey]) return state.core.api.inFlight[cacheKey];

    const promise = new Promise(async (resolve) => {
      const direct = await requestFFBatchApi(uniqueIds, !!payload.forceFresh);

      if (direct.ok) {
        const mergedUsers = [];
        for (const row of direct.rows) {
          const id = Number(row.player_id);
          if (!Number.isFinite(id)) continue;

          ensureUserRecord(id, {
            ff: {
              fairFight: Number.isFinite(Number(row.value)) ? Number(row.value) : null,
              estimatedStats: Number.isFinite(Number(row.bs_estimate)) ? Number(row.bs_estimate) : null,
              estimatedStatsHuman: row.bs_estimate_human || "",
              distributionHuman: row.distribution_human || "",
              distributionLastUpdated: row.distribution_last_updated ? Number(row.distribution_last_updated) : null,
              ffLastUpdated: row.last_updated ? Number(row.last_updated) : null,
              lastRefreshAt: now(),
              source: "ff_batch_api",
            },
          });

          mergedUsers.push(id);
        }

        await writeFFRowsToCache(direct.rows);

        const headers = direct.rateHeaders || {};
        state.core.api.status.ffRateLimitLimit = toNumber(headers["x-ratelimit-limit"]);
        state.core.api.status.ffRateLimitRemaining = toNumber(headers["x-ratelimit-remaining"]);
        state.core.api.status.ffRateLimitResetAt = headers["x-ratelimit-reset-timestamp"]
          ? toEpochMs(Number(headers["x-ratelimit-reset-timestamp"]))
          : null;

        const data = {
          userIds: uniqueIds,
          mergedUserIds: mergedUsers,
          found: mergedUsers.length,
          missing: uniqueIds.length - mergedUsers.length,
          status: "ok",
        };

        state.core.api.cache.ff[cacheKey] = { ts: now(), data };
        state.core.api.stats.lastBatchFFAt = now();
        state.core.api.status.ffLastSuccessAt = now();
        state.core.api.status.ffLastError = "";
        delete state.core.api.inFlight[cacheKey];
        publishCore(true);

        resolve({ ok: true, source: "ff_batch_api", data });
        return;
      }

      const ffRows = await loadFFRowsByUserIds(uniqueIds);
      const mergedUsers = [];

      for (const id of uniqueIds) {
        const row = ffRows[String(id)];
        if (!row) continue;

        ensureUserRecord(id, {
          ff: {
            fairFight: Number.isFinite(Number(row.value)) ? Number(row.value) : null,
            estimatedStats: Number.isFinite(Number(row.bs_estimate)) ? Number(row.bs_estimate) : null,
            estimatedStatsHuman: row.bs_estimate_human || "",
            distributionHuman: row.distribution_human || "",
            distributionLastUpdated: row.distribution_last_updated ? Number(row.distribution_last_updated) : null,
            ffLastUpdated: row.last_updated ? Number(row.last_updated) : null,
            lastRefreshAt: now(),
            source: "ff_cache_db",
          },
        });
        mergedUsers.push(id);
      }

      const data = {
        userIds: uniqueIds,
        mergedUserIds: mergedUsers,
        found: mergedUsers.length,
        missing: uniqueIds.length - mergedUsers.length,
        status: mergedUsers.length ? "cache_fallback" : "error",
        error: direct.error || "FF refresh failed",
      };

      state.core.api.cache.ff[cacheKey] = { ts: now(), data };
      state.core.api.stats.lastBatchFFAt = now();
      state.core.api.status.ffLastError = direct.error || "FF refresh failed";
      delete state.core.api.inFlight[cacheKey];
      publishCore(true);

      resolve({
        ok: mergedUsers.length > 0,
        source: mergedUsers.length ? "ff_cache_db" : "error",
        data,
        error: direct.error || "FF refresh failed",
      });
    });

    state.core.api.inFlight[cacheKey] = promise;
    return promise;
  }

  async function brokerTornBatch(userIds, cacheKey, payload = {}) {
    const uniqueIds = Array.from(new Set((userIds || []).map(Number).filter(Number.isFinite)));
    if (!uniqueIds.length) {
      return { ok: true, source: "policy", data: { userIds: [], results: {}, usedApi: false } };
    }

    const cached = state.core.api.cache.torn[cacheKey];
    if (!payload.forceFresh && isFresh(cached, state.cfg.tornBatchTtlMs)) {
      return { ok: true, source: "cache", data: cached.data };
    }

    if (state.core.api.inFlight[cacheKey]) return state.core.api.inFlight[cacheKey];

    const promise = new Promise(async (resolve) => {
      const results = {};
      const maxBatch = clamp(Number(state.cfg.tornMaxBatchSize) || 15, 1, 25);

      for (const id of uniqueIds.slice(0, maxBatch)) {
        const apiResult = await requestTornProfileApi(id, !!payload.forceFresh);

        if (apiResult.ok) {
          ensureUserRecord(id, {
            torn: {
              status: apiResult.status || "",
              hospitalUntil: apiResult.hospitalUntil || null,
              hospitalEtaText: apiResult.hospitalEtaText || "",
              lastRefreshAt: apiResult.fetchedAt || now(),
              source: "torn_batch_api",
            },
          });
        }

        const merged = state.core.users.byId[String(id)] || null;
        results[String(id)] = {
          ok: !!apiResult.ok,
          error: apiResult.error || null,
          errorCode: apiResult.errorCode || null,
          usedApi: true,
          torn: merged?.torn || null,
        };
      }

      const data = {
        userIds: uniqueIds.slice(0, maxBatch),
        usedApi: true,
        source: "torn_batch_api",
        refreshedAt: now(),
        results,
      };

      state.core.api.cache.torn[cacheKey] = { ts: now(), data };
      state.core.api.stats.lastBatchTornAt = now();

      const hasAnySuccess = Object.values(results).some((r) => r.ok);
      if (hasAnySuccess) {
        state.core.api.status.tornLastSuccessAt = now();
        state.core.api.status.tornLastError = "";
      } else {
        const firstError = Object.values(results).find((r) => r.error)?.error || "Torn refresh failed";
        state.core.api.status.tornLastError = firstError;
      }

      delete state.core.api.inFlight[cacheKey];
      publishCore(true);

      resolve({ ok: hasAnySuccess, source: "torn_batch_api", data });
    });

    state.core.api.inFlight[cacheKey] = promise;
    return promise;
  }

  async function refreshProtectedMembers(force = false) {
    const enabled = !!state.cfg.allianceProtectionEnabled;
    const factions = parseProtectedFactionsText(state.cfg.protectedFactionsText);
    const ttlMs = Math.max(60 * 1000, Number(state.cfg.allianceRefreshMs) || (3 * 24 * 60 * 60 * 1000));
    const isFreshEnough = state.core.protectedMembers.lastRefreshAt && ((now() - Number(state.core.protectedMembers.lastRefreshAt)) < ttlMs);

    if (!enabled) {
      state.core.protectedMembers.byUserId = {};
      state.core.protectedMembers.factionIds = [];
      state.core.protectedMembers.lastError = "";
      publishCore(true);
      return {
        ok: true,
        source: "policy",
        data: { enabled: false, factions: [], members: 0 },
      };
    }

    if (!force && isFreshEnough) {
      return {
        ok: true,
        source: "cache",
        data: {
          enabled: true,
          factions: state.core.protectedMembers.factionIds || [],
          members: Object.keys(state.core.protectedMembers.byUserId || {}).length,
        },
      };
    }

    const byUserId = {};
    const errors = [];
    const factionIds = factions.map((f) => f.id);

    for (const faction of factions) {
      const result = await requestFactionMembersApi(faction.id);

      if (!result.ok) {
        errors.push(`${faction.id}: ${result.error || "Unknown error"}`);
        continue;
      }

      const membersObj = result.members || {};
      for (const [userIdRaw, member] of Object.entries(membersObj)) {
        const userId = Number(userIdRaw);
        if (!Number.isFinite(userId)) continue;

        const memberName = normalizeText(member?.name || "");
        const status = normalizeStatusText(member?.status?.state || member?.status?.description || "");
        const hospitalUntil = toEpochMs(member?.status?.until);

        byUserId[String(userId)] = {
          userId,
          factionId: faction.id,
          factionName: faction.name,
          protected: true,
          refreshedAt: now(),
        };

        ensureUserRecord(userId, {
          name: memberName,
          torn: status ? {
            status,
            hospitalUntil,
            lastRefreshAt: now(),
            source: "protected_members_api",
          } : undefined,
          group: {
            factionId: faction.id,
            factionName: faction.name,
            isProtected: true,
            protectedLastRefreshAt: now(),
            source: "protected_members_api",
          },
          seen: { lastSeenAt: now() },
        });
      }
    }

    state.core.protectedMembers.byUserId = byUserId;
    state.core.protectedMembers.factionIds = factionIds;
    state.core.protectedMembers.lastRefreshAt = now();
    state.core.protectedMembers.lastError = errors.join(" | ");

    publishCore(true);

    return {
      ok: errors.length === 0,
      source: "protected_members_api",
      data: {
        enabled: true,
        factions: factionIds,
        members: Object.keys(byUserId).length,
        errors,
      },
    };
  }

  function handleBrokerRequest(req) {
    const { type, payload } = req;
    const cacheKey = makeCacheKey(type, payload);

    switch (type) {
      case "dom.state":
        return Promise.resolve({ ok: true, source: "dom", data: state.core.dom });

      case "users.visible":
        return Promise.resolve({ ok: true, source: "cache", data: state.core.users });

      case "user.visible":
        return Promise.resolve({
          ok: true,
          source: "cache",
          data: state.core.users.byId[String(payload.userId)] || null,
        });

      case "user.refresh.ff.batch":
        return brokerFFBatch(payload.userIds || [], cacheKey, payload);

      case "user.refresh.torn.batch":
        return brokerTornBatch(payload.userIds || [], cacheKey, payload);

      case "protection.refresh":
        return refreshProtectedMembers(true);

      case "user.refresh.attackLoader": {
        const userId = Number(payload.userId);
        const cachedUser = Number.isFinite(userId) ? (state.core.users.byId[String(userId)] || null) : null;
        const hasRecentAttackTruth =
          !!cachedUser &&
          cachedUser.torn?.source === "attack_loader" &&
          (now() - Number(cachedUser.torn?.lastRefreshAt || 0)) <= state.cfg.attackTruthTtlMs;

        return Promise.resolve({
          ok: true,
          source: "attack_loader_recommendation",
          data: {
            userId: Number.isFinite(userId) ? userId : null,
            recommendedUrl: `/page.php?sid=attack&user2ID=${Number(payload.userId) || 0}`,
            cachedUser,
            hasRecentAttackTruth,
            preferredSingleRefreshPath: "attack_loader",
          },
        });
      }

      default:
        return Promise.resolve({ ok: false, error: `Unknown broker request type: ${type}` });
    }
  }

  function parseLifeBox() {
    const lifeRegions = Array.from(document.querySelectorAll('[role="region"]')).slice(0, 20);

    for (const region of lifeRegions) {
      const txt = normalizeText(region.innerText || region.textContent || "");
      if (!txt.includes("Life")) continue;

      const valueEl = region.querySelector('p[class*="bar-value"]');
      const valueTxt = normalizeText(valueEl?.innerText || valueEl?.textContent || "");
      const m = valueTxt.match(/(\d[\d,]*)\s*\/\s*(\d[\d,]*)/);
      if (m) {
        const current = Number(m[1].replace(/,/g, ""));
        const max = Number(m[2].replace(/,/g, ""));
        if (Number.isFinite(current) && Number.isFinite(max) && max > 0) {
          return { current, max, source: "life-region" };
        }
      }
    }

    return { current: null, max: null, source: "" };
  }

  function parseCashBox() {
    const el = document.querySelector("#user-money");
    if (!el) return { onHand: null, source: "" };

    const dataMoney = toNumber(el.getAttribute("data-money"));
    const txtValue = parseMoney(el.innerText || el.textContent || "");
    return { onHand: dataMoney ?? txtValue, source: "#user-money" };
  }

  function parseHospitalGlobal() {
    const icon = document.querySelector('a[aria-label^="Hospital:"]');
    return {
      hasGlobalHospitalIcon: !!icon,
      label: icon?.getAttribute("aria-label") || "",
    };
  }

  function parseAttackPage() {
    const title = Array.from(document.querySelectorAll("h4")).find(
      (el) => normalizeText(el.innerText || el.textContent || "").toLowerCase() === "attacking"
    );

    const dialog = Array.from(document.querySelectorAll("div")).find((el) => {
      const txt = normalizeText(el.innerText || el.textContent || "");
      return txt.includes("currently in hospital and cannot be attacked") || txt.includes("Release ETA:");
    });

    const dialogText = normalizeText(dialog?.innerText || dialog?.textContent || "");
    const etaMatch = dialogText.match(/Release ETA:\s*(.+?)\.?$/i);
    const targetUserId = parseUser2IdFromHref(location.href);

    return {
      onAttackPage: !!title || location.href.toLowerCase().includes("sid=attack"),
      targetHospitalDialog: dialogText || "",
      targetReleaseEtaText: etaMatch ? etaMatch[1].trim() : "",
      targetUserId: Number.isFinite(targetUserId) ? targetUserId : null,
    };
  }

  function getPageType() {
    const href = location.href.toLowerCase();
    const path = location.pathname.toLowerCase();
    if (href.includes("sid=attack")) return "attack";
    if (path.includes("/factions.php")) return "faction";
    if (path.includes("/profiles.php")) return "profile";
    if (path.includes("/bazaar.php")) return "bazaar";
    if (path.includes("/trade.php")) return "trade";
    if (path.includes("/properties.php")) return "properties";
    return "other";
  }

  function updateDomState() {
    const t = now();
    const pageType = getPageType();
    const life = parseLifeBox();
    const cash = parseCashBox();
    const hospital = parseHospitalGlobal();
    const combat = parseAttackPage();

    const prevLife = state.prev.lifeCurrent;
    const prevCash = state.prev.cashOnHand;

    const lifeDelta = (Number.isFinite(life.current) && Number.isFinite(prevLife)) ? life.current - prevLife : null;
    const lifeDrop = (Number.isFinite(lifeDelta) && lifeDelta < 0) ? Math.abs(lifeDelta) : 0;
    const lifeRise = (Number.isFinite(lifeDelta) && lifeDelta > 0) ? lifeDelta : 0;
    const cashDelta = (Number.isFinite(cash.onHand) && Number.isFinite(prevCash)) ? cash.onHand - prevCash : null;
    const cashIncrease = (Number.isFinite(cashDelta) && cashDelta > 0) ? cashDelta : 0;

    const lifePct = (Number.isFinite(life.current) && Number.isFinite(life.max) && life.max > 0)
      ? (life.current / life.max) * 100
      : null;

    state.core.dom.ts = t;
    state.core.dom.domVersion = ++state.version;
    state.core.dom.url = {
      href: location.href,
      path: location.pathname,
      hash: location.hash,
      changed: location.href !== state.prev.href,
      pathChanged: location.pathname !== state.prev.path,
      hashChanged: location.hash !== state.prev.hash,
    };
    state.core.dom.page = {
      type: pageType,
      isPropertiesPage: pageType === "properties",
      isVaultPage: false,
      isAttackPage: pageType === "attack",
      isTradePage: pageType === "trade",
      isBazaarPage: pageType === "bazaar",
      isFactionPage: pageType === "faction",
      isProfilePage: pageType === "profile",
    };
    state.core.dom.life = {
      current: life.current,
      max: life.max,
      pct: lifePct,
      delta: lifeDelta,
      drop: lifeDrop,
      rise: lifeRise,
      changed: Number.isFinite(lifeDelta) && lifeDelta !== 0,
      source: life.source,
    };
    state.core.dom.cash = {
      onHand: cash.onHand,
      delta: cashDelta,
      increase: cashIncrease,
      changed: Number.isFinite(cashDelta) && cashDelta !== 0,
      source: cash.source,
    };
    state.core.dom.hospital = hospital;
    state.core.dom.combat = {
      attackDetected: !!combat.onAttackPage || lifeDrop > 0,
      onAttackPage: !!combat.onAttackPage,
      targetHospitalDialog: combat.targetHospitalDialog,
      targetReleaseEtaText: combat.targetReleaseEtaText,
      targetUserId: combat.targetUserId,
    };

    state.prev.href = location.href;
    state.prev.path = location.pathname;
    state.prev.hash = location.hash;
    if (Number.isFinite(life.current)) state.prev.lifeCurrent = life.current;
    if (Number.isFinite(cash.onHand)) state.prev.cashOnHand = cash.onHand;
  }

  function scanGenericProfileLinks() {
    const anchors = Array.from(document.querySelectorAll('a[href*="profiles.php?XID="], a[href*="bazaar.php?userId="], a[href*="loader.php?sid=attack&user2ID="]'));
    for (const anchor of anchors.slice(0, 400)) {
      const userId =
        parseXidFromHref(anchor.href) ??
        parseUserIdFromHref(anchor.href) ??
        parseUser2IdFromHref(anchor.href);

      if (!Number.isFinite(userId)) continue;

      let name = "";
      const text = normalizeText(anchor.textContent || "");
      if (text && text.length <= 40) name = text;

      const protectedInfo = state.core.protectedMembers.byUserId[String(userId)] || null;

      ensureUserRecord(userId, {
        name,
        seen: { lastSeenAt: now() },
        dom: {
          statusText: "",
          source: "dom_visible",
          lastSeenAt: now(),
        },
        group: protectedInfo ? {
          factionId: protectedInfo.factionId,
          factionName: protectedInfo.factionName,
          isProtected: true,
          protectedLastRefreshAt: protectedInfo.refreshedAt || now(),
          source: "protected_members_api",
        } : undefined,
      });
    }
  }

  function scanProfilePage() {
    if (!state.core.dom.page.isProfilePage) return;
    const userId = parseXidFromHref(location.href);
    if (!Number.isFinite(userId)) return;

    const text = normalizeText(document.body?.innerText || "");
    let status = "";
    if (text.includes("Okay")) status = "Okay";
    else if (text.includes("Hospital")) status = "Hospital";
    else if (text.includes("Traveling")) status = "Traveling";

    ensureUserRecord(userId, {
      seen: { lastSeenAt: now() },
      dom: {
        statusText: status,
        source: "profile_dom",
        lastSeenAt: now(),
      },
      torn: status ? {
        status,
        lastRefreshAt: now(),
        source: "profile_dom",
      } : undefined,
    });
  }

  function scanAttackPageTarget() {
    if (!state.core.dom.page.isAttackPage) return;
    const targetUserId = Number(state.core.dom.combat.targetUserId);
    if (!Number.isFinite(targetUserId)) return;

    const dialog = state.core.dom.combat.targetHospitalDialog || "";
    const eta = state.core.dom.combat.targetReleaseEtaText || "";
    const isHospital = /hospital/i.test(dialog);

    ensureUserRecord(targetUserId, {
      seen: { lastSeenAt: now() },
      torn: {
        status: isHospital ? "Hospital" : "",
        hospitalEtaText: eta,
        lastRefreshAt: now(),
        source: "attack_loader",
      },
    });
  }

  function pruneStaleUsers() {
    const cutoff = now() - Math.max(30 * 1000, Number(state.cfg.visibleUserStaleMs) || 120000);
    const attackTruthCutoff = now() - Math.max(30 * 1000, Number(state.cfg.attackTruthTtlMs) || 60000);
    const profileTruthCutoff = now() - Math.max(60 * 1000, Number(state.cfg.profileTruthTtlMs) || 300000);

    for (const [key, user] of Object.entries(state.core.users.byId)) {
      user.seen.isStale = Number(user.seen.lastSeenAt || 0) < cutoff;
      user.seen.attackTruthStale = !(
        user.torn?.source === "attack_loader" &&
        Number(user.torn?.lastRefreshAt || 0) >= attackTruthCutoff
      );
      user.seen.profileTruthStale = !(
        user.torn?.source === "profile_dom" &&
        Number(user.torn?.lastRefreshAt || 0) >= profileTruthCutoff
      );

      const protectedInfo = state.core.protectedMembers.byUserId[String(user.userId)] || null;
      if (protectedInfo) {
        user.group = {
          ...user.group,
          factionId: protectedInfo.factionId,
          factionName: protectedInfo.factionName,
          isProtected: true,
          protectedLastRefreshAt: protectedInfo.refreshedAt || now(),
          source: "protected_members_api",
        };
      }

      state.core.users.byId[key] = user;
    }
  }

  function runPageAdapters() {
    updateDomState();
    scanGenericProfileLinks();
    scanProfilePage();
    scanAttackPageTarget();
    pruneStaleUsers();
    state.core.ts = now();
  }

  function computeDomPollMs() {
    const dom = state.core.dom;
    if (dom.page.isAttackPage) return state.cfg.domPollFastMs;
    if (dom.page.isFactionPage || dom.page.isTradePage || dom.page.isProfilePage) return state.cfg.domPollMediumMs;
    return state.cfg.domPollSlowMs;
  }

  function restartDomLoop() {
    if (state.loops.dom) clearTimeout(state.loops.dom);
    const delay = clamp(Number(computeDomPollMs()) || state.cfg.domPollMediumMs, 100, 10000);
    state.loops.dom = setTimeout(() => domTick(false), delay);
  }

  function domTick(force = false) {
    if (!state.cfg.enabled) {
      restartDomLoop();
      return;
    }

    maybeBecomeLeader();
    refreshApiStatus();
    runPageAdapters();

    if (state.isLeader) {
      publishCore(force);
    } else {
      renderPanel();
      exposeWindowApi();
    }

    restartDomLoop();
  }

