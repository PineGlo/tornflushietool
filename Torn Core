                left: ${Number(GM_getValue(STORAGE_KEYS.panelX, 18)) || 18}px;
                top: ${Number(GM_getValue(STORAGE_KEYS.panelY, 80)) || 80}px;
                width: 340px;
                z-index: 999999;
                background: rgba(14,18,28,0.96);
                color: #eef3ff;
                border: 1px solid rgba(120,150,255,0.28);
                border-radius: 12px;
                box-shadow: 0 12px 30px rgba(0,0,0,0.35);
                font: 12px/1.4 Arial, sans-serif;
            }
            #torn-core-panel * { box-sizing: border-box; }
            #torn-core-head {
                padding: 8px 10px;
                display:flex;
                justify-content:space-between;
                align-items:center;
                cursor:move;
                border-bottom:1px solid rgba(120,150,255,0.15);
                user-select:none;
                font-weight:700;
            }
            #torn-core-panel.collapsed #torn-core-body { display:none; }
            #torn-core-body { padding: 10px; }
            .tc-row {
                display:flex;
                justify-content:space-between;
                gap:8px;
                margin:4px 0;
            }
            .tc-actions {
                display:flex;
                gap:6px;
            }
            .tc-btn {
                border:0;
                background:#445;
                color:white;
                border-radius:6px;
                padding:4px 8px;
                cursor:pointer;
            }
            .tc-btn.primary { background:#356dff; }
            .tc-good { color:#7CFF9B; font-weight:700; }
            .tc-warn { color:#FFD76C; font-weight:700; }
            .tc-bad { color:#FF9090; font-weight:700; }
            .tc-section {
                margin-bottom:8px;
                padding:8px;
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.06);
                border-radius:8px;
            }
            .tc-small {
                font-size:11px;
                color:#c7d2ff;
            }
            .tc-label {
                display:block;
                margin:6px 0 2px;
                font-size:11px;
                color:#c7d2ff;
            }
            .tc-input {
                width:100%;
                border:1px solid rgba(255,255,255,0.12);
                background:#1d2335;
                color:white;
                border-radius:6px;
                padding:6px;
            }
        `);

        const panel = document.createElement('div');
        panel.id = 'torn-core-panel';
        if (GM_getValue(STORAGE_KEYS.panelCollapsed, false)) {
            panel.classList.add('collapsed');
        }

        panel.innerHTML = `
            <div id="torn-core-head">
                <span>Torn Core v2</span>
                <div class="tc-actions">
                    <button class="tc-btn" id="tc-toggle">${panel.classList.contains('collapsed') ? '▸' : '▾'}</button>
                    <button class="tc-btn" id="tc-enable">${state.cfg.enabled ? 'On' : 'Off'}</button>
                    <button class="tc-btn primary" id="tc-push">Push</button>
                </div>
            </div>
            <div id="torn-core-body"></div>
        `;

        document.body.appendChild(panel);
        state.panel = panel;
        state.panelBody = panel.querySelector('#torn-core-body');

        panel.querySelector('#tc-toggle').addEventListener('click', (e) => {
            e.stopPropagation();
            panel.classList.toggle('collapsed');
            GM_setValue(STORAGE_KEYS.panelCollapsed, panel.classList.contains('collapsed'));
            panel.querySelector('#tc-toggle').textContent = panel.classList.contains('collapsed') ? '▸' : '▾';
        });

        panel.querySelector('#tc-enable').addEventListener('click', (e) => {
            e.stopPropagation();
            state.cfg.enabled = !state.cfg.enabled;
            saveSettings();
            panel.querySelector('#tc-enable').textContent = state.cfg.enabled ? 'On' : 'Off';
            if (state.cfg.enabled) domTick(true);
        });

        panel.querySelector('#tc-push').addEventListener('click', (e) => {
            e.stopPropagation();
            domTick(true);
        });

        const head = panel.querySelector('#torn-core-head');
        head.addEventListener('mousedown', (e) => {
            state.dragging = {
                x: e.clientX,
                y: e.clientY,
                left: panel.offsetLeft,
                top: panel.offsetTop,
            };
        });

        window.addEventListener('mouseup', () => {
            state.dragging = null;
        });

        window.addEventListener('mousemove', (e) => {
            if (!state.dragging) return;
            const dx = e.clientX - state.dragging.x;
            const dy = e.clientY - state.dragging.y;
            const left = Math.max(0, state.dragging.left + dx);
            const top = Math.max(0, state.dragging.top + dy);
            panel.style.left = `${left}px`;
            panel.style.top = `${top}px`;
            panel.style.right = 'auto';
            GM_setValue(STORAGE_KEYS.panelX, left);
            GM_setValue(STORAGE_KEYS.panelY, top);
        });

        renderPanel();
    }

