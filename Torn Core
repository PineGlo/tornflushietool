// ==UserScript==
// @name         Torn Core v2 Scaffold
// @namespace    pineglow.torn.core
// @version      2.0.0
// @description  Shared Torn runtime core: page adapters, DOM state, visible-user cache, API broker scaffold, and request bus.
// @match        https://www.torn.com/*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @connect      api.torn.com
// @connect      ffscouter.com
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    const CORE_NAME = 'torn_core_v2';
    const CHANNEL_NAME = 'torn_core_v2_channel';
    const EVENT_NAME = 'torn_core_v2_update';
    const BRIDGE_KEYS = {
        snapshot: 'torn_core_v2_bridge_snapshot',
        requests: 'torn_core_v2_bridge_requests',
        responses: 'torn_core_v2_bridge_responses',
    };

    const STORAGE_KEYS = {
        settings: 'torn_core_v2_settings',
        leader: 'torn_core_v2_leader',
        snapshot: 'torn_core_v2_snapshot',
        panelCollapsed: 'torn_core_v2_panel_collapsed',
        panelX: 'torn_core_v2_panel_x',
        panelY: 'torn_core_v2_panel_y',
        tabId: 'torn_core_v2_tab_id',
    };

    const DEFAULTS = {
        enabled: true,
        domPollFastMs: 250,
        domPollMediumMs: 1000,
        domPollSlowMs: 2000,
        leaderHeartbeatMs: 1500,
        leaderStaleMs: 5000,
        heartbeatPublishMs: 5000,

        tornApiKey: '',
        ffApiKey: '',

        tornBatchTtlMs: 60 * 1000,
        ffBatchTtlMs: 3 * 24 * 60 * 60 * 1000,
        visibleUserStaleMs: 120 * 1000,
        attackTruthTtlMs: 60 * 1000,
        profileTruthTtlMs: 5 * 60 * 1000,

        debug: false,
        showPanel: true,
    };

    const SOURCE_PRIORITY = {
        unknown: 0,
        dom_visible: 1,
        profile_dom: 2,
        ff_visible_dom: 2,
        ff_cache_db: 3,
        torn_batch_api: 3,
        ff_batch_api: 4,
        attack_loader: 5,
    };

    const state = {
        tabId: getOrCreateTabId(),
        bc: typeof BroadcastChannel !== 'undefined' ? new BroadcastChannel(CHANNEL_NAME) : null,
        cfg: loadSettings(),
        isLeader: false,

        loops: {
            dom: null,
            leader: null,
            ui: null,
            bridge: null,
        },
        brokerSeq: 0,
        brokerPending: {},

        panel: null,
        panelBody: null,
        dragging: null,

        version: 0,
        lastPublishedJson: '',
        lastPublishedAt: 0,

        prev: {
            href: location.href,
            path: location.pathname,
            hash: location.hash,
            lifeCurrent: null,
            cashOnHand: null,
            vaultCash: null,
        },

        core: {
            ts: 0,
            schemaVersion: 2,
            coreVersion: '2.0.0',
            leaderTabId: null,

            dom: {
                ts: 0,
                domVersion: 0,

                url: {
                    href: location.href,
                    path: location.pathname,
                    hash: location.hash,
                    changed: false,
                    pathChanged: false,
                    hashChanged: false,
                },

                page: {
                    type: 'other',
                    isPropertiesPage: false,
                    isVaultPage: false,
                    isAttackPage: false,
                    isTradePage: false,
                    isBazaarPage: false,
                    isFactionPage: false,
                    isProfilePage: false,
                },

                life: {
                    current: null,
                    max: null,
                    pct: null,
                    delta: null,
                    drop: 0,
                    rise: 0,
                    changed: false,
                    source: '',
                },

                cash: {
                    onHand: null,
                    delta: null,
                    increase: 0,
                    changed: false,
                    source: '',
                },

                vault: {
                    cash: null,
                    delta: null,
                    changed: false,
                    title: '',
                    input: {
                        value: null,
                        dataMoney: null,
                        dataDeposit: null,
                        dataMax: null,
                    },
                },

                actions: {
                    hasVaultMaxButton: false,
                    hasVaultDepositButton: false,
                    hasFactionDepositButton: false,
                    hasFactionDepositConfirmYes: false,
                },

                trade: {
                    hasTradeTab: false,
                    hasTradeTextbox: false,
                    hasTradeSendButton: false,
                },

                hospital: {
                    hasGlobalHospitalIcon: false,
                    label: '',
                },

                combat: {
                    attackDetected: false,
                    onAttackPage: false,
                    targetHospitalDialog: '',
                    targetReleaseEtaText: '',
                    targetUserId: null,
                },
            },

            users: {
                byId: {},
            },

            api: {
                cache: {
                    torn: {},
                    ff: {},
                },
                inFlight: {},
                stats: {
                    lastBatchTornAt: 0,
                    lastBatchFFAt: 0,
                }
            },

            requests: {
                pending: [],
            }
        }
    };

    function getOrCreateTabId() {
        const existing = sessionStorage.getItem(STORAGE_KEYS.tabId);
        if (existing) return existing;
        const created = `core_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`;
        sessionStorage.setItem(STORAGE_KEYS.tabId, created);
        return created;
    }

    function loadSettings() {
        const raw = GM_getValue(STORAGE_KEYS.settings, {}) || {};
        return {
            ...DEFAULTS,
            ...raw,
        };
    }

    function saveSettings() {
        GM_setValue(STORAGE_KEYS.settings, state.cfg);
    }

    function log(...args) {
        if (state.cfg.debug) {
            console.log('[TORN CORE]', ...args);
        }
    }

    function now() {
        return Date.now();
    }

    function clamp(n, min, max) {
        return Math.max(min, Math.min(max, n));
    }

    function safeJsonParse(text, fallback = null) {
        try {
            return JSON.parse(text);
        } catch {
            return fallback;
        }
    }

    function normalizeText(text) {
        return String(text || '').replace(/\s+/g, ' ').trim();
    }

    function toNumber(v) {
        const n = Number(v);
        return Number.isFinite(n) ? n : null;
    }

    function parseMoney(text) {
        if (!text) return null;
        const cleaned = String(text).replace(/[^0-9.-]/g, '');
        if (!cleaned) return null;
        const n = Number(cleaned.replace(/,/g, ''));
        return Number.isFinite(n) ? n : null;
    }

    function parseXidFromHref(href) {
        if (!href) return null;
        const m = String(href).match(/[?&]XID=(\d+)/i);
        return m ? Number(m[1]) : null;
    }

    function parseUser2IdFromHref(href) {
        if (!href) return null;
        const m = String(href).match(/[?&]user2ID=(\d+)/i);
        return m ? Number(m[1]) : null;
    }

    function normalizeStatusText(text) {
        const s = normalizeText(text).toLowerCase();
        if (!s) return '';
        if (s === 'okay') return 'Okay';
        if (s.includes('hospital')) return 'Hospital';
        if (s.includes('traveling') || s.includes('returning to torn')) return 'Traveling';
        return '';
    }

    function parseTravelDestination(text) {
        const normalized = normalizeText(text);
        if (!normalized) return '';
        const toMatch = normalized.match(/traveling to\s+(.+)$/i);
        if (toMatch) return normalizeText(toMatch[1]);
        const returnMatch = normalized.match(/returning to\s+(.+)$/i);
        if (returnMatch) return normalizeText(returnMatch[1]);
        return '';
    }

    function parseHospitalEtaText(text) {
        const normalized = normalizeText(text);
        if (!normalized) return '';
        const eta = normalized.match(/Release ETA:\s*(.+?)\.?$/i);
        if (eta) return normalizeText(eta[1]);
        const fallback = normalized.match(/(\d+\s*h)?\s*(\d+\s*m)?\s*(\d+\s*s)?/i);
        return fallback ? normalizeText(fallback[0]) : '';
    }

    function toEpochMs(value) {
        const n = Number(value);
        if (!Number.isFinite(n) || n <= 0) return null;
        return n < 1e12 ? n * 1000 : n;
    }

    function fmtMoney(v) {
        return Number.isFinite(v) ? `$${Math.round(v).toLocaleString()}` : '-';
    }

    function fmtPct(v, digits = 1) {
        return Number.isFinite(v) ? `${v.toFixed(digits)}%` : '-';
    }

    function getLeaderRecord() {
        return GM_getValue(STORAGE_KEYS.leader, null);
    }

    function setLeaderRecord() {
        GM_setValue(STORAGE_KEYS.leader, {
            tabId: state.tabId,
            heartbeatAt: now(),
        });
    }

    function clearLeaderRecord() {
        const rec = getLeaderRecord();
        if (rec && rec.tabId === state.tabId) {
            GM_setValue(STORAGE_KEYS.leader, null);
        }
    }

    function maybeBecomeLeader() {
        const rec = getLeaderRecord();
        const t = now();

        if (!rec || !rec.tabId || (t - Number(rec.heartbeatAt || 0)) > state.cfg.leaderStaleMs) {
            state.isLeader = true;
            state.core.leaderTabId = state.tabId;
            setLeaderRecord();
            return;
        }

        state.isLeader = rec.tabId === state.tabId;
        state.core.leaderTabId = rec.tabId || null;
    }

    function heartbeatLeader() {
        if (!state.isLeader) return;
        setLeaderRecord();
        broadcast({
            type: 'leader-heartbeat',
            leaderTabId: state.tabId,
        });
    }

    function broadcast(payload) {
        try {
            if (state.bc) {
                state.bc.postMessage({
                    sender: state.tabId,
                    at: now(),
                    ...payload,
                });
            }
        } catch (_) {}
    }

    function setupBroadcastChannel() {
        if (!state.bc) return;
        state.bc.onmessage = (event) => {
            const msg = event.data || {};
            if (msg.sender === state.tabId) return;

            if (msg.type === 'leader-heartbeat') {
                state.core.leaderTabId = msg.leaderTabId || state.core.leaderTabId;
                return;
            }

            if (msg.type === 'core-update' && msg.snapshot && !state.isLeader) {
                applySnapshot(msg.snapshot);
                renderPanel();
                exposeWindowApi();
                return;
            }

            if (msg.type === 'request-broker' && state.isLeader) {
                handleBrokerMessage(msg);
                return;
            }

            if (msg.type === 'broker-response') {
                handleBrokerResponse(msg);
                return;
            }
        };
    }

    function exposeWindowApi() {
        window.__TORN_CORE_STATE__ = state.core;

        window.TornCore = {
            getState() {
                return state.core;
            },
            getDomState() {
                return state.core.dom;
            },
            getUsers() {
                return state.core.users;
            },
            getUser(userId) {
                return state.core.users.byId[String(userId)] || null;
            },
            async getFreshUser(userId, opts = {}) {
                const id = Number(userId);
                if (!Number.isFinite(id)) return null;
                if (opts.ff) {
                    await requestBroker('user.refresh.ff.batch', { userIds: [id] });
                }
                if (opts.torn !== false) {
                    await requestBroker('user.refresh.torn.batch', {
                        userIds: [id],
                        forceFresh: !!opts.forceFresh,
                        forceSingleApi: !!opts.forceSingleApi,
                    });
                }
                return state.core.users.byId[String(id)] || null;
            },
            requestUsersFFRefresh(userIds = []) {
                return requestBroker('user.refresh.ff.batch', { userIds });
            },
            requestUsersTornRefresh(userIds = [], opts = {}) {
                return requestBroker('user.refresh.torn.batch', { userIds, ...opts });
            },
            subscribe(callback) {
                if (typeof callback !== 'function') return () => {};
                const handler = (event) => callback(event.detail);
                window.addEventListener(EVENT_NAME, handler);
                return () => window.removeEventListener(EVENT_NAME, handler);
            },
            request(type, payload = {}) {
                return requestBroker(type, payload);
            },
        };
    }

    function dispatchWindowUpdate() {
        try {
            window.dispatchEvent(new CustomEvent(EVENT_NAME, {
                detail: state.core,
            }));
        } catch (_) {}
    }

    function snapshotCore() {
        return JSON.parse(JSON.stringify(state.core));
    }

    function applySnapshot(snapshot) {
        if (!snapshot || typeof snapshot !== 'object') return;
        state.core = snapshot;
    }

    function persistSnapshot(snapshot) {
        try {
            localStorage.setItem(STORAGE_KEYS.snapshot, JSON.stringify(snapshot));
        } catch (_) {}
    }

    function loadSnapshot() {
        const raw = localStorage.getItem(STORAGE_KEYS.snapshot);
        return safeJsonParse(raw, null);
    }

    function publishCore(force = false) {
        const snapshot = snapshotCore();
        const json = JSON.stringify(snapshot);
        const heartbeatDue = (now() - state.lastPublishedAt) >= state.cfg.heartbeatPublishMs;

        if (!force && json === state.lastPublishedJson && !heartbeatDue) {
            return false;
        }

        state.lastPublishedJson = json;
        state.lastPublishedAt = now();

        persistSnapshot(snapshot);
        publishBridgeSnapshot(snapshot);
        broadcast({
            type: 'core-update',
            snapshot,
        });

        exposeWindowApi();
        dispatchWindowUpdate();
        renderPanel();
        return true;
    }

    function publishBridgeSnapshot(snapshot) {
        try {
            GM_setValue(BRIDGE_KEYS.snapshot, {
                ts: Number(snapshot?.ts || now()),
                leaderTabId: snapshot?.leaderTabId || null,
                users: snapshot?.users || { byId: {} },
                api: { stats: snapshot?.api?.stats || {} },
            });
        } catch (err) {
            log('Failed to publish bridge snapshot', err);
        }
    }

    function appendBridgeResponse(item) {
        try {
            const responses = GM_getValue(BRIDGE_KEYS.responses, []) || [];
            responses.push(item);
            GM_setValue(BRIDGE_KEYS.responses, responses.slice(-200));
        } catch (err) {
            log('Failed to append bridge response', err);
        }
    }

    function processBridgeRequests() {
        if (!state.isLeader) return;
        const requests = GM_getValue(BRIDGE_KEYS.requests, []) || [];
        if (!Array.isArray(requests) || !requests.length) return;

        const responses = GM_getValue(BRIDGE_KEYS.responses, []) || [];
        const responded = new Set(responses.map((r) => r?.requestId).filter(Boolean));

        requests.forEach((req) => {
            if (!req?.id || responded.has(req.id)) return;
            Promise.resolve(handleBrokerRequest({
                id: req.id,
                type: req.type,
                payload: req.payload || {},
                requesterTabId: req.requester || 'bridge',
                requestedAt: Number(req.createdAt) || now(),
            }))
                .then((result) => appendBridgeResponse({ requestId: req.id, at: now(), result }))
                .catch((err) => appendBridgeResponse({
                    requestId: req.id,
                    at: now(),
                    result: { ok: false, error: String(err?.message || err || 'Bridge broker execution failed') }
                }));
        });

        if (requests.length > 200) {
            GM_setValue(BRIDGE_KEYS.requests, requests.slice(-200));
        }
    }

    function requestBroker(type, payload = {}) {
        const requestId = `req_${Date.now()}_${++state.brokerSeq}_${Math.random().toString(36).slice(2, 8)}`;
        const req = {
            id: requestId,
            type,
            payload,
            requesterTabId: state.tabId,
            requestedAt: now(),
        };

        if (state.isLeader) {
            return handleBrokerRequest(req);
        }

        broadcast({
            type: 'request-broker',
            request: req,
        });

        return new Promise((resolve) => {
            const timeoutMs = 7000;
            const timeout = setTimeout(() => {
                delete state.brokerPending[requestId];
                resolve({
                    ok: false,
                    brokered: true,
                    timeout: true,
                    message: 'Broker response timed out waiting for leader.',
                    request: req,
                });
            }, timeoutMs);

            state.brokerPending[requestId] = { resolve, timeout };
        });
    }

    function handleBrokerMessage(msg) {
        const req = msg.request;
        if (!req) return;
        Promise.resolve(handleBrokerRequest(req))
            .then((result) => {
                if (!req.requesterTabId || req.requesterTabId === state.tabId) return;
                broadcast({
                    type: 'broker-response',
                    requestId: req.id,
                    requesterTabId: req.requesterTabId,
                    result,
                });
            })
            .catch((err) => {
                if (!req.requesterTabId || req.requesterTabId === state.tabId) return;
                broadcast({
                    type: 'broker-response',
                    requestId: req.id,
                    requesterTabId: req.requesterTabId,
                    result: {
                        ok: false,
                        error: String(err?.message || err || 'Broker execution failed'),
                    }
                });
            });
    }

    function handleBrokerResponse(msg) {
        if (!msg || msg.requesterTabId !== state.tabId) return;
        const pending = state.brokerPending[msg.requestId];
        if (!pending) return;
        clearTimeout(pending.timeout);
        delete state.brokerPending[msg.requestId];
        pending.resolve(msg.result || { ok: false, error: 'Empty broker response' });
    }

    function makeCacheKey(type, payload) {
        return `${type}:${JSON.stringify(payload || {})}`;
    }

    function isFresh(entry, ttlMs) {
        return !!entry && (now() - Number(entry.ts || 0)) < ttlMs;
    }

    function openIndexedDb(dbName) {
        return new Promise((resolve, reject) => {
            try {
                const req = indexedDB.open(dbName);
                req.onerror = () => reject(req.error || new Error(`Failed to open DB ${dbName}`));
                req.onsuccess = () => resolve(req.result);
            } catch (err) {
                reject(err);
            }
        });
    }

    function readAllRows(db, storeName) {
        return new Promise((resolve, reject) => {
            try {
                const tx = db.transaction(storeName, 'readonly');
                const store = tx.objectStore(storeName);
                const req = store.getAll();
                req.onerror = () => reject(req.error || new Error('getAll failed'));
                req.onsuccess = () => resolve(req.result || []);
            } catch (err) {
                reject(err);
            }
        });
    }

    async function loadFFRowsByUserIds(userIds) {
        const wanted = new Set((userIds || []).map(Number).filter(Number.isFinite));
        if (!wanted.size) return {};

        let db = null;
        try {
            db = await openIndexedDb('ffscouter-cache');
            const rows = await readAllRows(db, 'cache');
            const out = {};

            for (const row of rows) {
                const id = Number(row?.player_id);
                if (!Number.isFinite(id) || !wanted.has(id)) continue;
                out[String(id)] = row;
            }
            return out;
        } catch (err) {
            log('FF cache read failed', err);
            return {};
        } finally {
            try { db?.close(); } catch (_) {}
        }
    }

    function requestTornProfileApi(userId, forceFresh = false) {
        return new Promise((resolve) => {
            const key = String(state.cfg.tornApiKey || '').trim();
            if (!key) {
                resolve({ ok: false, userId, error: 'Missing Torn API key in Torn Core settings.' });
                return;
            }

            let url = `https://api.torn.com/user/${Number(userId)}?selections=profile&key=${encodeURIComponent(key)}&comment=torn_core_batch`;
            if (forceFresh) {
                url += `&timestamp=${Date.now()}`;
            }

            GM_xmlhttpRequest({
                method: 'GET',
                url,
                onload: (response) => {
                    try {
                        const data = JSON.parse(response.responseText || '{}');
                        if (data.error) {
                            resolve({
                                ok: false,
                                userId,
                                error: data.error.error || 'API error',
                                errorCode: Number(data.error.code) || null,
                            });
                            return;
                        }

                        const status = data.status || {};
                        const statusText = normalizeStatusText(status.state || status.description || '');
                        const hospitalUntil = toEpochMs(status.until);
                        resolve({
                            ok: true,
                            userId,
                            status: statusText,
                            hospitalUntil,
                            hospitalEtaText: '',
                            fetchedAt: now(),
                        });
                    } catch (err) {
                        resolve({ ok: false, userId, error: 'Parse error' });
                    }
                },
                onerror: () => resolve({ ok: false, userId, error: 'Network error' }),
                ontimeout: () => resolve({ ok: false, userId, error: 'Timeout' }),
            });
        });
    }

    function handleBrokerRequest(req) {
        const { type, payload } = req;
        const cacheKey = makeCacheKey(type, payload);

        switch (type) {
            case 'dom.state':
                return Promise.resolve({
                    ok: true,
                    source: 'dom',
                    data: state.core.dom,
                });

            case 'users.visible':
                return Promise.resolve({
                    ok: true,
                    source: 'cache',
                    data: state.core.users,
                });

            case 'user.visible':
                return Promise.resolve({
                    ok: true,
                    source: 'cache',
                    data: state.core.users.byId[String(payload.userId)] || null,
                });

            case 'user.refresh.ff.batch':
                return brokerFFBatch(payload.userIds || [], cacheKey);

            case 'user.refresh.torn.batch':
                return brokerTornBatch(payload.userIds || [], cacheKey, payload);

            case 'user.refresh.attackLoader':
                {
                    const userId = Number(payload.userId);
                    const cachedUser = Number.isFinite(userId) ? (state.core.users.byId[String(userId)] || null) : null;
                    const hasRecentAttackTruth =
                        !!cachedUser &&
                        cachedUser.torn?.source === 'attack_loader' &&
                        (now() - Number(cachedUser.torn?.lastRefreshAt || 0)) <= state.cfg.attackTruthTtlMs;

                    return Promise.resolve({
                        ok: true,
                        source: 'attack_loader_recommendation',
                        data: {
                            userId: Number.isFinite(userId) ? userId : null,
                            recommendedUrl: `/page.php?sid=attack&user2ID=${Number(payload.userId) || 0}`,
                            cachedUser,
                            hasRecentAttackTruth,
                            preferredSingleRefreshPath: 'attack_loader',
                        }
                    });
                }

            default:
                return Promise.resolve({
                    ok: false,
                    error: `Unknown broker request type: ${type}`,
                });
        }
    }

    function brokerFFBatch(userIds, cacheKey) {
        const uniqueIds = Array.from(new Set((userIds || []).map(Number).filter(Number.isFinite)));
        const cached = state.core.api.cache.ff[cacheKey];

        if (isFresh(cached, state.cfg.ffBatchTtlMs)) {
            return Promise.resolve({
                ok: true,
                source: 'cache',
                data: cached.data,
            });
        }

        if (state.core.api.inFlight[cacheKey]) {
            return state.core.api.inFlight[cacheKey];
        }

        const promise = new Promise(async (resolve) => {
            const ffRows = await loadFFRowsByUserIds(uniqueIds);
            const mergedUsers = [];

            for (const id of uniqueIds) {
                const row = ffRows[String(id)];
                if (!row) continue;

                ensureUserRecord(id, {
                    ff: {
                        estimatedStats: row.bs_estimate ?? null,
                        estimatedStatsHuman: row.bs_estimate_human || '',
                        visibleFairFight: row.ff_visible || '',
                        visibleEstimatedStats: row.ff_estimate_visible || '',
                        lastRefreshAt: now(),
                        source: 'ff_batch_api',
                    }
                });
                mergedUsers.push(id);
            }

            const data = {
                userIds: uniqueIds,
                mergedUserIds: mergedUsers,
                found: mergedUsers.length,
                missing: uniqueIds.length - mergedUsers.length,
                status: 'ok',
            };

            state.core.api.cache.ff[cacheKey] = {
                ts: now(),
                data,
            };
            state.core.api.stats.lastBatchFFAt = now();
            delete state.core.api.inFlight[cacheKey];
            publishCore(true);

            resolve({
                ok: true,
                source: 'ff_batch_api',
                data,
            });
        });

        state.core.api.inFlight[cacheKey] = promise;
        return promise;
    }

    function brokerTornBatch(userIds, cacheKey, payload = {}) {
        const uniqueIds = Array.from(new Set((userIds || []).map(Number).filter(Number.isFinite)));
        if (!uniqueIds.length) {
            return Promise.resolve({
                ok: true,
                source: 'policy',
                data: { userIds: [], results: {}, usedApi: false }
            });
        }

        if (uniqueIds.length === 1 && !payload.forceSingleApi) {
            const singleUserId = uniqueIds[0];
            const cachedUser = state.core.users.byId[String(singleUserId)] || null;
            return Promise.resolve({
                ok: true,
                source: 'policy',
                data: {
                    userIds: uniqueIds,
                    usedApi: false,
                    reason: 'Single-user refresh prefers attack loader/profile/visible DOM before API.',
                    recommendation: `/page.php?sid=attack&user2ID=${singleUserId}`,
                    cachedUser,
                }
            });
        }

        const cached = state.core.api.cache.torn[cacheKey];

        if (isFresh(cached, state.cfg.tornBatchTtlMs)) {
            return Promise.resolve({
                ok: true,
                source: 'cache',
                data: cached.data,
            });
        }

        if (state.core.api.inFlight[cacheKey]) {
            return state.core.api.inFlight[cacheKey];
        }

        const promise = new Promise(async (resolve) => {
            const key = String(state.cfg.tornApiKey || '').trim();
            if (!key) {
                const fallbackResults = {};
                for (const id of uniqueIds) {
                    const cachedUser = state.core.users.byId[String(id)] || null;
                    fallbackResults[String(id)] = {
                        ok: false,
                        usedApi: false,
                        reason: 'missing_core_api_key',
                        cachedUser,
                    };
                }
                const noKeyData = {
                    userIds: uniqueIds,
                    usedApi: false,
                    source: 'policy',
                    reason: 'Missing Torn Core API key.',
                    results: fallbackResults,
                };
                delete state.core.api.inFlight[cacheKey];
                resolve({ ok: false, source: 'policy', data: noKeyData });
                return;
            }

            const results = {};
            for (const id of uniqueIds) {
                const apiResult = await requestTornProfileApi(id, !!payload.forceFresh);
                if (apiResult.ok) {
                    ensureUserRecord(id, {
                        torn: {
                            status: apiResult.status || '',
                            hospitalUntil: apiResult.hospitalUntil || 0,
                            hospitalEtaText: apiResult.hospitalEtaText || '',
                            lastRefreshAt: apiResult.fetchedAt || now(),
                            source: 'torn_batch_api',
                        }
                    });
                }

                const merged = state.core.users.byId[String(id)] || null;
                results[String(id)] = {
                    ok: !!apiResult.ok,
                    error: apiResult.error || null,
                    errorCode: apiResult.errorCode || null,
                    usedApi: true,
                    torn: merged?.torn || null,
                };
            }

            const data = {
                userIds: uniqueIds,
                usedApi: true,
                source: 'torn_batch_api',
                refreshedAt: now(),
                results,
            };

            state.core.api.cache.torn[cacheKey] = {
                ts: now(),
                data,
            };
            state.core.api.stats.lastBatchTornAt = now();
            delete state.core.api.inFlight[cacheKey];
            publishCore(true);

            resolve({
                ok: true,
                source: 'torn_batch_api',
                data,
            });
        });

        state.core.api.inFlight[cacheKey] = promise;
        return promise;
    }

    function parseLifeBox() {
        const lifeRegions = Array.from(document.querySelectorAll('[role="region"]')).slice(0, 20);

        for (const region of lifeRegions) {
            const txt = normalizeText(region.innerText || region.textContent || '');
            if (!txt.includes('Life')) continue;

            const valueEl = region.querySelector('p[class*="bar-value"]');
            const valueTxt = normalizeText(valueEl?.innerText || valueEl?.textContent || '');
            const m = valueTxt.match(/(\d[\d,]*)\s*\/\s*(\d[\d,]*)/);

            if (m) {
                const current = Number(m[1].replace(/,/g, ''));
                const max = Number(m[2].replace(/,/g, ''));
                if (Number.isFinite(current) && Number.isFinite(max) && max > 0) {
                    return {
                        current,
                        max,
                        source: 'life-region',
                    };
                }
            }
        }

        const fallbackEls = Array.from(document.querySelectorAll('p[class*="bar-value"]')).slice(0, 20);
        for (const el of fallbackEls) {
            const parentTxt = normalizeText(el.parentElement?.innerText || '');
            if (!parentTxt.includes('Life')) continue;

            const txt = normalizeText(el.innerText || el.textContent || '');
            const m = txt.match(/(\d[\d,]*)\s*\/\s*(\d[\d,]*)/);
            if (m) {
                const current = Number(m[1].replace(/,/g, ''));
                const max = Number(m[2].replace(/,/g, ''));
                if (Number.isFinite(current) && Number.isFinite(max) && max > 0) {
                    return {
                        current,
                        max,
                        source: 'life-value-fallback',
                    };
                }
            }
        }

        return {
            current: null,
            max: null,
            source: '',
        };
    }

