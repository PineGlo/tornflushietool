                <div class="tc-row"><span>Faction deposit</span><strong>${dom.actions.hasFactionDepositButton ? 'Yes' : 'No'}</strong></div>
                <div class="tc-row"><span>Faction confirm</span><strong>${dom.actions.hasFactionDepositConfirmYes ? 'Yes' : 'No'}</strong></div>
            </div>

            <div class="tc-section">
                <div class="tc-row"><span>Trade tab</span><strong>${dom.trade.hasTradeTab ? 'Yes' : 'No'}</strong></div>
                <div class="tc-row"><span>Trade box</span><strong>${dom.trade.hasTradeTextbox ? 'Yes' : 'No'}</strong></div>
                <div class="tc-row"><span>Hosp icon</span><strong>${dom.hospital.hasGlobalHospitalIcon ? 'Yes' : 'No'}</strong></div>
                <div class="tc-row"><span>Attack detected</span><strong>${dom.combat.attackDetected ? 'Yes' : 'No'}</strong></div>
            </div>

            <div class="tc-section">
                <label class="tc-label">Torn API key</label>
                <input class="tc-input" id="tc-torn-key" type="password" value="${escapeHtml(state.cfg.tornApiKey)}" />
                <label class="tc-label">FF API key</label>
                <input class="tc-input" id="tc-ff-key" type="password" value="${escapeHtml(state.cfg.ffApiKey)}" />
                <div class="tc-actions" style="margin-top:8px;">
                    <button class="tc-btn primary" id="tc-save-settings">Save keys</button>
                </div>
            </div>

            <div class="tc-small">
                domVersion ${dom.domVersion} • ${new Date(dom.ts || now()).toLocaleTimeString()}
            </div>
        `;

        const saveBtn = state.panelBody.querySelector('#tc-save-settings');
        if (saveBtn) {
            saveBtn.addEventListener('click', () => {
                const tornKey = state.panelBody.querySelector('#tc-torn-key')?.value?.trim() || '';
                const ffKey = state.panelBody.querySelector('#tc-ff-key')?.value?.trim() || '';
                state.cfg.tornApiKey = tornKey;
                state.cfg.ffApiKey = ffKey;
                saveSettings();
            });
        }
    }

    function escapeHtml(str) {
        return String(str || '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function installUnloadHandler() {
        window.addEventListener('beforeunload', () => {
            if (state.isLeader) clearLeaderRecord();
            try {
                if (state.bc) state.bc.close();
            } catch (_) {}
        });
    }

    function init() {
        setupBroadcastChannel();

        const snap = loadSnapshot();
        if (snap && !state.isLeader) {
            applySnapshot(snap);
        }

        maybeBecomeLeader();
        exposeWindowApi();
        createPanel();
        installUnloadHandler();

        domTick(true);

        state.loops.leader = setInterval(() => {
            maybeBecomeLeader();
            if (state.isLeader) {
                heartbeatLeader();
            }
        }, Math.max(500, Number(state.cfg.leaderHeartbeatMs) || 1500));

        state.loops.ui = setInterval(() => {
            renderPanel();
        }, 1000);

        state.loops.bridge = setInterval(() => {
            processBridgeRequests();
        }, 800);
    }

    init();
})();
