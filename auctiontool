    const ExpiringStore = {
        getAll(storageKey) {
            return Util.safeJsonParse(localStorage.getItem(storageKey), {}) || {};
        },

        setAll(storageKey, data) {
            localStorage.setItem(storageKey, JSON.stringify(data || {}));
        },

        get(storageKey, key, ttlMs) {
            const all = this.getAll(storageKey);
            const row = all[key];
            if (!row) return null;
            if ((Date.now() - row.ts) > ttlMs) {
                delete all[key];
                this.setAll(storageKey, all);
                return null;
            }
            return row.data;
        },

        set(storageKey, key, data) {
            const all = this.getAll(storageKey);
            all[key] = { ts: Date.now(), data };
            this.setAll(storageKey, all);
        },

        clear(storageKey) {
            this.setAll(storageKey, {});
        },
    };

