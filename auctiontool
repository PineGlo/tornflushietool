    function renderMarket(modal) {
        const f  = state.filters, ms = settings.get().market;
        const noFiltered = !state.mLoading && !state.mError && !state.mResults.length
            && (f.bonus1Id || f.qualityMin) && (!ms.disableBonusFilter || !ms.disableQualityFilter);

