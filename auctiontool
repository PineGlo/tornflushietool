    const tabsHTML = active => {
        const t = (id, lbl) => `<button class="ah-tab${active===id?' active':''}" data-tab="${id}">${lbl}</button>`;
        return `<div class="ah-tabs">${t('search','Search')}${t('market','Market &amp; Bazaar')}${t('settings','Settings')}</div>`;
    };

    const headerHTML = () =>
        `<div class="ah-header"><h3 class="ah-title">Price History</h3><button class="ah-close" id="ah-close">&times;</button></div>`;

    // Build stats meta line with optional delta badges vs sourceStats
    function statsMetaHTML(dmg, acc, armor, quality, srcStats) {
        const parts = [];
        if (quality != null) {
            const qVal = parseFloat(quality).toFixed(1);
            parts.push(`<span>Quality: <strong>${qVal}%</strong>${srcStats ? deltaBadge(parseFloat(qVal), srcStats.quality, '%') : ''}</span>`);
        }
        if (dmg != null) {
            const d = parseFloat(dmg).toFixed(1);
            parts.push(`<span>DMG: <strong>${d}</strong>${srcStats ? deltaBadge(parseFloat(d), srcStats.dmg) : ''}</span>`);
        }
        if (acc != null) {
            const a = parseFloat(acc).toFixed(1);
            parts.push(`<span>ACC: <strong>${a}</strong>${srcStats ? deltaBadge(parseFloat(a), srcStats.acc) : ''}</span>`);
        }
        if (armor != null) {
            const ar = parseFloat(armor).toFixed(1);
            parts.push(`<span>Armor: <strong>${ar}</strong>${srcStats ? deltaBadge(parseFloat(ar), srcStats.armor) : ''}</span>`);
        }
        return parts.join(`<span class="ah-stat-sep">·</span>`);
    }

    function itemCardHTML(a, isMarket = false) {
        const src = state.sourceStats;

        // Extract stats
        const name    = isMarket ? a.itemName : a.item_name;
        const quality = isMarket ? parseFloat(a.quality||0) : (a.stat_quality ?? null);
        const dmg     = isMarket ? (a.damage   != null ? parseFloat(a.damage)   : null) : (a.stat_damage   ?? null);
        const acc     = isMarket ? (a.accuracy != null ? parseFloat(a.accuracy) : null) : (a.stat_accuracy ?? null);
        const armor   = isMarket ? null : (a.stat_armor ?? null);

        // Bonuses
        let bonusHtml = '';
        if (!isMarket) {
            if (a.bonus_values?.length) bonusHtml = a.bonus_values.map(bv => {
                const bval = bv.bonus_value != null ? bv.bonus_value : null;
                // Delta vs source bonus if same bonus id
                let bdelta = '';
                if (src && bval != null) {
                    const srcB = src.bonuses?.find(b => b.id === bv.bonus_id);
                    if (srcB?.value != null) bdelta = deltaBadge(bval, srcB.value, '%');
                }
                return `<span class="ah-bonus">${bval != null ? bval+'% ' : ''}${bonusName(bv.bonus_id)}${bdelta}</span>`;
            }).join('');
            else if (a.bonus_ids?.length) bonusHtml = a.bonus_ids.map(id => `<span class="ah-bonus">${bonusName(id)}</span>`).join('');
        } else {
            if (a.bonuses) bonusHtml = Object.values(a.bonuses).map(b => `<span class="ah-bonus">${b.value?b.value+'% ':''}${b.bonus}</span>`).join('');
        }

        const metaHTML = statsMetaHTML(dmg, acc, armor, quality, src);

        let rightHTML, bottomHTML;
        if (!isMarket) {
            rightHTML  = `<p class="ah-price">${fmt$(a.price)}</p><p class="ah-date">${fmtDate(a.timestamp)}</p>${a.bid_count?`<p class="ah-bids">${a.bid_count} bids</p>`:''}`;
            bottomHTML = `<p class="ah-players">Seller: ${profileLink(a.seller_id, a.seller_name)} · Buyer: ${profileLink(a.buyer_id, a.buyer_name)}</p>`;
        } else {
            rightHTML  = `<p class="ah-price">${fmt$(a.price)}</p>`;
            const isBaz = a.playerId || a.playerName;
            bottomHTML = `<p class="ah-players">Listed by: ${isBaz ? `<a href="https://www.torn.com/bazaar.php?userId=${a.playerId}#/" target="_blank">${a.playerName||'Unknown'}'s Bazaar</a>` : `<span style="color:var(--t2)">Market Listing</span>`}</p>`;
        }

        return `<div class="ah-item">
            <div class="ah-item-left">
                <div class="ah-item-top"><p class="ah-item-name">${name}</p>${rarityBadge(a.rarity)}</div>
                <div class="ah-item-meta">${metaHTML}</div>
                ${bonusHtml ? `<div class="ah-item-bonuses">${bonusHtml}</div>` : ''}
                ${bottomHTML}
            </div>
            <div class="ah-item-right">${rightHTML}</div>
        </div>`;
    }

    // ─── Render ───────────────────────────────────────────────────────────────────

    function render() {
        const modal = document.getElementById('ah-modal');
        if (!modal) return;
        modal.className = state.open ? 'ah-modal open' : 'ah-modal';
        if (!state.open) return;
        if (state.activeTab === 'search')   renderSearch(modal);
        else if (state.activeTab === 'market')   renderMarket(modal);
        else                                     renderSettings(modal);
    }

    function bindCommon(modal) {
        document.getElementById('ah-close').onclick = closeModal;
        modal.querySelectorAll('.ah-tab').forEach(tab => {
            tab.onclick = () => {
                state.activeTab = tab.dataset.tab; render();
                if (state.activeTab === 'market' && !state.mLoading && !state.mResults.length) doMarketSearch();
            };
        });
    }

    function renderSearch(modal) {
        const f = state.filters;
        const widenBanner = state.autoWidened ? (() => {
            const parts = [];
            if (state.autoWidened.bonusPct  > 0) parts.push(`bonus ±${state.autoWidened.bonusPct}%`);
            if (state.autoWidened.qualityPct > 0) parts.push(`quality ±${state.autoWidened.qualityPct}%`);
            return `<div class="ah-widened">⚠️ <span>No exact matches — results shown with widened <strong>${parts.join(' and ')}</strong></span></div>`;
        })() : '';

        let resultsHTML;
                const analysisHTML = (!state.loading && !state.error)
            ? renderAnalysisBanner()
            : '';
        if (state.loading) {
            resultsHTML = `<div class="ah-loading"><div class="ah-spinner"></div>Searching...</div>`;
        } else if (state.error) {
            resultsHTML = `<div class="ah-error">⚠️ ${state.error}<br><button class="ah-search-btn" id="ah-retry" style="margin-top:10px;font-size:12px;padding:6px 14px">Retry</button></div>`;
        } else if (!state.results.length) {
            resultsHTML = `<div class="ah-empty">No matching sales found</div>`;
        } else {
            resultsHTML = widenBanner + state.results.map(a => itemCardHTML(a)).join('');
        }

        // Suggested price + median stats bar
        let sugHTML = '';
        if (!state.loading && !state.error && state.results.length) {
            const s = computeSuggestion(state.results);
            if (s) {
                const src = state.sourceStats;
                sugHTML = `<div class="ah-suggestion">
                    <div style="display:flex;flex-direction:column;gap:2px">
                        <span class="ah-sug-label">Suggested Price</span>
                        <span class="ah-sug-main">${fmt$(s.suggested)}</span>
                        <span class="ah-sug-range">Low <span>${fmt$(s.low)}</span> – High <span>${fmt$(s.high)}</span></span>
                    </div>
                    <div class="ah-sug-stats">
                        ${s.medDmg     != null ? `<div class="ah-sug-stat"><span class="lbl">DMG</span><span class="val">${s.medDmg.toFixed(1)}</span>${src?.dmg != null ? deltaBadge(s.medDmg, src.dmg) : ''}</div>` : ''}
                        ${s.medAcc     != null ? `<div class="ah-sug-stat"><span class="lbl">ACC</span><span class="val">${s.medAcc.toFixed(1)}</span>${src?.acc != null ? deltaBadge(s.medAcc, src.acc) : ''}</div>` : ''}
                        ${s.medArmor   != null ? `<div class="ah-sug-stat"><span class="lbl">Armor</span><span class="val">${s.medArmor.toFixed(1)}</span>${src?.armor != null ? deltaBadge(s.medArmor, src.armor) : ''}</div>` : ''}
                        ${s.medQuality != null ? `<div class="ah-sug-stat"><span class="lbl">Qual</span><span class="val">${s.medQuality.toFixed(1)}%</span>${src?.quality != null ? deltaBadge(s.medQuality, src.quality, '%') : ''}</div>` : ''}
                    </div>
                    <p class="ah-sug-note">Based on ${s.count} recent sale${s.count!==1?'s':''} (weighted median)</p>
                </div>`;
            }
        }

    modal.innerHTML =
        headerHTML() +
        tabsHTML('search') +
        filterHTML(f) +
        analysisHTML +
        `<div class="ah-results">${resultsHTML}</div>` +
        sugHTML +
        `<div class="ah-footer">
            <span>${state.total.toLocaleString()} results</span>
            <div class="ah-nav">
                <button class="ah-nav-btn" id="ah-prev" ${state.offset === 0 ? 'disabled' : ''}>Prev</button>
                <button class="ah-nav-btn" id="ah-next" ${state.offset + CFG.PAGE_SIZE >= state.total ? 'disabled' : ''}>Next</button>
            </div>
        </div>`;

        bindCommon(modal); setSelects(f);
        document.getElementById('ah-search-btn').onclick = () => { readFilters(); state.offset = 0; doSearch(); };
        document.getElementById('ah-prev').onclick = () => { state.offset = Math.max(0, state.offset-CFG.PAGE_SIZE); doSearch(); };
        document.getElementById('ah-next').onclick = () => { state.offset += CFG.PAGE_SIZE; doSearch(); };
        document.getElementById('ah-item').onkeypress = e => { if (e.key==='Enter') document.getElementById('ah-search-btn').click(); };
        document.getElementById('ah-retry')?.addEventListener('click', () => { state.offset=0; doSearch(); });
        if (f.itemName && f.itemName !== state.lastItem && !state.loading) { state.offset = 0; doSearch(); }
