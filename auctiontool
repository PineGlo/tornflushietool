                <input type="file" id="s-import-file" class="ah-hidden" accept=".json">
                <button class="ah-reset-btn" id="s-reset">Reset All</button>
            </div>
        </div>`;

        bindCommon(modal);

        // ── Appearance sliders / colour pickers ──
        const liveRange = (id, dispId, unit, fn) => {
            const el = document.getElementById(id), disp = document.getElementById(dispId);
