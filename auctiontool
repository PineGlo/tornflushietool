    function deltaBadge(val, refVal, unit = '') {
        if (refVal == null || val == null) return '';
        const diff = parseFloat((val - refVal).toFixed(1));
        if (diff === 0) return `<span class="ah-delta eq">≈</span>`;
        const sign = diff > 0 ? '+' : '';
        const cls  = diff > 0 ? 'pos' : 'neg';
        return `<span class="ah-delta ${cls}">${sign}${diff}${unit}</span>`;
    }

    function computeSuggestion(results) {
        if (!results?.length) return null;
        const now = Date.now() / 1000;
        const w = results.map(a => ({ p: a.price, w: Math.exp(-((now-a.timestamp)/86400)/60) })).sort((a,b)=>a.p-b.p);
        const tot = w.reduce((s,x)=>s+x.w, 0);
        let cum = 0, med = w[0].p;
        for (const x of w) { cum += x.w; if (cum >= tot/2) { med = x.p; break; } }
        const prices = results.map(a=>a.price).sort((a,b)=>a-b);
        // Median stats across results
        const midIdx = Math.floor(results.length / 2);
        const sorted = [...results].sort((a,b)=>(a.stat_quality||0)-(b.stat_quality||0));
        const mid    = sorted[midIdx];
        return {
            suggested: med,
            low:  prices[Math.floor(prices.length*0.10)] ?? prices[0],
            high: prices[Math.floor(prices.length*0.90)] ?? prices[prices.length-1],
            count: results.length,
            medDmg:     mid?.stat_damage,
            medAcc:     mid?.stat_accuracy,
            medArmor:   mid?.stat_armor,
            medQuality: mid?.stat_quality,
        };
    }
