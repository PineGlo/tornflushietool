    // ─── Init ─────────────────────────────────────────────────────────────────────

    function init() {
        createModal();
        injectPageScanButton();
        injectButtons();
        new MutationObserver(() => setTimeout(injectButtons, 200)).observe(document.body, { childList: true, subtree: true });
        setInterval(injectButtons, 2000);
    }

    document.readyState === 'loading'
        ? document.addEventListener('DOMContentLoaded', init)
        : init();

