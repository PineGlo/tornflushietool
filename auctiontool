        ensurePageBatchButton() {
            let btn = document.getElementById('twx-page-batch-btn');

            if (!Util.pageIsAuction()) {
                if (btn) btn.remove();
                return;
            }

            if (!btn) {
                btn = document.createElement('button');
                btn.id = 'twx-page-batch-btn';
                btn.className = 'twx-page-batch-btn';
                btn.addEventListener('click', async () => {
                    if (AppState.batch.running) return;
                    await Actions.priceEntirePage();
                });
                document.body.appendChild(btn);
            }

            btn.disabled = !!AppState.batch.running;
            btn.textContent = AppState.batch.running
                ? `Pricing Page ${AppState.batch.statusText}`
                : (AppState.batch.statusText
                    ? `Price Page • ${AppState.batch.statusText}`
                    : 'Price Entire Auction Page');
        },
    };

    /**********************************************************************
     * DRAG
     **********************************************************************/
    const Drag = {
        makeDraggable(modal, handle) {
            if (!modal || !handle) return;

            let dragging = false;
            let startX = 0;
            let startY = 0;
            let startLeft = 0;
            let startTop = 0;

            const saved = Util.safeJsonParse(localStorage.getItem(CFG.MODAL_POS_KEY), null);
            if (saved && Number.isFinite(saved.left) && Number.isFinite(saved.top)) {
                modal.style.left = `${saved.left}px`;
                modal.style.top = `${saved.top}px`;
                modal.style.transform = 'none';
            }

            handle.addEventListener('mousedown', (e) => {
                if (e.target.closest('button')) return;
                dragging = true;
                startX = e.clientX;
                startY = e.clientY;

                const rect = modal.getBoundingClientRect();
                startLeft = rect.left;
                startTop = rect.top;
                document.body.style.userSelect = 'none';
            });

            window.addEventListener('mousemove', (e) => {
                if (!dragging) return;
                const dx = e.clientX - startX;
                const dy = e.clientY - startY;
                modal.style.left = `${startLeft + dx}px`;
                modal.style.top = `${startTop + dy}px`;
                modal.style.transform = 'none';
            });

            window.addEventListener('mouseup', () => {
                if (!dragging) return;
                dragging = false;
                document.body.style.userSelect = '';
                const rect = modal.getBoundingClientRect();
                localStorage.setItem(CFG.MODAL_POS_KEY, JSON.stringify({ left: rect.left, top: rect.top }));
            });
        },
    };

    /**********************************************************************
     * ACTIONS
     **********************************************************************/
    const Actions = {
        reparsePage() {
            const items = AuctionParser.parseAll();

            const byRowKey = new Map(AppState.items.map(item => [item.rowKey, item]));
            for (const item of items) {
                const old = byRowKey.get(item.rowKey);
                if (old?.historySummary && !item.historySummary) {
                    item.historySummary = old.historySummary;
                    item.historyRows = old.historyRows || [];
                    item.historyError = old.historyError || null;
                }
            }

            AppState.items = items;

            if (AppState.activeItem) {
                const same = items.find(x => x.rowKey === AppState.activeItem.rowKey);
                AppState.activeItem = same || items[0] || null;
            } else {
                AppState.activeItem = items[0] || null;
            }

            ItemDecorators.refresh(items);
            UI.ensurePageBatchButton();

            const modal = document.getElementById('twx-modal');
            if (modal?.classList.contains('open')) {
                if (AppState.ui.activeTab === 'search') return;
                UI.renderActiveItem(AppState.activeItem);
            }
        },

        clearCaches() {
            ExpiringStore.clear(CFG.HISTORY_CACHE_KEY);
            ExpiringStore.clear(CFG.ROW_CACHE_KEY);

            for (const item of AppState.items) {
                item.historySummary = null;
                item.historyRows = [];
                item.historyError = null;
            }

            ItemDecorators.refresh(AppState.items);
            UI.ensurePageBatchButton();
        },

        async runSearch() {
            AppState.search.loading = true;
            AppState.search.error = null;
            UI.renderActiveItem(AppState.activeItem);

            try {
                const [historyResult, liveResult] = await Promise.all([
                    DataAPI.searchAuctionHistory(AppState.search.filters).catch((err) => ({ rows: [], total: 0, _error: err })),
                    DataAPI.searchWeav3rLive(AppState.search.filters).catch((err) => ({ rows: [], total: 0, _error: err })),
                ]);

                AppState.search.rows = [...(liveResult.rows || []), ...(historyResult.rows || [])];
                AppState.search.total = Number((historyResult.total || 0) + (liveResult.total || 0));
                AppState.search.lastRunAt = Date.now();
                if (historyResult._error && liveResult._error) {
                    throw new Error(`History: ${historyResult._error?.message || 'failed'} | Live: ${liveResult._error?.message || 'failed'}`);
                }
            } catch (err) {
                AppState.search.rows = [];
                AppState.search.total = 0;
                AppState.search.error = err?.message || 'Search failed';
            } finally {
                AppState.search.loading = false;
                UI.renderActiveItem(AppState.activeItem);
            }
        },

        async selectAndPriceItem(index, forceRefresh = false) {
            const item = AppState.items[index];
            if (!item) return;

            AppState.activeItem = item;
            AppState.ui.activeTab = 'details';
            UI.openModal();
            UI.renderActiveItem(item);

            if (SettingsStore.get().autoPriceOnClick || forceRefresh) {
                await this.priceItem(item, forceRefresh);
                UI.renderActiveItem(item);
            }
        },

        async priceItem(item, forceRefresh = false) {
            const fpKey = DataAPI.historyKeyFromFingerprint(item.historyFingerprint);

            if (!forceRefresh) {
                const cached = ExpiringStore.get(CFG.HISTORY_CACHE_KEY, fpKey, CFG.HISTORY_CACHE_TTL_MS);
                if (cached) {
                    item.historySummary = cached.summary || null;
                    item.historyRows = cached.rows || [];
                    item.historyError = cached.error || null;

                    ExpiringStore.set(CFG.ROW_CACHE_KEY, item.rowKey, {
                        summary: item.historySummary,
                        rows: item.historyRows,
                        error: item.historyError,
                    });

                    ItemDecorators.ensureHistorySummary(item);
                    return item.historySummary;
                }
            }

            try {
                const result = await DataAPI.searchAuctionHistory(item.historyFingerprint);
                const summary = HistoryAnalysis.summarize(result.rows || []);

                item.historySummary = summary;
                item.historyRows = result.rows || [];
                item.historyError = null;

                ExpiringStore.set(CFG.HISTORY_CACHE_KEY, fpKey, {
                    summary,
                    rows: item.historyRows,
                    error: null,
                });

                ExpiringStore.set(CFG.ROW_CACHE_KEY, item.rowKey, {
                    summary,
                    rows: item.historyRows,
                    error: null,
                });

                ItemDecorators.ensureHistorySummary(item);
                return summary;
            } catch (err) {
                const msg = err?.message || 'History request failed';
                item.historySummary = {
                    lastSold: null,
                    count: 0,
                    median: null,
                    low: null,
                    high: null,
                    suggested: null,
                    rows: [],
                };
                item.historyRows = [];
                item.historyError = msg;

                ExpiringStore.set(CFG.HISTORY_CACHE_KEY, fpKey, {
                    summary: item.historySummary,
                    rows: [],
                    error: msg,
                });

                ExpiringStore.set(CFG.ROW_CACHE_KEY, item.rowKey, {
                    summary: item.historySummary,
                    rows: [],
                    error: msg,
                });

                ItemDecorators.ensureHistorySummary(item);
                return item.historySummary;
            }
        },

        async priceEntirePage() {
            const items = AppState.items || [];
            if (!items.length) return;

            AppState.batch.running = true;
            AppState.batch.done = 0;
            AppState.batch.total = items.length;
            AppState.batch.statusText = `0 / ${items.length}`;
            UI.ensurePageBatchButton();

            for (let i = 0; i < items.length; i++) {
                const item = items[i];

                await this.priceItem(item, false);

                AppState.batch.done = i + 1;
                AppState.batch.statusText = `${i + 1} / ${items.length}`;
                UI.ensurePageBatchButton();

                if (AppState.activeItem?.rowKey === item.rowKey) {
                    UI.renderActiveItem(item);
                }

                if (i < items.length - 1) {
                    await Util.sleep(CFG.REQUEST_SPACING_MS);
                }
            }

            AppState.batch.running = false;
            AppState.batch.statusText = `Done (${items.length})`;
            UI.ensurePageBatchButton();
        },
    };

    /**********************************************************************
     * SAFE BOOT / RESCAN
     **********************************************************************/
    function bootPass() {
        try {
            Actions.reparsePage();
        } catch (err) {
            console.error('[TWX] reparse failed', err);
        }
    }

    function startBootPasses() {
        let runs = 0;
        if (AppState.bootTimer) clearInterval(AppState.bootTimer);

        AppState.bootTimer = setInterval(() => {
            runs++;
            bootPass();

            if (runs >= CFG.BOOT_PASS_COUNT) {
                clearInterval(AppState.bootTimer);
                AppState.bootTimer = null;
            }
        }, CFG.BOOT_PASS_INTERVAL_MS);
    }

    function startPeriodicRescan() {
        if (AppState.rescanTimer) clearInterval(AppState.rescanTimer);

        AppState.rescanTimer = setInterval(() => {
            if (AppState.batch.running) return;
            bootPass();
        }, CFG.RESCAN_INTERVAL_MS);
    }

    /**********************************************************************
     * INIT
     **********************************************************************/
    function init() {
        if (!Util.pageIsAuction()) return;

        Theme.apply();
        UI.ensureModal();
        UI.ensurePageBatchButton();

        startBootPasses();
        startPeriodicRescan();
    }

    window.addEventListener('load', () => {
        setTimeout(init, 1200);
    });

    setTimeout(() => {
        if (Util.pageIsAuction()) init();
    }, 2200);
})();
