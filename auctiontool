            );

            const found = [];
            for (const bonus of BONUS_DATA) {
                const safe = bonus.title.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                const rx1 = new RegExp(`\\b${safe}\\b[: ]*\\s*(\\d+(?:\\.\\d+)?)?%?`, 'i');
                const rx2 = new RegExp(`(\\d+(?:\\.\\d+)?)%\\s+${safe}`, 'i');
                const m = normalized.match(rx2) || normalized.match(rx1);
                if (m) {
                    found.push({
                        id: bonus.id,
                        name: bonus.title,
                        value: m[1] != null && m[1] !== '' ? parseFloat(m[1]) : null,
                    });
                }
            }
            return found;
        },

        parseEffectTypesFromRow(row) {
            const out = [];

            const spans = Util.qsa('.item-bonuses .iconsbonuses span[title]', row);
            for (const span of spans) {
                const title = span.getAttribute('title') || '';
                const m = title.match(/<b>(.*?)<\/b>/i);
                if (m && m[1]) {
                    out.push({ name: Util.normalizeWhitespace(m[1]) });
                }
            }

            const icons = Util.qsa('.item-bonuses .iconsbonuses i', row);
            for (const icon of icons) {
                const classes = Array.from(icon.classList || []);
                const cls = classes.find(c => c.startsWith('bonus-attachment-'));
                if (!cls) continue;
                if (cls.includes('item-damage-bonus') || cls.includes('item-accuracy-bonus')) continue;

                const plain = cls.replace(/^bonus-attachment-/, '').replace(/[-_]+/g, ' ');
                const pretty = plain.replace(/\b\w/g, c => c.toUpperCase());
                out.push({ name: pretty });
            }

            return Util.uniqueBy(out.filter(x => x.name), x => x.name).slice(0, 2);
        },
    };

    const BB = {
        getExactValue(item) {
            const table = TypeNormalizer.getBunkerValues(item.classification?.normalizedType);
            if (!table) return null;

            const rarity = item.rarity;
            const effects = item.effectCount || 0;

            if (rarity === 'yellow') return table.yellow ?? null;
            if (rarity === 'orange') return effects >= 2 ? (table.orangeTwo ?? table.orange ?? null) : (table.orange ?? null);
            if (rarity === 'red') return effects >= 2 ? (table.redTwo ?? table.red ?? null) : (table.red ?? null);
            return null;
        },

        rarityColor(rarity) {
            if (rarity === 'yellow') return '#facc15';
            if (rarity === 'orange') return '#fb923c';
            if (rarity === 'red') return '#ef4444';
            return '#7dd3fc';
        },
    };

    const Deal = {
        getTargetValue(item) {
            const settings = SettingsStore.get();
            if (!item?.bbValue || !settings.targetPerBB) return null;
            return item.bbValue * settings.targetPerBB;
        },

        getPercent(item) {
            const target = this.getTargetValue(item);
            if (!target || !item?.currentPrice) return null;
            return (item.currentPrice / target) * 100;
        },

        getPercentLabel(item) {
            const pct = this.getPercent(item);
            if (pct == null) return '—';
            return `${Math.round(pct)}%`;
        },

        getPercentColor(item) {
            const pct = this.getPercent(item);
            const s = SettingsStore.get();

            if (pct == null) return '#94a3b8';
            if (pct <= s.pctGood) return '#34d399';
            if (pct <= s.pctWarn) return '#fbbf24';
            if (pct <= s.pctBad) return '#fb923c';
            return '#ef4444';
        },

        parseTargetInput(raw) {
            const v = String(raw || '').trim();
            if (!v) return null;
            return Util.parseMoney(v) ?? Util.tryNumber(v);
        },
    };

    const HistoryAnalysis = {
        summarize(rows = []) {
            if (!rows.length) {
                return {
                    lastSold: null,
                    count: 0,
                    median: null,
                    low: null,
                    high: null,
                    suggested: null,
                    rows: [],
                };
            }

            const prices = rows
                .map(r => Number(r.price))
                .filter(n => Number.isFinite(n) && n > 0)
                .sort((a, b) => a - b);

            if (!prices.length) {
                return {
                    lastSold: null,
                    count: 0,
                    median: null,
                    low: null,
                    high: null,
                    suggested: null,
                    rows,
                };
            }

            const median = prices[Math.floor(prices.length / 2)] ?? null;
            const low = prices[Math.floor(prices.length * 0.10)] ?? prices[0] ?? null;
            const high = prices[Math.floor(prices.length * 0.90)] ?? prices[prices.length - 1] ?? null;

            const newest = [...rows]
                .filter(r => Number.isFinite(Number(r.timestamp)))
                .sort((a, b) => Number(b.timestamp) - Number(a.timestamp))[0];

            const lastSold = newest?.price != null ? Number(newest.price) : null;

            return {
                lastSold,
                count: prices.length,
                median,
                low,
                high,
                suggested: median,
                rows,
            };
        },
    };

    /**********************************************************************
     * PARSER
     **********************************************************************/
    const AuctionParser = {
        findRows() {
            return Util.qsa('li[id]').filter(row =>
                row.querySelector('.item-cont-wrap') &&
                row.querySelector('.item-name')
            );
        },

        parseAll() {
            const items = this.findRows()
                .map(row => this.parseRow(row))
                .filter(Boolean);

            return Util.uniqueBy(items, item => item.rowKey);
        },

        parseRow(row) {
            const itemName = Util.text(row.querySelector('.item-name'));
            if (!itemName) return null;

            const imageElement = row.querySelector('.item-plate img, .img-wrap img') || null;
            const currentPrice = Util.parseMoney(Util.text(row.querySelector('.c-bid-wrap')));
            const seller = Util.text(row.querySelector('.seller-wrap .name a')) || null;
            const highBidder = Util.text(row.querySelector('.seller-wrap .namehight a')) || null;

            const bidCountText = Util.text(row.querySelector('.bids-wrap'));
            const bidCountMatch = bidCountText.match(/(\d+)/);
            const bidCount = bidCountMatch ? Number(bidCountMatch[1]) : null;

            const endTitle = row.querySelector('.time-wrap [title]')?.getAttribute('title') || '';
            const timeLeft = Util.text(row.querySelector('.time-wrap .dh-time')) ||
                             Util.text(row.querySelector('.time-wrap .time')) ||
                             null;

            const aria = row.querySelector('.view-info')?.getAttribute('aria-label') || '';

            const collapsed = this.extractCollapsedStats(row, aria);
            const expanded = this.extractExpandedStats(row);
            const classification = this.extractClassification(row, itemName, aria);
            const rarity = expanded.rarity || this.extractGlowRarity(row) || null;
            const effectTypes = this.extractEffectTypes(row, collapsed, expanded);
            const iconEffectCount = Util.qsa('.item-bonuses .iconsbonuses i', row).filter(i => {
                const cls = Array.from(i.classList || []).join(' ');
                return !cls.includes('item-damage-bonus') && !cls.includes('item-accuracy-bonus');
            }).length;
            const effectCount = Math.min(2, Math.max(iconEffectCount, effectTypes.length, collapsed.bonuses.length, expanded.bonuses.length));

            const stats = {
                dmg: expanded.dmg ?? collapsed.dmg ?? null,
                acc: expanded.acc ?? collapsed.acc ?? null,
                armor: expanded.armor ?? collapsed.armor ?? null,
                quality: expanded.quality ?? collapsed.quality ?? null,
                bonuses: expanded.bonuses.length ? expanded.bonuses : collapsed.bonuses,
            };

            const rowKey = JSON.stringify({
                itemName,
                currentPrice: currentPrice || 0,
                seller: seller || '',
                highBidder: highBidder || '',
                bids: bidCount || 0,
                endTitle: endTitle || '',
                quality: stats.quality ?? '',
                bonuses: (stats.bonuses || []).map(b => `${b.name || b.id}:${b.value ?? ''}`).join('|'),
            });

            const fingerprint = {
                itemName: itemName || '',
                qualityMin: stats.quality != null ? String(Math.floor(stats.quality)) : '',
                qualityMax: stats.quality != null ? String(Math.ceil(stats.quality)) : '',
                bonus1Id: stats.bonuses?.[0]?.id != null ? String(stats.bonuses[0].id) : '',
                bonus1Min: stats.bonuses?.[0]?.value != null ? String(stats.bonuses[0].value) : '',
                bonus1Max: stats.bonuses?.[0]?.value != null ? String(stats.bonuses[0].value) : '',
                bonus2Id: stats.bonuses?.[1]?.id != null ? String(stats.bonuses[1].id) : '',
                bonus2Min: stats.bonuses?.[1]?.value != null ? String(stats.bonuses[1].value) : '',
                bonus2Max: stats.bonuses?.[1]?.value != null ? String(stats.bonuses[1].value) : '',
            };

            const cachedSummary = ExpiringStore.get(CFG.ROW_CACHE_KEY, rowKey, CFG.ROW_CACHE_TTL_MS) || null;

            const item = {
                pageType: 'auction',
                itemType: classification.normalizedType === 'armor' ? 'armor' : 'weapon',
                itemName,
                currentPrice,
                seller,
                highBidder,
                bidCount,
                endTitle,
                timeLeft,
                sourceStats: stats,
                classification,
                rarity,
                effectCount,
                effectTypes,
                auctionId: row.id || null,
                rowKey,
                historyFingerprint: fingerprint,
                containerElement: row,
                sourceElement: row.querySelector('.item-cont-wrap') || row,
                imageElement,
                historySummary: cachedSummary?.summary || null,
                historyRows: cachedSummary?.rows || [],
                historyError: cachedSummary?.error || null,
            };

            item.bbValue = BB.getExactValue(item);
            return item;
        },

        extractCollapsedStats(row, ariaText) {
            let dmg = null;
            let acc = null;
            let armor = null;
            let quality = null;
            let bonuses = [];

            const statSpans = Util.qsa('.item-bonuses .infobonuses .label-value', row)
                .map(el => Util.text(el))
                .filter(Boolean);

            if (statSpans.length >= 1) dmg = Util.tryNumber(statSpans[0]);
            if (statSpans.length >= 2) acc = Util.tryNumber(statSpans[1]);

            const bonusTitles = Util.qsa('.iconsbonuses [title]', row)
                .map(el => el.getAttribute('title') || '')
                .filter(Boolean);

            for (const t of bonusTitles) {
                bonuses.push(...Stats.parseBonusesFromText(t));
            }

            if (ariaText) {
                const dmgMatch = ariaText.match(/Damage:\s*([0-9.]+)/i);
                const accMatch = ariaText.match(/Accuracy:\s*([0-9.]+)/i);
                const qMatch = ariaText.match(/([0-9.]+)%\s*Quality/i);

                if (dmg == null && dmgMatch) dmg = parseFloat(dmgMatch[1]);
                if (acc == null && accMatch) acc = parseFloat(accMatch[1]);
                if (quality == null && qMatch) quality = parseFloat(qMatch[1]);

                if (!bonuses.length) {
                    bonuses = Stats.parseBonusesFromText(ariaText);
                }
            }

            bonuses = Util.uniqueBy(bonuses, b => `${b.name || b.id}:${b.value ?? ''}`).slice(0, 2);
            return { dmg, acc, armor, quality, bonuses };
        },

        extractExpandedStats(row) {
            const info = row.querySelector('.show-item-info .item-info, .show-item-info .itemInfo___mNZ5j');
            if (!info) {
                return { dmg: null, acc: null, armor: null, quality: null, bonuses: [], rarity: null };
            }

            const dmg = Util.tryNumber(Util.getPropRowValue(info, 'Damage'));
            const acc = Util.tryNumber(Util.getPropRowValue(info, 'Accuracy'));
            const armor = Util.tryNumber(Util.getPropRowValue(info, 'Armor'));
            const quality = Util.parsePercent(Util.getPropRowValue(info, 'Quality'));
            const bonusText = Util.getPropRowValue(info, 'Bonus');
            const rarityText = Util.text(info.querySelector('[class*="rarity"]'));
            const rarity = rarityText ? Util.lower(rarityText) : null;

            const bonuses = Util.uniqueBy(
                Stats.parseBonusesFromText(bonusText),
                b => `${b.name || b.id}:${b.value ?? ''}`
            ).slice(0, 2);

            return {
                dmg,
                acc,
                armor,
                quality,
                bonuses,
                rarity: rarity && (rarity.includes('yellow') || rarity.includes('orange') || rarity.includes('red'))
                    ? (rarity.includes('yellow') ? 'yellow' : rarity.includes('orange') ? 'orange' : 'red')
                    : null
            };
        },

        extractClassification(row, itemName, ariaText) {
            let typeName = '';

            const infoDesc = row.querySelector('.show-item-info .description___xJ1N5, .show-item-info [class*="description"]');
            const descText = Util.text(infoDesc);
            const descMatch = descText.match(/\bis a\s+([A-Za-z ]+?)\s+Weapon\b/i);
            if (descMatch) typeName = descMatch[1].trim();

            if (!typeName && ariaText) {
                const ariaTypeMatch = ariaText.match(/\b(Pistol|SMG|Shotgun|Rifle|Machine Gun|Heavy Artillery|Clubbing|Slashing|Piercing|Mechanical|Armor)\b/i);
                if (ariaTypeMatch) typeName = ariaTypeMatch[1];
            }

            if (!typeName) {
                typeName = WeaponNameTypeLookup[itemName] || '';
            }

            return {
                slot: null,
                typeName,
                normalizedType: TypeNormalizer.normalizeTypeName(typeName),
            };
        },

        extractGlowRarity(row) {
            const plate = row.querySelector('.item-plate');
            if (!plate) return null;
            const cls = plate.className;
            if (/glow-yellow/i.test(cls)) return 'yellow';
            if (/glow-orange/i.test(cls)) return 'orange';
            if (/glow-red/i.test(cls)) return 'red';
            return null;
        },

        extractEffectTypes(row, collapsed, expanded) {
            const fromIcons = Stats.parseEffectTypesFromRow(row);
            if (fromIcons.length) return fromIcons.slice(0, 2);

            const fromBonuses = (expanded?.bonuses?.length ? expanded.bonuses : collapsed?.bonuses || [])
                .map(b => ({
                    id: b.id ?? null,
                    name: b.name || Stats.bonusName(b.id),
                    value: b.value ?? null,
                }));

            return Util.uniqueBy(fromBonuses, x => x.name).slice(0, 2);
        },
    };

