    // ─── Modal lifecycle ──────────────────────────────────────────────────────────

    const posStore = {
        load() { try { return JSON.parse(localStorage.getItem(CFG.POSITION_KEY)||'null'); } catch { return null; } },
        save(p) { try { localStorage.setItem(CFG.POSITION_KEY, JSON.stringify(p)); } catch {} },
    };

    const isPC = () => window.matchMedia('(min-width: 768px) and (pointer: fine)').matches;

    function setupDrag(modal) {
        let drag = false, ox = 0, oy = 0;
        document.addEventListener('mousedown', e => {
            if (!e.target.closest('.ah-header') || !state.open || e.target.closest('.ah-close')) return;
            drag = true; modal.classList.add('dragging');
            const r = modal.getBoundingClientRect();
            if (modal.style.transform) { modal.style.transform='none'; modal.style.top=r.top+'px'; modal.style.left=r.left+'px'; }
            ox = e.clientX - r.left; oy = e.clientY - r.top;
        });
        document.addEventListener('mousemove', e => {
            if (!drag) return;
            modal.style.left = Math.max(0, Math.min(e.clientX-ox, window.innerWidth -modal.offsetWidth ))+'px';
            modal.style.top  = Math.max(0, Math.min(e.clientY-oy, window.innerHeight-modal.offsetHeight))+'px';
        });
        document.addEventListener('mouseup', () => {
            if (!drag) return;
            drag = false; modal.classList.remove('dragging');
            posStore.save({ top: modal.style.top, left: modal.style.left, w: modal.offsetWidth, h: modal.offsetHeight });
        });
        new ResizeObserver(() => { if (state.open && !drag) posStore.save({ top: modal.style.top, left: modal.style.left, w: modal.offsetWidth, h: modal.offsetHeight }); }).observe(modal);
    }

    function createModal() {
        const modal = document.createElement('div');
        modal.id = 'ah-modal';
        document.body.appendChild(modal);
        if (isPC()) setupDrag(modal);
    }

    function openModal(itemName, parsedBonuses, quality, itemType = 'weapon', srcStats = null) {
        state.open      = true;
        state.activeTab = 'search';
        state.offset    = 0;
        state.itemType  = itemType;
        state.mResults  = []; state.mTotal = 0;
        state.lastItem  = ''; state.mLastItem = '';
        state.filters.itemName = itemName || '';
        // Store the source item stats for comparison deltas
        state.sourceStats = srcStats;

        const modal = document.getElementById('ah-modal');
        if (modal) {
            if (isPC()) {
                const pos = posStore.load();
                if (pos?.top && pos?.left) {
                    modal.style.transform = 'none'; modal.style.top = pos.top; modal.style.left = pos.left;
                    if (pos.w) modal.style.width = pos.w+'px'; if (pos.h) modal.style.height = pos.h+'px';
                } else { modal.style.transform = 'translate(-50%,-50%)'; modal.style.top = '50%'; modal.style.left = '50%'; }
            } else { modal.style.transform = 'none'; modal.style.top = modal.style.left = ''; }
        }

        const calcRange = (val, tol) => {
            if (!val) return { min:'', max:'' };
            if (tol === 0) return { min: String(val), max: String(val) };
            const f = tol/100;
            return { min: String(Math.floor(val*(1-f))), max: String(Math.ceil(val*(1+f))) };
        };

        const b1 = parsedBonuses?.[0], b2 = parsedBonuses?.[1];
        state.filters.bonus1Id = b1 ? String(b1.id) : ''; state.filters.bonus2Id = b2 ? String(b2.id) : '';
        const r1 = b1 ? calcRange(b1.value, settings.bonusTol(b1.id)) : {min:'',max:''};
        const r2 = b2 ? calcRange(b2.value, settings.bonusTol(b2.id)) : {min:'',max:''};
        state.filters.bonus1Min = r1.min; state.filters.bonus1Max = r1.max;
        state.filters.bonus2Min = r2.min; state.filters.bonus2Max = r2.max;

        const qTol = settings.qualityTol(b1?.id);
        const qr   = (qTol !== null && quality) ? calcRange(quality, qTol) : {min:'',max:''};
        state.filters.qualityMin = qr.min; state.filters.qualityMax = qr.max;

        state.results = []; state.total = 0;
        render(); doSearch();
    }

    function closeModal() { state.open = false; render(); }

    // ─── Page parsing ─────────────────────────────────────────────────────────────

    const getPageType = () => {
        const u = location.href;
        if (u.includes('amarket.php'))    return 'auction';
        if (u.includes('sid=ItemMarket')) return 'itemmarket';
        if (u.includes('item.php'))       return 'inventory';
        if (u.includes('bazaar.php'))     return 'bazaar';
        if (u.includes('displaycase.php')) return 'displaycase';
        if (u.includes('trade.php'))      return 'trading';
        if (u.includes('factions.php') && u.includes('armoury')) return 'armory';
        return 'unknown';
    };

    function hasRarity(el) {
        const r = el.querySelector('[class*="rarity___"]');
        if (r) { const t = (r.className+r.textContent).toLowerCase(); if (t.includes('yellow')||t.includes('orange')||t.includes('red')) return true; }
        return !!el.querySelector('[class*="extraordinary"],[class*="extremely-rare"]');
    }

    function parseReactItem(el) {
        let itemName = '', bonuses = [], quality = null, itemType = 'weapon';
        let dmg = null, acc = null, armor = null;
        const nameEl = el.querySelector('.description___xJ1N5 .bold,[class*="description"] .bold,[class*="itemName"],.item-name');
        if (nameEl) itemName = nameEl.textContent.trim().replace(/^The\s+/i, '');

        for (const prop of el.querySelectorAll('li[class*="propertyWrapper"],[class*="propertyWrapper"]')) {
            const title = prop.querySelector('[class*="title"]')?.textContent.trim();
            if (!title) continue;
            if (title === 'Damage:') { itemType = 'weapon'; const v = prop.querySelector('[aria-label*="Damage"]'); if(v){const m=(v.getAttribute('aria-label')||'').match(/([\d.]+)/);if(m)dmg=parseFloat(m[1]);} }
            else if (title === 'Armor:') { itemType = 'armor'; const v = prop.querySelector('[aria-label*="Armor"]'); if(v){const m=(v.getAttribute('aria-label')||'').match(/([\d.]+)/);if(m)armor=parseFloat(m[1]);} }
            if (title === 'Accuracy:') { const v = prop.querySelector('[aria-label*="Accuracy"]'); if(v){const m=(v.getAttribute('aria-label')||'').match(/([\d.]+)/);if(m)acc=parseFloat(m[1]);} }
            if (title === 'Quality:') { const v = prop.querySelector('[aria-label*="Quality"]'); if(v){const m=(v.getAttribute('aria-label')||'').match(/([\d.]+)/);if(m)quality=parseFloat(m[1]);} }
            if (title === 'Bonus:') {
                const v = prop.querySelector('[aria-label*="Bonus"]');
                if (v) {
                    const aria = v.getAttribute('aria-label') || '';
                    const mv = aria.match(/([\d.]+)\s*(%|T)?\s*(.+?)\s*Bonus/i);
                    let bName = mv ? mv[3].trim() : (aria.match(/^\s*(.+?)\s*Bonus/i)||[])[1]?.trim();
                    if (bName) { const id = bonusId(bName); if (id) bonuses.push({ id, value: mv ? parseFloat(mv[1]) : null }); }
                }
            }
        }
        return { itemName, bonuses, quality, itemType, srcStats: { dmg, acc, armor, quality, bonuses } };
    }

    function parseLegacyItem(row) {
        let itemName = '', bonuses = [], quality = null, itemType = 'weapon';
        itemName = row.querySelector('.item-name')?.textContent.trim() || '';
        const exp = row.querySelector('.show-item-info');
        if (exp?.textContent.includes('Armor:')) itemType = 'armor';
        const bonusTxt = row.querySelector('.title p.t-gray-6');
        if (bonusTxt) {
            for (const line of bonusTxt.innerHTML.split(/<br\s*\/?>/i)) {
                const text = line.trim();
                const mv = text.match(/([\d.]+)\s*(%|T)\s+(.+)/i);
                const bName = mv ? mv[3].trim() : (text && !text.match(/^\d/) ? text : null);
                if (bName) { const id = bonusId(bName); if (id) bonuses.push({ id, value: mv ? parseFloat(mv[1]) : null }); }
            }
        }
        if (exp) { const qs = exp.querySelector('span[aria-label*="Quality"]'); if(qs){const m=(qs.getAttribute('aria-label')||'').match(/([\d.]+)/);if(m)quality=parseFloat(m[1]);} }
        return { itemName, bonuses, quality, itemType, srcStats: { dmg:null, acc:null, armor:null, quality, bonuses } };
    }

    const makeBtn = onClick => {
        const btn = document.createElement('button');
        btn.className = 'ah-btn'; btn.textContent = 'Price Check';
        btn.onclick = e => { e.preventDefault(); e.stopPropagation(); onClick(); };
        return btn;
    };

    function injectInto(containers, checkRarity = true) {
        containers.forEach(el => {
            const parsed = parseReactItem(el);
            const bbAmount = calcBunkerBucks(parsed.itemName, getRarityKey(el), parsed.bonuses.length, parsed.itemType);
            injectBBBage(el, bbAmount);
            if (el.querySelector('.ah-btn')) return;
            if (checkRarity && !hasRarity(el)) return;
            const wrap = el.querySelector('.descriptionWrapper___Lh0y0,[class*="itemInfo___"]') || el;
            wrap.style.position = 'relative';
            wrap.appendChild(makeBtn(() => { const d = parseReactItem(el); openModal(d.itemName, d.bonuses, d.quality, d.itemType, d.srcStats); }));
        });
    }

    function injectAuction() {
        for (const sel of ['.itemInfoWrapper___nA_eu','[class*="itemInfoWrapper"]','[class*="itemInfo___"]']) {
            const els = document.querySelectorAll(sel);
            if (!els.length) continue;
            Array.from(els).forEach(el => {
                if (!el.querySelector('[class*="propertyWrapper"],[aria-label*="Bonus"],[aria-label*="Quality"]')) return;
                const parsed = parseReactItem(el);
                const bbAmount = calcBunkerBucks(parsed.itemName, getRarityKey(el), parsed.bonuses.length, parsed.itemType);
                injectBBBage(el, bbAmount);
                if (el.querySelector('.ah-btn')) return;
                const wrap = el.querySelector('.descriptionWrapper___Lh0y0') || el;
                wrap.appendChild(makeBtn(() => {
                    const d = parseReactItem(el);
                    document.querySelectorAll('.ah-open-source').forEach(x => x.classList.remove('ah-open-source'));
                    el.classList.add('ah-open-source');
                    openModal(d.itemName, d.bonuses, d.quality, d.itemType, d.srcStats);
                }));
            });
            return;
        }

        // Legacy
        document.querySelectorAll('li').forEach(li => {
            if (!li.querySelector('.item-cont-wrap')) return;
            const exp = li.querySelector('.show-item-info');
            if (!exp || exp.style.display === 'none') {
                li.querySelector('.ah-btn')?.remove();
                return;
            }
            if (li.querySelector('.ah-btn')) return;
            const wrap = li.querySelector('.descriptionWrapper___Lh0y0') || exp;
            wrap.style.position = 'relative';
            wrap.appendChild(makeBtn(() => {
                const d = parseLegacyItem(li);
                document.querySelectorAll('.ah-open-source').forEach(x => x.classList.remove('ah-open-source'));
                li.classList.add('ah-open-source');
                openModal(d.itemName, d.bonuses, d.quality, d.itemType, d.srcStats);
            }));
        });
    }

    function injectButtons() {
        injectCollapsedAuctionButtons();

        const pt = getPageType();
        if (pt === 'auction') {
            injectAuction();
        } else if (pt === 'itemmarket') {
            injectInto(document.querySelectorAll('.itemInfoWrapper___nA_eu,[class*="itemInfo___"]'));
        } else if (pt === 'inventory' || pt === 'displaycase') {
            injectInto(document.querySelectorAll('li.show-item-info'));
        } else if (pt === 'bazaar') {
            injectInto(document.querySelectorAll('div.show-item-info,[class*="info___"].show-item-info'));
        } else if (pt === 'trading') {
            injectInto(document.querySelectorAll(
                '.itemInfoWrapper___nA_eu,[class*="itemInfo___"],li.show-item-info,div.show-item-info,[class*="info___"].show-item-info'
            ), false);
        } else if (pt === 'armory') {
            injectInto(Array.from(document.querySelectorAll('div.view-item-info')).filter(e => e.style.display !== 'none'));
        }
    }

    // ─── Page scan / deal scanner ───────────────────────────────────────────────

    const pageScan = {
        running: false,
        stopped: false,
        queue: [],
        index: 0,
        goodDeals: [],
        delayMin: 4000,
        delayMax: 9000,
        panel: null,
    };

    function randInt(min, max) {
        return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function waitUntil(fn, timeout = 30000, step = 250) {
        const start = Date.now();
        while (Date.now() - start < timeout) {
            try {
                if (fn()) return true;
            } catch {}
            await sleep(step);
        }
        return false;
    }

    function getScanContainers() {
        return Array.from(document.querySelectorAll('.ah-btn'))
            .map(btn => btn.parentElement)
            .filter(Boolean);
    }

    function getContainerSignature(container) {
        const txt = (container.innerText || container.textContent || '')
            .trim()
            .replace(/\s+/g, ' ');
        return txt.slice(0, 300);
    }

    function removeScanBadge(container) {
        const old = container.querySelector('.ah-scan-badge');
        if (old) old.remove();
    }

    function setScanBadge(container, html, cls = '') {
        removeScanBadge(container);

        if (getComputedStyle(container).position === 'static') {
            container.style.position = 'relative';
        }

        const badge = document.createElement('div');
        badge.className = `ah-scan-badge ${cls}`.trim();
        badge.innerHTML = html;
        container.appendChild(badge);
    }

    function analysisClass(label) {
        if (['STEAL', 'GOOD', 'Hot', 'Popular', 'Meta', 'High'].includes(label)) return 'good';
        if (['FAIR', 'Average', 'Mid', 'Medium'].includes(label)) return 'mid';
        return 'bad';
    }

    function summarizeScanResult(analysis) {
        const fair = analysis?.fair?.fairValue;
        const current = analysis?.currentPrice;
        const deal = analysis?.deal?.label || 'Unknown';
        const pop = analysis?.popularity?.tier || 'Unknown';
        const bonus = analysis?.bonus?.tier || 'Unknown';

        return `
            <div class="ah-scan-line ah-${analysisClass(deal)}"><strong>${deal}</strong></div>
            <div class="ah-scan-mini">Fair: ${fair ? fmt$(fair) : '—'}</div>
            <div class="ah-scan-mini">Now: ${current ? fmt$(current) : '—'}</div>
            <div class="ah-scan-mini">Pop: ${pop} • Bonus: ${bonus}</div>
        `;
    }

    function updateScanPanel() {
        if (!pageScan.panel) return;

        const total = pageScan.queue.length;
        const done = pageScan.index;
        const found = pageScan.goodDeals.length;

        pageScan.panel.innerHTML = `
            <div class="ah-scan-panel-top">
                <strong>Page Scan</strong>
                <div class="ah-scan-panel-actions">
                    <button id="ah-stop-scan-btn" class="ah-scan-control">Stop</button>
                    <button id="ah-start-scan-btn" class="ah-scan-control">Start</button>
                </div>
            </div>
            <div class="ah-scan-panel-body">
                <div>Status: ${pageScan.running ? 'Running' : 'Idle'}</div>
                <div>Progress: ${done} / ${total}</div>
                <div>Good deals found: ${found}</div>
            </div>
        `;

        const stopBtn = document.getElementById('ah-stop-scan-btn');
        const startBtn = document.getElementById('ah-start-scan-btn');

        if (stopBtn) stopBtn.onclick = stopPageScan;
        if (startBtn) startBtn.onclick = startPageScan;
    }

    function ensureScanPanel() {
        if (pageScan.panel && document.body.contains(pageScan.panel)) return;

        const panel = document.createElement('div');
        panel.id = 'ah-scan-panel';
        panel.style.position = 'fixed';
        panel.style.right = '14px';
        panel.style.bottom = '14px';
        panel.style.zIndex = '100000';
        panel.style.padding = '10px 12px';
        panel.style.borderRadius = '10px';
        panel.style.background = 'rgba(15,15,15,0.92)';
        panel.style.border = '1px solid rgba(255,255,255,0.12)';
        panel.style.color = '#f5f5f5';
        panel.style.fontSize = '12px';
        panel.style.minWidth = '200px';
        panel.style.backdropFilter = 'blur(8px)';
        panel.style.boxShadow = '0 8px 30px rgba(0,0,0,0.35)';
        document.body.appendChild(panel);
        pageScan.panel = panel;

        updateScanPanel();
    }

    function stopPageScan() {
        pageScan.stopped = true;
        pageScan.running = false;
        updateScanPanel();
    }

    async function scanOneContainer(container) {
        const btn = container.querySelector('.ah-btn');
        if (!btn) return null;

        setScanBadge(
            container,
            `<div class="ah-scan-line ah-info"><strong>Checking…</strong></div>`,
            'working'
        );

        btn.click();

        const loaded = await waitUntil(() => !state.loading, 35000, 300);
        if (!loaded) {
            setScanBadge(
                container,
                `<div class="ah-scan-line ah-bad"><strong>Timed out</strong></div>`,
                'bad'
            );
            return null;
        }

        if (typeof doMarketSearch === 'function') {
            try {
                await doMarketSearch();
            } catch {}
        }

        const marketLoaded = await waitUntil(() => !state.mLoading, 35000, 300);
        if (!marketLoaded) {
            setScanBadge(
                container,
                `<div class="ah-scan-line ah-bad"><strong>Market timeout</strong></div>`,
                'bad'
            );
            return null;
        }

        if (typeof analyzeCurrentItem !== 'function') {
            setScanBadge(
                container,
                `<div class="ah-scan-line ah-bad"><strong>No analyzer</strong></div>`,
                'bad'
            );
            return null;
        }

        const analysis = analyzeCurrentItem();
        const dealLabel = analysis?.deal?.label || 'Unknown';
        const cls = analysisClass(dealLabel);

        setScanBadge(container, summarizeScanResult(analysis), cls);

        if (dealLabel === 'STEAL' || dealLabel === 'GOOD') {
            pageScan.goodDeals.push({
                container,
                analysis,
                text: getContainerSignature(container),
            });
        }

        return analysis;
    }

    async function startPageScan() {
        if (pageScan.running) return;

        ensureScanPanel();

        pageScan.running = true;
        pageScan.stopped = false;
        pageScan.goodDeals = [];
        pageScan.queue = getScanContainers();
        pageScan.index = 0;

        updateScanPanel();

        for (let i = 0; i < pageScan.queue.length; i++) {
            if (pageScan.stopped) break;

            const container = pageScan.queue[i];
            pageScan.index = i + 1;
            updateScanPanel();

            try {
                await scanOneContainer(container);
            } catch (err) {
                console.error('[AH scan]', err);
                setScanBadge(
                    container,
                    `<div class="ah-scan-line ah-bad"><strong>Error</strong></div><div class="ah-scan-mini">${String(err?.message || err)}</div>`,
                    'bad'
                );
            }

            if (pageScan.stopped) break;

            const delay = randInt(pageScan.delayMin, pageScan.delayMax);
            updateScanPanel();
            await sleep(delay);
        }

        pageScan.running = false;
        updateScanPanel();

        if (typeof closeModal === 'function') {
            closeModal();
        }

        console.log('[AH scan] finished', {
            scanned: pageScan.index,
            total: pageScan.queue.length,
            goodDeals: pageScan.goodDeals.length,
        });
    }

