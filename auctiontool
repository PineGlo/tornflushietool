                AppState.search.filters.itemName = item.itemName || '';
                AppState.search.filters.bonus1Id = item.effectTypes?.[0]?.id ? String(item.effectTypes[0].id) : '';
                AppState.search.filters.bonus2Id = item.effectTypes?.[1]?.id ? String(item.effectTypes[1].id) : '';
                AppState.search.filters.qualityMin = item.sourceStats?.quality != null ? String(item.sourceStats.quality) : '';
                AppState.search.filters.qualityMax = item.sourceStats?.quality != null ? String(item.sourceStats.quality) : '';
                this.renderActiveItem(AppState.activeItem);
            });

            document.getElementById('twx-search-clear')?.addEventListener('click', () => {
                AppState.search.filters = {
                    itemName: '',
                    bonus1Id: '',
                    bonus1Min: '',
                    bonus1Max: '',
                    bonus2Id: '',
                    bonus2Min: '',
                    bonus2Max: '',
                    qualityMin: '',
                    qualityMax: '',
                    itemCategory: 'weapon',
                    weaponClass: '',
                    armorSet: '',
                    armorPiece: '',
                    includeBazaar: true,
                    includeMarket: true,
                };
                AppState.search.rows = [];
                AppState.search.total = 0;
                AppState.search.error = null;
                this.renderActiveItem(AppState.activeItem);
            });
        },

        getRowSourceToken(row) {
            const raw = String(
                row?.listing_source ||
                row?.source ||
                row?.origin ||
                row?.market_source ||
                row?.listing_type ||
                row?.source_type ||
                row?.table_name ||
                ''
            ).toLowerCase();
            if (raw.includes('bazaar')) return 'bazaar';
            if (raw.includes('market') || raw.includes('itemmarket')) return 'market';
            return '';
        },

        formatSearchRowTimestamp(timestamp) {
            if (timestamp == null || timestamp === '') return '—';
            if (typeof timestamp === 'number') {
                const ms = timestamp > 10_000_000_000 ? timestamp : timestamp * 1000;
                return new Date(ms).toLocaleString();
            }
            const asNum = Number(timestamp);
            if (Number.isFinite(asNum)) {
                const ms = asNum > 10_000_000_000 ? asNum : asNum * 1000;
                return new Date(ms).toLocaleString();
            }
            const parsed = new Date(String(timestamp));
            if (Number.isNaN(parsed.getTime())) return '—';
            return parsed.toLocaleString();
        },

        getSearchRowSourceLabel(row, filters = null) {
            const src = this.getRowSourceToken(row);
            if (src === 'bazaar') return 'Bazaar';
            if (src === 'market') return 'Market';
            if (filters?.includeBazaar && !filters?.includeMarket) return 'Bazaar';
            if (!filters?.includeBazaar && filters?.includeMarket) return 'Market';
            return 'Historical listing';
        },

        getSearchRowBonusesLabel(row, filters = null) {
            const b1Id = row?.bonus1_id ?? row?.bonus_1_id ?? row?.b1_id ?? row?.bonus1;
            const b2Id = row?.bonus2_id ?? row?.bonus_2_id ?? row?.b2_id ?? row?.bonus2;
            const b1NameRaw = row?.bonus1_name ?? row?.bonus_1_name ?? row?.bonus1_title ?? null;
            const b2NameRaw = row?.bonus2_name ?? row?.bonus_2_name ?? row?.bonus2_title ?? null;
            const b1Name = b1NameRaw || (b1Id ? Stats.bonusName(Number(b1Id)) : (filters?.bonus1Id ? Stats.bonusName(Number(filters.bonus1Id)) : null));
            const b2Name = b2NameRaw || (b2Id ? Stats.bonusName(Number(b2Id)) : (filters?.bonus2Id ? Stats.bonusName(Number(filters.bonus2Id)) : null));
            const b1v = row?.bonus1_value ?? row?.bonus_1_value;
            const b2v = row?.bonus2_value ?? row?.bonus_2_value;
            const p1 = b1Name ? `${b1Name}${b1v != null ? ` ${b1v}%` : ''}` : null;
            const p2 = b2Name ? `${b2Name}${b2v != null ? ` ${b2v}%` : ''}` : null;
            return [p1, p2].filter(Boolean).join(' • ') || 'No bonuses';
        },

        getSearchRowLink(row, filters) {
            let source = this.getRowSourceToken(row);
            if (!source && filters?.includeBazaar && !filters?.includeMarket) source = 'bazaar';
            if (!source && !filters?.includeBazaar && filters?.includeMarket) source = 'market';
            if (source === 'bazaar') {
                const userIdRaw =
                    row?.seller_id ?? row?.sellerId ??
                    row?.user_id ?? row?.userId ??
                    row?.owner_id ?? row?.ownerId ??
                    row?.uid ?? row?.userid ?? row?.bazaar_user_id;
                const userId = Number(userIdRaw);
                if (!Number.isFinite(userId) || userId <= 0) return '';
                return `https://www.torn.com/bazaar.php?userId=${userId}`;
            }

            if (source === 'market') {
                const wc = String(filters?.weaponClass || '').toLowerCase();
                const categoryName = filters?.itemCategory === 'armor'
                    ? 'Armor'
                    : (wc === 'secondary' ? 'Secondary' : wc === 'melee' ? 'Melee' : 'Primary');
                const params = [
                    `categoryName=${categoryName}`,
                    'sortField=price',
                    'sortOrder=ASC',
                ];

                const bonus1Name = row?.bonus1_name ?? row?.bonus_1_name ?? null;
                const bonus1Id = row?.bonus1_id || row?.bonus_1_id || filters?.bonus1Id || Stats.bonusIdByName(bonus1Name);
                if (bonus1Id) params.push(`bonuses[0]=${Number(bonus1Id)}`);

                const damageTo = row?.stat_damage ?? filters?.damageMax;
                const accuracyTo = row?.stat_accuracy ?? filters?.accuracyMax;
                if (damageTo != null && damageTo !== '') params.push(`damageTo=${Math.round(Number(damageTo))}`);
                if (accuracyTo != null && accuracyTo !== '') params.push(`accuracyTo=${Math.round(Number(accuracyTo))}`);

                return `https://www.torn.com/page.php?sid=ItemMarket#/market/view=category&${params.join('&')}`;
            }

            return '';
        },

        filterSearchRowsBySource(rows, filters) {
            const includeBazaar = !!filters.includeBazaar;
            const includeMarket = !!filters.includeMarket;
            if (includeBazaar && includeMarket) return rows;
            if (!includeBazaar && !includeMarket) return [];
            return rows.filter((row) => {
                const src = this.getRowSourceToken(row);
                if (src === 'bazaar') return includeBazaar;
                if (src === 'market') return includeMarket;
                return includeBazaar || includeMarket;
            });
        },

