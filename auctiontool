        if (t.includes('extremely rare') || t.includes('very rare')) return 'red';
        if (t.includes('extraordinary') || /\brare\b/.test(t)) return 'orange';
        if (t.includes('uncommon') || t.includes('yellow') || t.includes('common')) return 'yellow';
        return null;
    }

    function bonusCountFromAriaLabel(aria) {
        const t = (aria || '').toLowerCase();
