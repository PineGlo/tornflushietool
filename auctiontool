                const pctWarn = Util.tryNumber(document.getElementById('twx-setting-pct-warn')?.value) ?? DEFAULT_SETTINGS.pctWarn;
                const pctBad = Util.tryNumber(document.getElementById('twx-setting-pct-bad')?.value) ?? DEFAULT_SETTINGS.pctBad;

