    // ─── Apply initial style vars ─────────────────────────────────────────────────

    applyStyle();

    // ─── Search logic ─────────────────────────────────────────────────────────────

    function buildSearchBody(f, offset, bPct, qPct) {
        const expand = (min, max, pct) => {
            const lo = (min !== '' && min != null) ? parseFloat(min) : null;
            const hi = (max !== '' && max != null) ? parseFloat(max) : null;
            if (lo == null && hi == null) return { min: null, max: null };
            if (pct === 0) return { min: lo, max: hi };
            const center = lo != null && hi != null ? (lo+hi)/2 : lo??hi;
            const half   = lo != null && hi != null ? (hi-lo)/2 : Math.abs(center)*(pct/100);
            const nh     = half + half*(pct/100);
            return { min: lo != null ? Math.max(0, Math.floor(center-nh)) : null,
                     max: hi != null ? Math.ceil(center+nh) : null };
        };
        const body = { limit: CFG.PAGE_SIZE, offset, sort_by: 'timestamp', sort_order: 'desc' };
        if (f.itemName) body.item_name = f.itemName;
        if (f.bonus1Id) { body.bonus1_id = +f.bonus1Id; const r = expand(f.bonus1Min, f.bonus1Max, bPct); if (r.min!=null) body.bonus1_value_min=r.min; if (r.max!=null) body.bonus1_value_max=r.max; }
        if (f.bonus2Id) { body.bonus2_id = +f.bonus2Id; const r = expand(f.bonus2Min, f.bonus2Max, bPct); if (r.min!=null) body.bonus2_value_min=r.min; if (r.max!=null) body.bonus2_value_max=r.max; }
        const qr = expand(f.qualityMin, f.qualityMax, qPct);
        if (qr.min != null) body.quality_min = qr.min;
        if (qr.max != null) body.quality_max = qr.max;
        return body;
    }

    async function doSearch() {
        state.loading = true; state.error = null; state.autoWidened = null;
        render();
        try {
            const f  = state.filters;
            const s  = settings.get();
            const hasRanges = f.bonus1Min||f.bonus1Max||f.bonus2Min||f.bonus2Max||f.qualityMin||f.qualityMax;
            const steps = (s.autoWiden && hasRanges) ? s.widenSteps : [[0,0]];
            const minR  = s.minResults || 1;
            let found = false;
            for (const [bPct, qPct] of steps) {
                const body = buildSearchBody(f, state.offset, bPct, qPct);
                const k    = JSON.stringify(body);
                let data   = cache.get(k);
                if (!data) { data = await supabase('search-auctions', body); cache.set(k, data); }
                const results = data.auctions || [];
                if (results.length >= minR || (state.offset > 0 && (data.total||0) > 0)) {
                    state.results   = results;
                    state.total     = data.total || 0;
                    state.autoWidened = (bPct>0||qPct>0) ? {bonusPct:bPct, qualityPct:qPct} : null;
                    found = true; break;
                }
            }
            if (!found) { state.results = []; state.total = 0; }
        } catch(e) { console.error('[AH]', e); state.error = e.message; state.results = []; state.total = 0; }
        state.loading = false; state.lastItem = state.filters.itemName;
        render();
    }

    function buildMarketParams() {
        const f = state.filters, ms = settings.get().market, p = new URLSearchParams();
        if (f.itemName) p.set(state.itemType==='armor' ? 'armorPiece' : 'weaponName', f.itemName);
        if (f.bonus1Id) { const n=bonusById[f.bonus1Id]; if(n) p.set('bonus1',n); if(!ms.disableBonusFilter){if(f.bonus1Min)p.set('minBonus1Value',f.bonus1Min);if(f.bonus1Max)p.set('maxBonus1Value',f.bonus1Max);} }
        if (f.bonus2Id) { const n=bonusById[f.bonus2Id]; if(n) p.set('bonus2',n); if(!ms.disableBonusFilter){if(f.bonus2Min)p.set('minBonus2Value',f.bonus2Min);if(f.bonus2Max)p.set('maxBonus2Value',f.bonus2Max);} }
        if (!ms.disableQualityFilter) { if(f.qualityMin)p.set('minQuality',f.qualityMin); if(f.qualityMax)p.set('maxQuality',f.qualityMax); }
        p.set('tab', state.itemType==='armor' ? 'armor' : 'weapons'); p.set('sortField','price'); p.set('sortDirection','asc');
        return p;
    }

    async function doMarketSearch() {
        state.mLoading = true; state.mError = null; render();
        try { const d = await weav3rGet(buildMarketParams()); state.mResults = d.weapons||[]; state.mTotal = d.total_count||0; }
        catch(e) { state.mError = e.message; state.mResults = []; state.mTotal = 0; }
        state.mLoading = false; state.mLastItem = state.filters.itemName; render();
    }

