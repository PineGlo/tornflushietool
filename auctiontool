    const Util = {
        qs(sel, root = document) {
            return root.querySelector(sel);
        },

        qsa(sel, root = document) {
            return Array.from(root.querySelectorAll(sel));
        },

        text(el) {
            return (el?.textContent || '').replace(/\s+/g, ' ').trim();
        },

        lower(v) {
            return String(v || '').trim().toLowerCase();
        },

        slug(v) {
            return Util.lower(v).replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
        },

        sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        },

        safeJsonParse(raw, fallback) {
            try { return JSON.parse(raw); } catch { return fallback; }
        },

        money(v) {
            if (!Number.isFinite(v)) return '—';
            if (v >= 1e9) return `$${(v / 1e9).toFixed(2)}B`;
            if (v >= 1e6) return `$${(v / 1e6).toFixed(2)}M`;
            if (v >= 1e3) return `$${(v / 1e3).toFixed(1)}K`;
            return `$${Math.round(v).toLocaleString()}`;
        },

        parseMoney(text) {
            const m = String(text || '').match(/\$?\s*([\d,.]+)\s*([kmb])?/i);
            if (!m) return null;
            let n = parseFloat(m[1].replace(/,/g, ''));
            if (!Number.isFinite(n)) return null;
            const u = (m[2] || '').toLowerCase();
            if (u === 'k') n *= 1e3;
            else if (u === 'm') n *= 1e6;
            else if (u === 'b') n *= 1e9;
            return Math.round(n);
        },

        tryNumber(text) {
            const n = parseFloat(String(text ?? '').replace(/[^\d.-]/g, ''));
            return Number.isFinite(n) ? n : null;
        },

        parsePercent(text) {
            const m = String(text || '').match(/(-?\d+(?:\.\d+)?)\s*%/);
            if (m) return parseFloat(m[1]);
            return Util.tryNumber(text);
        },

        escapeHtml(str) {
            return String(str ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        },

        uniqueBy(arr, keyFn) {
            const seen = new Set();
            const out = [];
            for (const item of arr) {
                const key = keyFn(item);
                if (seen.has(key)) continue;
                seen.add(key);
                out.push(item);
            }
            return out;
        },

        normalizeWhitespace(v) {
            return String(v || '').replace(/\s+/g, ' ').trim();
        },

        pageIsAuction() {
            return /amarket\.php/i.test(location.href);
