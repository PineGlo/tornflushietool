    /**********************************************************************
     * DECORATORS
     **********************************************************************/
    const ItemDecorators = {
        ensureHost(item) {
            const host =
                item.imageElement?.closest('.img-wrap') ||
                item.imageElement?.parentElement ||
                item.sourceElement ||
                item.containerElement;

            if (!host) return null;
            host.classList.add('twx-overlay-host');
            const pos = getComputedStyle(host).position;
            if (pos === 'static') host.style.position = 'relative';
            return host;
        },

ensurePill(item, index) {
    const titleHost =
        item.containerElement.querySelector('.title') ||
        item.containerElement.querySelector('.item-name')?.parentElement ||
        this.ensureHost(item);

    if (!titleHost || !SettingsStore.get().autoInjectPill) return;

    titleHost.classList.add('twx-title-host');

    let pill = titleHost.querySelector('.twx-pill');
    if (!pill) {
        pill = document.createElement('div');
        pill.className = 'twx-pill';
        titleHost.prepend(pill);
    }

    const bbLabel = item.bbValue != null ? `BB ${item.bbValue}` : 'BB ?';
    const pctLabel = Deal.getPercentLabel(item);
    const rarityColor = BB.rarityColor(item.rarity);
    const pctColor = Deal.getPercentColor(item);

    pill.innerHTML = `
        <span class="twx-bb">${Util.escapeHtml(bbLabel)}</span>
        <span class="twx-sep">|</span>
        <span class="twx-pct">${Util.escapeHtml(pctLabel)}</span>
    `;

    pill.style.boxShadow = `0 0 10px ${rarityColor}44`;

    const bbEl = pill.querySelector('.twx-bb');
    const pctEl = pill.querySelector('.twx-pct');

    if (bbEl) bbEl.style.color = rarityColor;
    if (pctEl) pctEl.style.color = pctColor;

    pill.onclick = async (e) => {
        e.preventDefault();
        e.stopPropagation();
        await Actions.selectAndPriceItem(index);
    };
},

        ensureHistorySummary(item) {
            const existingAnywhere = item.containerElement.querySelectorAll('.twx-history-summary');
            if (!item.historySummary) {
                existingAnywhere.forEach(el => el.remove());
                return;
            }

            const host =
                ((item.containerElement.querySelector('.show-item-info')) &&
                 getComputedStyle(item.containerElement.querySelector('.show-item-info')).display !== 'none')
                    ? item.containerElement.querySelector('.show-item-info')
                    : item.containerElement.querySelector('.item-cont-wrap') ||
                      item.containerElement;

            if (!host) return;

            let box = host.querySelector('.twx-history-summary');
            if (!box) {
                box = document.createElement('div');
                box.className = 'twx-history-summary';
                host.appendChild(box);
            }

            const summary = item.historySummary;
            box.innerHTML = `
                <div class="twx-history-title">History</div>
                <div class="twx-history-line"><span class="k">Last</span><span class="v">${Util.money(summary.lastSold)}</span></div>
                <div class="twx-history-line"><span class="k">Median</span><span class="v">${Util.money(summary.median)}</span></div>
                <div class="twx-history-line"><span class="k">Range</span><span class="v">${Util.money(summary.low)} – ${Util.money(summary.high)}</span></div>
                <div class="twx-history-line"><span class="k">Comps</span><span class="v">${summary.count ?? 0}</span></div>
            `;
        },

        refresh(items) {
            items.forEach((item, index) => {
                this.ensurePill(item, index);
                this.ensureHistorySummary(item);
            });
        },
    };

