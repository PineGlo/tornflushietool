    function fmtDate(ts) {
        const d = Math.floor((Date.now() - ts*1000) / 86400000);
        return d === 0 ? 'Today' : d === 1 ? 'Yesterday' : d < 7 ? d+'d ago' : new Date(ts*1000).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    }

    function rarityBadge(rarity) {
        if (!rarity) return '';
        const r = rarity.toLowerCase();
        const cls = r.includes('red') ? 'r-red' : r.includes('orange') ? 'r-orange' : r.includes('yellow') ? 'r-yellow' : '';
        return cls ? `<span class="ah-rarity ${cls}">${rarity.toUpperCase()}</span>` : '';
    }

    const normalizeItemName = name => (name || '').toLowerCase().replace(/^the\s+/i, '').replace(/\s+/g, ' ').trim();

    function getRarityKey(el) {
        const rarity = el.querySelector('[class*="rarity___"]');
        const text = ((rarity?.className || '') + ' ' + (rarity?.textContent || '')).toLowerCase();
        if (text.includes('red')) return 'red';
        if (text.includes('orange')) return 'orange';
        if (text.includes('yellow')) return 'yellow';
        if (el.querySelector('[class*="extremely-rare"]')) return 'red';
        if (el.querySelector('[class*="extraordinary"]')) return 'orange';
        return null;
    }

    function calcBunkerBucks(itemName, rarityKey, bonusCount, itemType = 'weapon') {
        const category = itemType === 'armor' ? 'Armor' : WEAPON_TYPE_BY_NAME[normalizeItemName(itemName)];
        if (!category) return null;
        const row = BB_VALUE_TABLE[category];
        if (!row) return null;
        if (!rarityKey) return null;
        if (rarityKey === 'yellow') return row.yellow;
        if (rarityKey === 'orange') return bonusCount >= 2 && row.orangeTwo != null ? row.orangeTwo : row.orange;
        if (rarityKey === 'red') return bonusCount >= 2 && row.redTwo != null ? row.redTwo : row.red;
        return null;
    }

    function bbDisplayText(bbAmount) {
        const bbCashValue = Number(settings.get().bbCashValue) || 0;
        const bbProfitMargin = Math.max(0, Math.min(100, Number(settings.get().bbProfitMargin) || 0));
        if (bbCashValue > 0) {
            const netCash = Math.round(bbAmount * bbCashValue * (1 - (bbProfitMargin / 100)));
            return {
                text: `${bbAmount} BB • ${fmt$(netCash)}`,
                title: `BB base: ${fmt$(bbCashValue)} each • margin: ${bbProfitMargin}%`,
            };
        }
        return { text: `${bbAmount} BB`, title: '' };
    }

