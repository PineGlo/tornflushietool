    function escapeHtml(str) {
        return String(str ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function weaponFamilyWeight(name) {
        let best = 0;
        for (const [rx, weight] of ITEM_FAMILY_WEIGHTS) {
            if (rx.test(name || '')) best = Math.max(best, weight);
        }
        return best;
    }

    function getBonusScoreByName(name) {
        return BONUS_SCORE_MAP[name] ?? 50;
    }

    function scoreBonusesFromSource(src) {
        const bonuses = src?.bonuses || [];
        if (!bonuses.length) {
            return { tier: 'None', score: 0, names: [] };
        }

        const scored = bonuses.map(b => {
            const name = bonusName(b.id);
            return {
                id: b.id,
                name,
                value: b.value ?? null,
                score: getBonusScoreByName(name),
            };
        });

        const avg = scored.reduce((sum, x) => sum + x.score, 0) / scored.length;

        let tier = 'Low';
        if (avg >= 88) tier = 'Meta';
        else if (avg >= 76) tier = 'High';
        else if (avg >= 62) tier = 'Mid';

        return {
            tier,
            score: Math.round(avg),
            names: scored.map(x => x.value != null ? `${x.name} ${x.value}%` : x.name),
            details: scored,
        };
    }

    function extractComparableBonuses(rows) {
        const names = [];
        for (const row of rows || []) {
            if (row?.bonus_values?.length) {
                for (const bv of row.bonus_values) {
                    names.push(bonusName(bv.bonus_id));
                }
            } else if (row?.bonus_ids?.length) {
                for (const id of row.bonus_ids) {
                    names.push(bonusName(id));
                }
            } else if (row?.bonuses && typeof row.bonuses === 'object') {
                for (const b of Object.values(row.bonuses)) {
                    if (b?.bonus) names.push(b.bonus);
                }
            }
        }
        return names;
    }

    function computeMarketFloor(marketRows) {
        const prices = (marketRows || [])
            .map(x => Number(x?.price))
            .filter(x => Number.isFinite(x) && x > 0)
            .sort((a, b) => a - b);

        return prices.length ? prices[0] : null;
    }

    function computeFairValue(histSuggestion, marketRows) {
        const hist = histSuggestion?.suggested ?? null;
        const floor = computeMarketFloor(marketRows);

        if (hist && floor) {
            // Conservative blend for flip decisions:
            // don't overestimate above current live market floor
            const blended = Math.round((hist * 0.65) + (floor * 0.35));
            return {
                fairValue: Math.min(blended, Math.round(floor * 1.03)),
                hist,
                floor,
            };
        }
        if (hist) return { fairValue: hist, hist, floor: null };
        if (floor) return { fairValue: floor, hist: null, floor };
        return { fairValue: null, hist: null, floor: null };
    }

function parseCurrentListingPrice() {
    const source = document.querySelector('.ah-open-source');
    if (!source) return null;

    const scopes = [
        source,
        source.closest('li'),
        source.closest('tr'),
        source.closest('[class*="row"]'),
        source.closest('[class*="item"]'),
        source.parentElement,
        source.parentElement?.parentElement,
    ].filter(Boolean);

    const candidates = [
        '[class*="currentBid"]',
        '[class*="current-bid"]',
        '[class*="bid"]',
        '[class*="price"]',
        '[aria-label*="current bid" i]',
        '[aria-label*="bid" i]',
        '[aria-label*="price" i]',
        '.price',
        '.bid',
    ];

    const found = [];

    for (const scope of scopes) {
        for (const sel of candidates) {
            scope.querySelectorAll(sel).forEach(el => {
                const txt = (el.textContent || '').trim();
                if (!txt) return;
                if (!/\$[\d,.]+(?:\s*[kmb])?/i.test(txt)) return;

                const parsed = parseMoneyText(txt);
                if (Number.isFinite(parsed) && parsed > 0) {
                    found.push({
                        value: parsed,
                        text: txt,
                        bidish: /bid/i.test(txt) ? 2 : /price/i.test(txt) ? 1 : 0,
                    });
                }
            });
        }
    }

    if (!found.length) return null;

    found.sort((a, b) => {
        if (a.biddish !== b.biddish) return b.biddish - a.biddish;
        return b.value - a.value;
    });

    return found[0].value;
}

    function parseMoneyText(text) {
        const m = String(text || '').match(/\$?\s*([\d,.]+)\s*([kmb])?/i);
        if (!m) return null;
        let n = parseFloat(m[1].replace(/,/g, ''));
        if (!Number.isFinite(n)) return null;
        const unit = (m[2] || '').toLowerCase();
        if (unit === 'k') n *= 1e3;
        else if (unit === 'm') n *= 1e6;
        else if (unit === 'b') n *= 1e9;
        return Math.round(n);
    }

    function rateDeal(currentPrice, fairValue) {
        if (!Number.isFinite(currentPrice) || !Number.isFinite(fairValue) || fairValue <= 0) {
            return { label: 'Unknown', score: 0, ratio: null };
        }

        const ratio = currentPrice / fairValue;

        if (ratio <= 0.80) return { label: 'STEAL', score: 95, ratio };
        if (ratio <= 0.92) return { label: 'GOOD', score: 82, ratio };
        if (ratio <= 1.08) return { label: 'FAIR', score: 60, ratio };
        if (ratio <= 1.20) return { label: 'HIGH', score: 35, ratio };
        return { label: 'OVERPRICED', score: 15, ratio };
    }

    function computeDemandSignals(itemName, histRows, marketRows, bonusScore) {
        const now = Date.now() / 1000;
        const recentSales = (histRows || []).filter(x => {
            const ts = Number(x?.timestamp);
            if (!Number.isFinite(ts)) return false;
            return ((now - ts) / 86400) <= 30;
        }).length;

        const salesDepth = (histRows || []).length;
        const marketDepth = (marketRows || []).length;
        const familyWeight = weaponFamilyWeight(itemName);

        let score = 0;
        score += familyWeight;
        score += Math.min(recentSales * 5, 30);
        score += Math.min(salesDepth * 1.5, 20);

        if (marketDepth <= 3) score += 15;
        else if (marketDepth <= 8) score += 8;
        else if (marketDepth >= 20) score -= 10;

        score += Math.min((bonusScore?.score || 0) * 0.28, 25);
        score = clamp(Math.round(score), 0, 100);

        let tier = 'Slow';
        if (score >= 75) tier = 'Hot';
        else if (score >= 55) tier = 'Popular';
        else if (score >= 35) tier = 'Average';

        return {
            tier,
            score,
            recentSales,
            salesDepth,
            marketDepth,
            familyWeight,
        };
    }

    function computeConfidence(histRows, marketRows, autoWidened) {
        let score = 0;
        const h = (histRows || []).length;
        const m = (marketRows || []).length;

        score += Math.min(h * 8, 50);
        score += Math.min(m * 4, 20);
        if (!autoWidened) score += 20;
        else {
            const penalty = (autoWidened.bonusPct || 0) + (autoWidened.qualityPct || 0);
            score -= Math.min(Math.round(penalty / 15), 20);
        }

        score = clamp(score, 0, 100);

        let tier = 'Low';
        if (score >= 65) tier = 'High';
        else if (score >= 40) tier = 'Medium';

        return { tier, score };
    }

    function analyzeCurrentItem() {
        const src = state.sourceStats || {};
        const histRows = state.results || [];
        const marketRows = state.mResults || [];

        const currentPrice = parseCurrentListingPrice();
        const histSuggestion = computeSuggestion(histRows);
        const fair = computeFairValue(histSuggestion, marketRows);
        const bonus = scoreBonusesFromSource(src);
        const pop = computeDemandSignals(state.filters.itemName, histRows, marketRows, bonus);
        const deal = rateDeal(currentPrice, fair.fairValue);
        const confidence = computeConfidence(histRows, marketRows, state.autoWidened);

        return {
            currentPrice,
            histSuggestion,
            fair,
            bonus,
            popularity: pop,
            confidence,
            deal,
            comparableBonuses: extractComparableBonuses(histRows).slice(0, 8),
        };
    }

    function analysisBadgeClass(label) {
        if (label === 'STEAL' || label === 'GOOD' || label === 'Hot' || label === 'Popular' || label === 'Meta' || label === 'High') {
            return 'good';
