        wire('s-mbonus',     e => settings.setMarket({ disableBonusFilter:   e.target.checked }));
        wire('s-mqual',      e => settings.setMarket({ disableQualityFilter: e.target.checked }));
        wire('s-bbvalue',    e => { settings.set({ bbCashValue: Math.max(0, parseInt(e.target.value) || 0) }); injectButtons(); });
        wire('s-bbmargin',   e => { settings.set({ bbProfitMargin: Math.min(100, Math.max(0, parseInt(e.target.value) || 0)) }); injectButtons(); });

        modal.querySelectorAll('.ah-ovr-item').forEach(el => {
            const id = +el.dataset.id;
