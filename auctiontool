        async searchWeav3rLive(filters) {
            const payload = this.buildWeav3rQuery(filters);

            if (window.TornCore?.request) {
                const result = await window.TornCore.request('weav3r.ranked.search', payload);
                if (!result?.ok) throw new Error(result?.error || 'Weav3r API failed via Torn Core');
                return {
                    rows: this.normalizeWeav3rRows(result?.rows || result?.data?.rows || []),
                    total: Number(result?.total || result?.data?.total || 0),
                };
            }

            const params = new URLSearchParams();
            Object.entries(payload).forEach(([key, value]) => {
                if (value === null || value === undefined || value === '') return;
                params.set(key, String(value));
            });
            const data = await Transport.request('GET', `https://weav3r.dev/api/ranked-weapons?${params.toString()}`);
            return {
                rows: this.normalizeWeav3rRows(data?.weapons || []),
                total: Number(data?.total_count || 0),
            };
        },

