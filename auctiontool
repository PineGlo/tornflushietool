                    <div class="grp"><span class="lbl">Bonus ±</span><input type="number" class="btol" value="${o.bonusTolerance??s.bonusTolerance}" min="0" max="100"><span class="lbl">%</span></div>
                    <div class="grp"><span class="lbl">Quality ±</span><input type="number" class="qtol" value="${o.ignoreQuality?'':(o.qualityTolerance??s.qualityTolerance)}" min="0" max="100" ${o.ignoreQuality?'disabled':''}><span class="lbl">%</span></div>
