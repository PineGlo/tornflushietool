    function httpRequest(method, url, headers, body) {
        return new Promise((resolve, reject) => {
            let done = false;
            const ok  = v => { if (!done) { done = true; resolve(v); } };
            const err = v => { if (!done) { done = true; reject(v);  } };
            const fallback = () =>
                fetch(url, { method, headers, body: body ? JSON.stringify(body) : undefined })
                    .then(r => r.json().then(d => r.ok ? ok(d) : err(new Error(d.error || d.message || `HTTP ${r.status}`))))
                    .catch(() => err(new Error('Network error')));
            try {
                GM_xmlhttpRequest({
                    method, url, headers, data: body ? JSON.stringify(body) : undefined, timeout: 15000,
                    onload(r) {
                        if (done) return;
                        try { const d = JSON.parse(r.responseText); r.status < 300 ? ok(d) : err(new Error(d.error || d.message || `HTTP ${r.status}`)); }
                        catch { err(new Error(r.status === 429 ? 'Rate limited' : `Error ${r.status}`)); }
                    },
                    onerror() { if (!done) { done = true; fallback(); } },
                    ontimeout() { err(new Error('Request timed out')); },
                });
            } catch { fallback(); }
        });
    }

