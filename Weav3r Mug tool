  function renderAttackMonitor() {
    const ui = state.attackMonitor.ui;
    const userId = state.attackMonitor.targetUserId;
    if (!ui || !userId) return;

    const coreUser = state.coreClient?.getUser?.(userId) || null;
    const torn = coreUser?.torn || null;
    let status = String(torn?.status || "").trim();
    let isHospital = status === "Hospital";
    let timerText = getAttackHospitalTimerText(userId);

    if (!status) {
      const domState = readAttackHospitalFromDom();
      if (domState) {
        isHospital = !!domState.isHospital;
        status = isHospital ? "Hospital" : "Unknown";
        if (isHospital && domState.etaText) {
          const etaMs = parseEtaTextToMs(domState.etaText);
          timerText = etaMs != null ? formatCountdownMs(etaMs) : domState.etaText;
        }
      }
    }

    if (!status) {
      ui.box.classList.remove("released");
      ui.status.textContent = `Target ${userId}: waiting for status...`;
      ui.sub.textContent = "Waiting for attack-page DOM status.";
      return;
    }

    if (isHospital) {
      ui.box.classList.remove("released");
      ui.status.textContent = `Target ${userId}: Hosp ${timerText}`;
      ui.sub.textContent = "Alarm watches release and landing (Okay); auto-start triggers on Okay.";
      state.attackMonitor.autoAttackStarted = false;
      state.attackMonitor.previousStatus = "Hospital";
    } else if (status === "Okay") {
      ui.box.classList.add("released");
      ui.status.textContent = `Target ${userId}: Okay`;
      ui.sub.textContent = state.cfg.attackAutoStartEnabled
        ? "Target landed (Okay). Auto-start is enabled."
        : "Target landed (Okay). Enable auto-start to click attack automatically.";
    } else {
      ui.box.classList.add("released");
      ui.status.textContent = `Target ${userId}: ${status}`;
      ui.sub.textContent = "Target appears to be out of hospital.";
    }

    handleAttackReleaseTransition(userId, status, isHospital);
  }

  function startAttackMonitorLoop() {
    const userId = parseAttackTargetUserIdFromHref(location.href);
    if (!Number.isFinite(userId)) return;
    state.attackMonitor.targetUserId = userId;
    buildAttackMonitorUi();
    setupCoreSubscription();

    processAttackMonitorTick().catch((err) => log("Initial attack monitor tick failed", err));
    state.attackMonitor.loopTimer = setInterval(() => {
      processAttackMonitorTick().catch((err) => log("Attack monitor tick failed", err));
    }, 3000);
  }

  async function processAttackMonitorTick() {
    const userId = state.attackMonitor.targetUserId;
    if (!Number.isFinite(userId)) return;
    state.coreClient = createCoreClient();
    state.coreMode = state.coreClient.mode;
    renderAttackMonitor();
  }

  function renderSeller(userId) {
    const seller = state.sellers.get(userId);
    if (!seller || !seller.anchor?.isConnected) return;

    ensureSellerUi(seller);

    const truth = mapCoreUserToSellerTruth(userId);
    const statusText = truth.status || "…";
    const bs = truth.estimatedStats;
    const okay = statusText === "Okay";
    const underCap = isUnderThreshold(truth);
    const good = okay && underCap;
    const evaluable = !!truth.status && Number.isFinite(bs);
    const bad = evaluable && !good;
    const bsText = truth.estimatedStatsHuman || (Number.isFinite(bs) ? humanizeNumber(bs) : "?");
    const protectedInfo = truth.protectedInfo;
    const hospitalCountdown = statusText === "Hospital" ? getHospitalCountdownText(userId) : "";
    const hideOutOfRange = !!state.cfg.hideOutOfRangeTargets && Number.isFinite(bs) && !underCap;

    if (seller.badgeEl) {
      seller.badgeEl.className = "wmh-badge neutral";

      if (truth.isProtected && state.cfg.highlightProtectedBlue) {
        const factionName = protectedInfo?.factionName || protectedInfo?.name || "Alliance";
        seller.badgeEl.textContent = `Protected | ${factionName}`;
        seller.badgeEl.classList.add("protected");
      } else {
        let badgeLeft = truth.status || "Unknown";

        if (statusText === "Hospital" && hospitalCountdown) {
          badgeLeft = hospitalCountdown;
        }

        seller.badgeEl.textContent = `${badgeLeft} | ${bsText}`;

        if (good) {
          seller.badgeEl.classList.add("ok");
        } else if (bad) {
          seller.badgeEl.classList.add("bad");
        } else {
          seller.badgeEl.classList.add("neutral");
        }
      }
    }

    if (seller.row) {
      seller.row.classList.toggle("wmh-row-good", !truth.isProtected && good);
      seller.row.classList.toggle("wmh-row-bad", !truth.isProtected && bad);
      seller.row.classList.toggle("wmh-row-protected", !!(truth.isProtected && state.cfg.highlightProtectedBlue));
      seller.row.classList.toggle("wmh-row-hidden", hideOutOfRange);
    }
  }

  function updateStatusLine() {
    const line = document.getElementById("wmh-statusline");
    if (!line) return;

    line.textContent =
      `Visible: ${state.lastPlan.visible} | Protected: ${state.lastPlan.protected} | FF queue: ${state.lastPlan.needFF} | Eligible: ${state.lastPlan.eligible} | Torn queue: ${state.lastPlan.needTorn} | Backend: ${state.coreMode} | Threshold: ${state.cfg.statThresholdText}`;
  }

  function createCoreClient() {
    if (state.cfg.useCoreBackend && window.TornCore?.request) {
      return {
        mode: "direct",
        getUser: (userId) => window.TornCore.getUser?.(userId) || null,
        subscribe: (cb) => window.TornCore.subscribe ? window.TornCore.subscribe(cb) : (() => {}),
        requestUsersFFRefresh: (userIds) => window.TornCore.request("user.refresh.ff.batch", { userIds }),
        requestUsersTornRefresh: (userIds, opts = {}) => window.TornCore.request("user.refresh.torn.batch", { userIds, ...opts }),
        requestFactionHospitalRefresh: (force = false) => window.TornCore.request("faction.hospital.refresh", { force }),
      };
    }

    if (state.domBridgeSnapshot?.users?.byId) {
      return {
        mode: "bridge_dom",
        getUser: (userId) => state.domBridgeSnapshot?.users?.byId?.[String(userId)] || null,
        subscribe: () => (() => {}),
        requestUsersFFRefresh: (userIds) => requestDomBridge("user.refresh.ff.batch", { userIds }),
        requestUsersTornRefresh: (userIds, opts = {}) => requestDomBridge("user.refresh.torn.batch", { userIds, ...opts }),
        requestFactionHospitalRefresh: (force = false) => requestDomBridge("faction.hospital.refresh", { force }),
      };
    }

    const bridgeSnapshotKey = "torn_core_v2_bridge_snapshot";
    const bridgeRequestKey = "torn_core_v2_bridge_requests";
    const bridgeResponseKey = "torn_core_v2_bridge_responses";

    const readSnapshot = () => GM_getValue(bridgeSnapshotKey, null);
    if (readSnapshot()?.users?.byId) {
      return {
        mode: "bridge",
        getUser: (userId) => {
          const snapshot = readSnapshot();
          return snapshot?.users?.byId?.[String(userId)] || null;
        },
        subscribe: (cb) => {
          let lastTs = state.bridgeSnapshotTs;
          const timer = setInterval(() => {
            const snapshot = readSnapshot();
            const ts = Number(snapshot?.ts || 0);
            if (ts && ts !== lastTs) {
              lastTs = ts;
              state.bridgeSnapshotTs = ts;
              cb(snapshot);
            }
          }, 2000);
          return () => clearInterval(timer);
        },
        requestUsersFFRefresh: (userIds) => requestBridgeBroker(bridgeRequestKey, bridgeResponseKey, "user.refresh.ff.batch", { userIds }),
        requestUsersTornRefresh: (userIds, opts = {}) => requestBridgeBroker(bridgeRequestKey, bridgeResponseKey, "user.refresh.torn.batch", { userIds, ...opts }),
        requestFactionHospitalRefresh: (force = false) => requestBridgeBroker(bridgeRequestKey, bridgeResponseKey, "faction.hospital.refresh", { force }),
      };
    }

    return {
      mode: "offline",
      getUser: () => null,
      subscribe: () => (() => {}),
      requestUsersFFRefresh: async () => ({ ok: false, error: "No Torn Core client available." }),
      requestUsersTornRefresh: async () => ({ ok: false, error: "No Torn Core client available." }),
      requestFactionHospitalRefresh: async () => ({ ok: false, error: "No Torn Core client available." }),
    };
  }

  function requestBridgeBroker(requestKey, responseKey, type, payload) {
    const requestId = `wmh_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
    const queue = GM_getValue(requestKey, []);
    queue.push({ id: requestId, type, payload, createdAt: now(), requester: "weav3r_mug_tool" });
    GM_setValue(requestKey, queue.slice(-100));

    return new Promise((resolve) => {
      const started = now();
      const timer = setInterval(() => {
        const responses = GM_getValue(responseKey, []);
        const hit = responses.find((item) => item?.requestId === requestId);
        if (hit) {
          clearInterval(timer);
          resolve(hit.result || { ok: false, error: "Empty bridge response." });
          return;
        }
        if ((now() - started) > 9000) {
          clearInterval(timer);
          resolve({ ok: false, timeout: true, error: "Bridge request timeout." });
        }
      }, 300);
    });
  }

  function requestDomBridge(type, payload = {}) {
    const id = `wmh_dom_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
    return new Promise((resolve) => {
      let settled = false;
      const onResponse = (event) => {
        const detail = event?.detail || {};
        if (detail.id !== id) return;
        settled = true;
        window.removeEventListener("torn-core-bridge-response", onResponse);
        resolve(detail.result || { ok: false, error: "Empty DOM bridge response." });
      };
      window.addEventListener("torn-core-bridge-response", onResponse);
      window.dispatchEvent(new CustomEvent("torn-core-bridge-request", {
        detail: { id, type, payload },
      }));
      setTimeout(() => {
        if (settled) return;
        window.removeEventListener("torn-core-bridge-response", onResponse);
        resolve({ ok: false, timeout: true, error: "DOM bridge timeout." });
      }, 2500);
    });
  }

  function collectRefreshPlan() {
    const sellerIds = Array.from(state.sellers.keys());
    const needFF = [];
    const eligible = [];
    const needTorn = [];
    let protectedCount = 0;

    for (const userId of sellerIds) {
      const truth = mapCoreUserToSellerTruth(userId);

      if (truth.isProtected) {
        protectedCount++;
        if (state.cfg.skipProtectedTargets) continue;
      }

      if (!truth.ffFresh) {
        needFF.push(userId);
        continue;
      }

      if (isUnderThreshold(truth)) {
        eligible.push(userId);
        if (!truth.tornFresh) needTorn.push(userId);
      }
    }

    return {
      visible: sellerIds.length,
      protected: protectedCount,
      needFF,
      eligible,
      needTorn,
    };
  }

  async function processQueues() {
    if (!state.cfg.enabled) return;

    state.coreClient = createCoreClient();
    state.coreMode = state.coreClient.mode;

    const factionBatchDue = (now() - Number(state.lastFactionHospitalRequestAt || 0)) > 20000;
    if (factionBatchDue) {
      state.lastFactionHospitalRequestAt = now();
      state.coreClient.requestFactionHospitalRefresh(false).catch((err) => log("Faction hospital refresh failed", err));
    }

    scanPage();

    const batchSize = Math.max(1, Number(state.cfg.batchSize) || 15);

    let plan = collectRefreshPlan();
    state.lastPlan = {
      visible: plan.visible,
      protected: plan.protected,
      needFF: plan.needFF.length,
      eligible: plan.eligible.length,
      needTorn: plan.needTorn.length,
    };
    updateStatusLine();

    if (plan.needFF.length) {
      try {
        await state.coreClient.requestUsersFFRefresh(plan.needFF.slice(0, batchSize));
      } catch (err) {
        log("FF refresh failed", err);
      }

      for (const userId of state.sellers.keys()) renderSeller(userId);

      plan = collectRefreshPlan();
      state.lastPlan = {
        visible: plan.visible,
        protected: plan.protected,
        needFF: plan.needFF.length,
        eligible: plan.eligible.length,
        needTorn: plan.needTorn.length,
      };
      updateStatusLine();
    }

    if (plan.needTorn.length) {
      try {
        await state.coreClient.requestUsersTornRefresh(plan.needTorn.slice(0, batchSize));
      } catch (err) {
        log("Torn refresh failed", err);
      }
    }

    for (const userId of state.sellers.keys()) renderSeller(userId);

    plan = collectRefreshPlan();
    state.lastPlan = {
      visible: plan.visible,
      protected: plan.protected,
      needFF: plan.needFF.length,
      eligible: plan.eligible.length,
      needTorn: plan.needTorn.length,
    };
    updateStatusLine();
  }

  function startLoop() {
    stopLoop();

    state.tickTimer = setInterval(() => {
      processQueues().catch((err) => log("Queue loop error", err));
    }, Math.max(1000, Number(state.cfg.tickMs) || 8000));

    state.scanTimer = setInterval(() => {
      for (const userId of state.sellers.keys()) {
        const truth = mapCoreUserToSellerTruth(userId);
        if (truth.status === "Hospital") {
          renderSeller(userId);
        }
      }
    }, 15000);

    processQueues().catch((err) => log("Initial queue error", err));
  }

  function stopLoop() {
    if (state.tickTimer) clearInterval(state.tickTimer);
    if (state.scanTimer) clearInterval(state.scanTimer);
    state.tickTimer = null;
    state.scanTimer = null;
  }

