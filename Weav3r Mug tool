(function () {
  "use strict";

  const STORAGE_KEY = "weav3r_mugging_helper_v1";
  const DEFAULTS = {
    enabled: true,
    useCoreBackend: true,
    enableBazaarTracking: true,
    bazaarScanMs: 1000,
    bazaarAutoRefresh: true,
    bazaarRefreshMs: 45000,
    bazaarRefreshJitterPct: 20,
    soldAlertUnits: 250,
    rapidJumpUnits: 40,
    statThresholdText: "500m",
    batchSize: 15,
    tickMs: 6000,
    debug: false,
  };

  const CORE_STALE = {
    tornMs: 60 * 1000,
    ffMs: 60 * 60 * 1000,
  };

  const state = {
    cfg: loadConfig(),
    sellers: new Map(),      // userId -> seller object
    coreClient: null,
    coreMode: "offline", // direct | bridge | offline
    bridgeSnapshotTs: 0,
    domBridgeSnapshot: null,
    domBridgeTimer: null,
    lastPlan: { needTorn: 0, needFF: 0 },
    observer: null,
    scanTimer: null,
    tickTimer: null,
    thresholdValue: 0,
    trackerEls: null,
    tracker: {
      mode: "idle", // idle | baseline | tracking | alert
      running: false,
      startedAt: 0,
      lastScanAt: 0,
      lastSnapshot: new Map(),
      totals: new Map(), // name -> { name, units, gross }
      totalUnits: 0,
      totalGross: 0,
      alerts: [],
      soldAlertTriggered: false,
      latestSource: "dom",
      refreshTimer: null,
    },
  };

  state.thresholdValue = parseHumanNumber(state.cfg.statThresholdText);

  GM_addStyle(`
