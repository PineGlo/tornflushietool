      user-select: none;
    }
    .wmh-body {
      padding: 10px 12px 12px;
    }
    .wmh-collapsed .wmh-body {
      display: none;
    }
    .wmh-row {
      margin-bottom: 8px;
    }
    .wmh-row label {
      display: block;
      margin-bottom: 4px;
      color: #cbd5e1;
      font-size: 11px;
    }
    .wmh-row input[type="text"],
    .wmh-row input[type="password"],
    .wmh-row input[type="number"] {
      width: 100%;
      padding: 7px 8px;
      border: 1px solid rgba(148, 163, 184, 0.28);
      border-radius: 8px;
      background: rgba(30, 41, 59, 0.95);
      color: #f8fafc;
      outline: none;
    }
    .wmh-inline {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
