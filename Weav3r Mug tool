    const hideOutRange = panel.querySelector("#wmh-hide-out-range");

    threshold.value = state.cfg.statThresholdText || "";
    batch.value = String(state.cfg.batchSize || 15);
    tick.value = String(state.cfg.tickMs || 6000);
    enabled.checked = !!state.cfg.enabled;
    skipProtected.checked = !!state.cfg.skipProtectedTargets;
    highlightProtected.checked = !!state.cfg.highlightProtectedBlue;
    hideOutRange.checked = !!state.cfg.hideOutOfRangeTargets;

    panel.querySelector("#wmh-save").addEventListener("click", () => {
      state.cfg.statThresholdText = threshold.value.trim();
      state.cfg.batchSize = Math.max(1, Number(batch.value) || 15);
      state.cfg.tickMs = Math.max(1000, Number(tick.value) || 6000);
      state.cfg.enabled = !!enabled.checked;
      state.cfg.skipProtectedTargets = !!skipProtected.checked;
      state.cfg.highlightProtectedBlue = !!highlightProtected.checked;
      state.cfg.hideOutOfRangeTargets = !!hideOutRange.checked;

      state.thresholdValue = parseHumanNumber(state.cfg.statThresholdText);
      saveConfig();

      processQueues().catch((err) => log("Manual save refresh error", err));
      startLoop();
    });

    panel.querySelector("#wmh-refresh").addEventListener("click", () => {
      processQueues().catch((err) => log("Manual refresh error", err));
    });

    panel.querySelector("#wmh-head").addEventListener("click", () => {
      panel.classList.toggle("wmh-collapsed");
      panel.querySelector("#wmh-collapse-indicator").textContent =
        panel.classList.contains("wmh-collapsed") ? "▸" : "▾";
    });

    updateStatusLine();
  }

  function buildBazaarPanel() {
    const panel = document.createElement("div");
    panel.className = "wmh-panel";
    panel.id = "wmh-panel-bazaar";
    panel.innerHTML = `
      <div class="wmh-head" id="wmh-bazaar-head">
        <span>Torn Bazaar Tracker</span>
        <span id="wmh-bazaar-collapse-indicator">▾</span>
      </div>
      <div class="wmh-body">
        <div class="wmh-check">
          <input id="wmh-track-bazaar" type="checkbox">
          <label for="wmh-track-bazaar" style="margin:0;">Enable tracking</label>
        </div>
        <div class="wmh-inline">
          <div class="wmh-row">
            <label for="wmh-sold-threshold">Sold alert (units)</label>
            <input id="wmh-sold-threshold" type="number" min="1" step="1">
          </div>
          <div class="wmh-row">
            <label for="wmh-rapid-jump">Rapid jump (units/scan)</label>
            <input id="wmh-rapid-jump" type="number" min="1" step="1">
          </div>
        </div>
        <div class="wmh-check">
          <input id="wmh-auto-refresh" type="checkbox">
          <label for="wmh-auto-refresh" style="margin:0;">Enable timed page refresh</label>
        </div>
        <div class="wmh-inline">
          <div class="wmh-row">
            <label for="wmh-refresh-ms">Refresh ms</label>
            <input id="wmh-refresh-ms" type="number" min="5000" step="1000">
          </div>
          <div class="wmh-row">
            <label for="wmh-refresh-jitter">Jitter %</label>
            <input id="wmh-refresh-jitter" type="number" min="0" max="80" step="1">
          </div>
        </div>
        <div class="wmh-actions">
          <button class="wmh-btn" id="wmh-save-bazaar">Save</button>
          <button class="wmh-btn wmh-secondary" id="wmh-reset-tracker">Reset</button>
        </div>
        <div class="wmh-tracker-stats" id="wmh-tracker-stats"></div>
        <ol class="wmh-tracker-top" id="wmh-tracker-top"></ol>
        <div class="wmh-alerts" id="wmh-alerts"></div>
      </div>
    `;
    document.body.appendChild(panel);

    const trackBazaar = panel.querySelector("#wmh-track-bazaar");
    const soldThreshold = panel.querySelector("#wmh-sold-threshold");
    const rapidJump = panel.querySelector("#wmh-rapid-jump");
    const autoRefresh = panel.querySelector("#wmh-auto-refresh");
    const refreshMs = panel.querySelector("#wmh-refresh-ms");
    const refreshJitter = panel.querySelector("#wmh-refresh-jitter");

    trackBazaar.checked = !!state.cfg.enableBazaarTracking;
    soldThreshold.value = String(state.cfg.soldAlertUnits || 250);
    rapidJump.value = String(state.cfg.rapidJumpUnits || 40);
    autoRefresh.checked = !!state.cfg.bazaarAutoRefresh;
    refreshMs.value = String(state.cfg.bazaarRefreshMs || 45000);
    refreshJitter.value = String(state.cfg.bazaarRefreshJitterPct || 20);

    state.trackerEls = {
      stats: panel.querySelector("#wmh-tracker-stats"),
      top: panel.querySelector("#wmh-tracker-top"),
      alerts: panel.querySelector("#wmh-alerts"),
    };
    renderBazaarTracker();

    panel.querySelector("#wmh-save-bazaar").addEventListener("click", () => {
      state.cfg.enableBazaarTracking = !!trackBazaar.checked;
      state.cfg.soldAlertUnits = Math.max(1, Number(soldThreshold.value) || 250);
      state.cfg.rapidJumpUnits = Math.max(1, Number(rapidJump.value) || 40);
      state.cfg.bazaarAutoRefresh = !!autoRefresh.checked;
      state.cfg.bazaarRefreshMs = Math.max(5000, Number(refreshMs.value) || 45000);
      state.cfg.bazaarRefreshJitterPct = Math.max(0, Math.min(80, Number(refreshJitter.value) || 20));
      saveConfig();
      resetBazaarTracker();
      scheduleBazaarRefresh();
      runBazaarTracker();
    });

    panel.querySelector("#wmh-reset-tracker").addEventListener("click", () => {
      resetBazaarTracker();
      scheduleBazaarRefresh();
      runBazaarTracker();
    });

    panel.querySelector("#wmh-bazaar-head").addEventListener("click", () => {
      panel.classList.toggle("wmh-collapsed");
      panel.querySelector("#wmh-bazaar-collapse-indicator").textContent =
        panel.classList.contains("wmh-collapsed") ? "▸" : "▾";
    });
  }

  function setupObserver() {
    const debouncedScan = debounce(scanPage, 500);

    state.observer = new MutationObserver((mutations) => {
      let shouldScan = false;
      for (const m of mutations) {
        if (m.addedNodes?.length || m.removedNodes?.length) {
          shouldScan = true;
          break;
        }
      }
      if (shouldScan) debouncedScan();
    });

    state.observer.observe(document.body, {
      childList: true,
      subtree: true,
    });
  }

  function setupBazaarObserver() {
    const debouncedTrack = debounce(runBazaarTracker, 250);
    state.observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (m.addedNodes?.length || m.removedNodes?.length) {
          debouncedTrack();
          break;
        }
      }
    });
    state.observer.observe(document.body, {
      childList: true,
      subtree: true,
    });
  }

  function startBazaarLoop() {
    if (state.scanTimer) clearInterval(state.scanTimer);
    state.scanTimer = setInterval(runBazaarTracker, Math.max(1000, Number(state.cfg.bazaarScanMs) || 1000));
    scheduleBazaarRefresh();
    runBazaarTracker();
  }

  function setupCoreSubscription() {
    state.coreClient = createCoreClient();
    state.coreMode = state.coreClient.mode;
    state.coreClient.subscribe(() => {
      for (const userId of state.sellers.keys()) renderSeller(userId);
      updateStatusLine();
    });

    if (state.domBridgeTimer) clearInterval(state.domBridgeTimer);
    state.domBridgeTimer = setInterval(() => {
      requestDomBridge("core.getSnapshot")
        .then((result) => {
          if (!result?.ok || !result?.data) return;
          state.domBridgeSnapshot = result.data;
          state.coreClient = createCoreClient();
          state.coreMode = state.coreClient.mode;
          for (const userId of state.sellers.keys()) renderSeller(userId);
          updateStatusLine();
        })
        .catch(() => {});
    }, 1500);
  }

  function init() {
    if (isTornAttackPage()) {
      startAttackMonitorLoop();
      return;
    }

    if (isTornBazaarPage()) {
      loadBazaarSessionState();
      buildBazaarPanel();
      setupBazaarObserver();
      startBazaarLoop();
      return;
    }

    buildPanel();
    setupCoreSubscription();
    scanPage();
    setupObserver();
    startLoop();
  }

  init();
})();
