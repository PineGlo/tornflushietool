      border: 1px solid rgba(248, 113, 113, 0.45);
    }

    .wmh-meta {
      margin-top: 4px;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 6px;
      font-size: 11px;
    }
    .wmh-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 6px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.28);
      background: rgba(15, 23, 42, 0.72);
      color: #e2e8f0;
      font-weight: 700;
      line-height: 1.2;
    }
    .wmh-badge.ok {
      background: rgba(22, 101, 52, 0.88);
      border-color: rgba(74, 222, 128, 0.55);
      color: #dcfce7;
    }
    .wmh-badge.bad {
      background: rgba(127, 29, 29, 0.88);
      border-color: rgba(248, 113, 113, 0.55);
      color: #fee2e2;
    }
    .wmh-badge.neutral {
      background: rgba(51, 65, 85, 0.88);
      color: #e2e8f0;
    }
    .wmh-attack {
      display: inline-flex;
      align-items: center;
      padding: 2px 7px;
      border-radius: 999px;
      background: #1d4ed8;
      color: #fff !important;
      font-weight: 700;
      text-decoration: none !important;
    }
    .wmh-attack:hover {
      filter: brightness(1.08);
      text-decoration: none !important;
    }

    .wmh-row-good {
      outline: 1px solid rgba(74, 222, 128, 0.6) !important;
      box-shadow: inset 0 0 0 9999px rgba(22, 101, 52, 0.15);
    }
  `);

  function loadConfig() {
    try {
      const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
      return { ...DEFAULTS, ...parsed };
    } catch {
      return { ...DEFAULTS };
    }
  }

  function saveConfig() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.cfg));
  }

  function log(...args) {
    if (state.cfg.debug) console.log("[WMH]", ...args);
  }

  function parseHumanNumber(input) {
    if (typeof input === "number") return input;
    const raw = String(input || "").trim().toLowerCase().replace(/,/g, "");
    if (!raw) return 0;
    const match = raw.match(/^(\d+(?:\.\d+)?)([kmbt])?$/i);
    if (!match) {
      const asNum = Number(raw);
      return Number.isFinite(asNum) ? asNum : 0;
    }
    const value = Number(match[1]);
    const suffix = (match[2] || "").toLowerCase();
    const mult =
      suffix === "k" ? 1e3 :
      suffix === "m" ? 1e6 :
      suffix === "b" ? 1e9 :
      suffix === "t" ? 1e12 : 1;
    return value * mult;
  }

  function humanizeNumber(n) {
    if (n == null || !Number.isFinite(n)) return "?";
    const abs = Math.abs(n);
    if (abs >= 1e12) return (n / 1e12).toFixed(2).replace(/\.00$/, "") + "t";
    if (abs >= 1e9) return (n / 1e9).toFixed(2).replace(/\.00$/, "") + "b";
    if (abs >= 1e6) return (n / 1e6).toFixed(2).replace(/\.00$/, "") + "m";
    if (abs >= 1e3) return (n / 1e3).toFixed(1).replace(/\.0$/, "") + "k";
    return String(Math.round(n));
  }

  function isTornBazaarPage() {
    return location.hostname === "www.torn.com" && location.pathname.includes("bazaar.php");
  }

  function parseMoney(text) {
    const m = String(text || "").match(/\$([\d,]+(?:\.\d+)?)/);
    if (!m) return null;
    const n = Number(m[1].replace(/,/g, ""));
    return Number.isFinite(n) ? n : null;
  }

  function parseInteger(text) {
    const n = Number(String(text || "").replace(/[^\d]/g, ""));
    return Number.isFinite(n) ? n : null;
  }

  function parseStock(text) {
    const m = String(text || "").match(/\(([\d,]+)\s+in stock\)/i);
    if (m) return parseInteger(m[1]);
    return parseInteger(text);
  }

  function extractTornBazaarRows() {
    const rows = Array.from(document.querySelectorAll('[data-testid="description"], .description___Y2Nrl'));
    const snapshot = new Map();

    for (const row of rows) {
      const nameEl = row.querySelector('[data-testid="name"], .name___B0RW3');
      const priceEl = row.querySelector('[data-testid="price"], .price___dJqda');
      const qtyEl = row.querySelector('[data-testid="amount-value"], .amountValue___cSVqO');
      const stockEl = row.querySelector('.amount___K8sOQ');

      const name = (nameEl?.textContent || "").replace(/\s+/g, " ").trim();
      const price = parseMoney(priceEl?.textContent || row.textContent);
      const qty = parseStock(qtyEl?.textContent || stockEl?.textContent || row.textContent);
      if (!name || !Number.isFinite(price) || !Number.isFinite(qty)) continue;

      snapshot.set(name, { name, price, qty });
    }

    return snapshot;
  }

  function resetBazaarTracker() {
    state.tracker.mode = "idle";
    state.tracker.running = false;
    state.tracker.startedAt = 0;
    state.tracker.lastScanAt = 0;
    state.tracker.lastSnapshot = new Map();
    state.tracker.totals = new Map();
    state.tracker.totalUnits = 0;
    state.tracker.totalGross = 0;
    state.tracker.alerts = [];
    state.tracker.soldAlertTriggered = false;
    renderBazaarTracker();
  }

  function renderBazaarTracker(extra = "") {
    if (!state.trackerEls?.stats || !state.trackerEls?.top || !state.trackerEls?.alerts) return;
    if (!state.cfg.enableBazaarTracking) {
      state.trackerEls.stats.textContent = "Tracker disabled";
      state.trackerEls.top.innerHTML = "";
      state.trackerEls.alerts.innerHTML = "";
      return;
    }
    if (!isTornBazaarPage()) {
      state.trackerEls.stats.textContent = "Open a Torn bazaar page to track sales.";
      state.trackerEls.top.innerHTML = "";
      state.trackerEls.alerts.innerHTML = "";
      return;
    }

    const minutesLive = state.tracker.startedAt ? Math.max(1 / 60, (now() - state.tracker.startedAt) / 60000) : 0;
    const unitsPerMin = minutesLive ? (state.tracker.totalUnits / minutesLive) : 0;
    const grossPerMin = minutesLive ? (state.tracker.totalGross / minutesLive) : 0;
    state.trackerEls.stats.textContent =
      `State: ${state.tracker.mode} | Sold: ${state.tracker.totalUnits} units | Gross: $${Math.round(state.tracker.totalGross).toLocaleString()} | U/min: ${unitsPerMin.toFixed(1)} | $/min: ${Math.round(grossPerMin).toLocaleString()}${extra ? ` • ${extra}` : ""}`;

    const top3 = Array.from(state.tracker.totals.values())
      .sort((a, b) => b.units - a.units)
      .slice(0, 3);

    if (!top3.length) {
      state.trackerEls.top.innerHTML = "<li>No sales tracked yet.</li>";
    } else {
      state.trackerEls.top.innerHTML = top3
        .map((item, i) => `<li>#${i + 1} ${item.name}: ${item.units} sold ($${Math.round(item.gross).toLocaleString()})</li>`)
        .join("");
    }

    const recentAlerts = state.tracker.alerts.slice(-3);
    state.trackerEls.alerts.innerHTML = recentAlerts.length
      ? recentAlerts.map((a) => `<div class="wmh-alert">${a}</div>`).join("")
      : "";
  }

  function runBazaarTracker() {
    if (!state.cfg.enableBazaarTracking || !isTornBazaarPage()) {
      renderBazaarTracker();
      return;
    }

    // Tracker is DOM-only; no external API requests are used here.
    const snapshot = extractTornBazaarRows();
    const scanTs = now();
    if (!snapshot.size) {
      renderBazaarTracker("No bazaar rows detected.");
      return;
    }

    if (!state.tracker.running) {
      state.tracker.mode = "baseline";
      state.tracker.running = true;
      state.tracker.startedAt = scanTs;
      state.tracker.lastScanAt = scanTs;
      state.tracker.lastSnapshot = snapshot;
      renderBazaarTracker(`Tracking ${snapshot.size} items.`);
      return;
    }

    let deltaUnits = 0;
    for (const [name, prev] of state.tracker.lastSnapshot.entries()) {
      const curr = snapshot.get(name);
      if (!curr) continue;
      const sold = Math.max(0, prev.qty - curr.qty);
      if (!sold) continue;
      deltaUnits += sold;
      const gross = sold * prev.price;
      const entry = state.tracker.totals.get(name) || { name, units: 0, gross: 0 };
      entry.units += sold;
      entry.gross += gross;
      state.tracker.totals.set(name, entry);
      state.tracker.totalUnits += sold;
      state.tracker.totalGross += gross;
    }

    state.tracker.mode = "tracking";
    if (!state.tracker.soldAlertTriggered && state.tracker.totalUnits >= (Number(state.cfg.soldAlertUnits) || 250)) {
      state.tracker.soldAlertTriggered = true;
      state.tracker.mode = "alert";
      state.tracker.alerts.push(`Threshold alert: ${state.tracker.totalUnits} total units sold.`);
    }
    if (deltaUnits >= (Number(state.cfg.rapidJumpUnits) || 40)) {
      state.tracker.mode = "alert";
      state.tracker.alerts.push(`Rapid jump alert: ${deltaUnits} units sold in ~${Math.max(1, Math.round((scanTs - state.tracker.lastScanAt) / 1000))}s.`);
    }
    state.tracker.lastScanAt = scanTs;
    state.tracker.lastSnapshot = snapshot;
    renderBazaarTracker(`Tracking ${snapshot.size} items. Last scan delta: ${deltaUnits}`);
  }

  function now() {
    return Date.now();
  }

  function isFresh(entry, ttlMs) {
    return !!entry && (now() - entry.ts) < ttlMs;
  }

  function debounce(fn, wait) {
    let t = null;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), wait);
    };
  }

  function parseUserIdFromHref(href) {
    if (!href) return null;
    const match = href.match(/(?:userId=|XID=)(\d+)/i);
    return match ? Number(match[1]) : null;
  }

  function findSellerAnchors() {
    return Array.from(document.querySelectorAll('a[href*="bazaar.php?userId="]'));
  }

  function findRowForAnchor(anchor) {
    return (
      anchor.closest('tr') ||
      anchor.closest('[role="row"]') ||
      anchor.closest('.grid') ||
      anchor.closest('li') ||
      anchor.parentElement?.parentElement ||
      anchor.parentElement
    );
  }

  function ensureSeller(userId, anchor) {
    let seller = state.sellers.get(userId);
    if (!seller) {
      seller = {
        userId,
        anchor,
        row: findRowForAnchor(anchor),
        metaEl: null,
        badgeEl: null,
        attackEl: null,
      };
      state.sellers.set(userId, seller);
    } else {
      seller.anchor = anchor;
      seller.row = findRowForAnchor(anchor);
    }
    ensureSellerUi(seller);
    return seller;
  }

  function ensureSellerUi(seller) {
    if (!seller.anchor || !seller.anchor.isConnected) return;

    let meta = seller.anchor.parentElement?.querySelector(`.wmh-meta[data-wmh-id="${seller.userId}"]`);
    if (!meta) {
      meta = document.createElement("div");
      meta.className = "wmh-meta";
      meta.dataset.wmhId = String(seller.userId);

      const badge = document.createElement("span");
      badge.className = "wmh-badge neutral";
      badge.textContent = "Checking...";

      const attack = document.createElement("a");
      attack.className = "wmh-attack";
      attack.href = `https://www.torn.com/loader.php?sid=attack&user2ID=${seller.userId}`;
      attack.target = "_blank";
      attack.rel = "noopener noreferrer";
      attack.textContent = "Attack";

      meta.appendChild(badge);
      meta.appendChild(attack);

      seller.anchor.insertAdjacentElement("afterend", meta);

      seller.metaEl = meta;
      seller.badgeEl = badge;
      seller.attackEl = attack;
    } else {
      seller.metaEl = meta;
      seller.badgeEl = meta.querySelector(".wmh-badge");
      seller.attackEl = meta.querySelector(".wmh-attack");
      if (seller.attackEl) {
        seller.attackEl.href = `https://www.torn.com/loader.php?sid=attack&user2ID=${seller.userId}`;
      }
    }
  }

  function queueIfNeeded(userId) {
    const torn = state.tornCache.get(userId);
    const ff = state.ffCache.get(userId);

    if (!isFresh(torn, state.cfg.tornTtlMs)) state.pendingTorn.add(userId);
    if (!isFresh(ff, state.cfg.ffTtlMs)) state.pendingFF.add(userId);
  }

  function scanPage() {
    const anchors = findSellerAnchors();
    for (const anchor of anchors) {
      const userId = parseUserIdFromHref(anchor.href);
      if (!userId) continue;
      ensureSeller(userId, anchor);
      queueIfNeeded(userId);
      renderSeller(userId);
    }
    runBazaarTracker();
    updateStatusLine();
  }

  function getTornStatusText(json) {
    return (
      json?.status?.description ||
      json?.status?.details ||
      json?.status?.state ||
      json?.status ||
      ""
    );
  }

  function renderSeller(userId) {
    const seller = state.sellers.get(userId);
    if (!seller || !seller.anchor?.isConnected) return;

    ensureSellerUi(seller);

    const torn = state.tornCache.get(userId);
    const ff = state.ffCache.get(userId);
    const statusText = torn?.status || "…";
    const bs = ff?.bs_estimate;
    const threshold = state.thresholdValue;
    const okay = statusText === "Okay";
    const underCap = Number.isFinite(bs) && bs <= threshold;
    const good = okay && underCap;

    if (seller.badgeEl) {
      seller.badgeEl.className = "wmh-badge neutral";

      if (!torn && !ff) {
        seller.badgeEl.textContent = "Checking...";
      } else if (torn && !ff) {
        seller.badgeEl.textContent = `${statusText} | FF...`;
        seller.badgeEl.classList.add(statusText === "Okay" ? "ok" : "bad");
      } else if (!torn && ff) {
        seller.badgeEl.textContent = `...? | ${ff.bs_estimate_human || humanizeNumber(ff.bs_estimate)}`;
      } else {
        const bsText = ff.bs_estimate_human || humanizeNumber(ff.bs_estimate);
        seller.badgeEl.textContent = `${statusText} | ${bsText}`;
        if (good) {
          seller.badgeEl.classList.add("ok");
        } else if (statusText !== "Okay" || (Number.isFinite(bs) && bs > threshold)) {
          seller.badgeEl.classList.add("bad");
        } else {
          seller.badgeEl.classList.add("neutral");
        }
      }
    }

    if (seller.row) {
      seller.row.classList.toggle("wmh-row-good", good);
    }
  }

  function updateStatusLine() {
    const line = document.getElementById("wmh-statusline");
    if (!line) return;

    const visible = state.sellers.size;
    const queuedTorn = state.pendingTorn.size;
    const queuedFF = state.pendingFF.size;
    line.textContent =
      `Visible sellers: ${visible} | Torn queue: ${queuedTorn} | FF queue: ${queuedFF} | Threshold: ${state.cfg.statThresholdText}`;
  }

  function takeFromSet(setObj, maxCount) {
    const out = [];
    for (const value of setObj) {
      out.push(value);
      if (out.length >= maxCount) break;
    }
    out.forEach(v => setObj.delete(v));
    return out;
  }

  function gmGet(url) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: "GET",
        url,
        timeout: 20000,
        onload: (resp) => {
          if (resp.status >= 200 && resp.status < 300) {
            resolve(resp);
          } else {
            reject(new Error(`HTTP ${resp.status}: ${resp.responseText || "request failed"}`));
          }
        },
        onerror: (err) => reject(err),
        ontimeout: () => reject(new Error("Request timed out")),
      });
    });
  }

  async function fetchFFBatch(userIds) {
    if (!state.cfg.ffApiKey || !userIds.length) return;
    const url =
      `https://ffscouter.com/api/v1/get-stats?key=${encodeURIComponent(state.cfg.ffApiKey)}&targets=${encodeURIComponent(userIds.join(","))}`;

    try {
      const resp = await gmGet(url);
      const data = JSON.parse(resp.responseText);
      if (!Array.isArray(data)) {
        log("Unexpected FF response:", data);
        return;
      }

      const seen = new Set();
      for (const item of data) {
        if (!item || !item.player_id) continue;
        seen.add(Number(item.player_id));
        state.ffCache.set(Number(item.player_id), {
          bs_estimate: Number.isFinite(item.bs_estimate) ? item.bs_estimate : null,
          bs_estimate_human: item.bs_estimate_human || null,
          fair_fight: Number.isFinite(item.fair_fight) ? item.fair_fight : null,
          raw: item,
          ts: now(),
        });
        renderSeller(Number(item.player_id));
      }

      for (const userId of userIds) {
        if (!seen.has(userId)) {
          state.ffCache.set(userId, {
            bs_estimate: null,
            bs_estimate_human: null,
            fair_fight: null,
            raw: null,
            ts: now(),
          });
          renderSeller(userId);
        }
      }
    } catch (err) {
      log("FF batch failed:", err);
      for (const userId of userIds) {
        state.pendingFF.add(userId);
      }
    }
  }

  async function fetchTornStatus(userId) {
    if (!state.cfg.tornApiKey || !userId) return;

    // Old-style endpoint kept deliberately because it is simple and widely supported.
    const url =
      `https://api.torn.com/user/${userId}?selections=profile&key=${encodeURIComponent(state.cfg.tornApiKey)}`;

    try {
      const resp = await gmGet(url);
      const data = JSON.parse(resp.responseText);

      if (data?.error) {
        log(`Torn API error for ${userId}:`, data.error);
        return;
      }

      const status = String(getTornStatusText(data) || "").trim();
      state.tornCache.set(userId, {
        status,
        raw: data,
        ts: now(),
      });
      renderSeller(userId);
    } catch (err) {
      log(`Torn status failed for ${userId}:`, err);
      state.pendingTorn.add(userId);
    }
  }

  async function processQueues() {
    if (!state.cfg.enabled) return;

    scanPage();

    const batchSize = Math.max(1, Number(state.cfg.batchSize) || 10);

    const ffIds = takeFromSet(state.pendingFF, batchSize);
    const tornIds = takeFromSet(state.pendingTorn, batchSize);

    if (ffIds.length) {
      fetchFFBatch(ffIds);
    }

    if (tornIds.length) {
      Promise.allSettled(tornIds.map(fetchTornStatus)).then(() => {
        for (const id of tornIds) renderSeller(id);
      });
    }

    updateStatusLine();
  }

  function startLoop() {
    stopLoop();
    state.tickTimer = setInterval(processQueues, Math.max(1000, Number(state.cfg.tickMs) || 8000));
    processQueues();
  }

  function stopLoop() {
    if (state.tickTimer) clearInterval(state.tickTimer);
    state.tickTimer = null;
  }

  function buildPanel() {
    const panel = document.createElement("div");
    panel.className = "wmh-panel";
    panel.id = "wmh-panel";
    panel.innerHTML = `
      <div class="wmh-head" id="wmh-head">
        <span>Weav3r Mugging Helper</span>
        <span id="wmh-collapse-indicator">▾</span>
      </div>
      <div class="wmh-body">
        <div class="wmh-row">
          <label for="wmh-torn-key">Torn API key</label>
          <input id="wmh-torn-key" type="password" placeholder="Your Torn API key">
        </div>

        <div class="wmh-row">
          <label for="wmh-ff-key">FF Scouter API key</label>
          <input id="wmh-ff-key" type="password" placeholder="Your FF Scouter key">
        </div>

        <div class="wmh-row">
          <label for="wmh-threshold">Max estimated stats</label>
          <input id="wmh-threshold" type="text" placeholder="e.g. 500m, 1.2b">
        </div>

        <div class="wmh-inline">
          <div class="wmh-row">
            <label for="wmh-batch">Batch size</label>
            <input id="wmh-batch" type="number" min="1" max="50">
          </div>
          <div class="wmh-row">
            <label for="wmh-tick">Tick ms</label>
            <input id="wmh-tick" type="number" min="1000" step="1000">
          </div>
        </div>

        <div class="wmh-check">
          <input id="wmh-enabled" type="checkbox">
          <label for="wmh-enabled" style="margin:0;">Enabled</label>
        </div>

        <div class="wmh-actions">
          <button class="wmh-btn" id="wmh-save">Save</button>
          <button class="wmh-btn wmh-secondary" id="wmh-refresh">Rescan</button>
        </div>

        <div class="wmh-statusline" id="wmh-statusline"></div>
      </div>
    `;
    document.body.appendChild(panel);

    const tornKey = panel.querySelector("#wmh-torn-key");
    const ffKey = panel.querySelector("#wmh-ff-key");
    const threshold = panel.querySelector("#wmh-threshold");
    const batch = panel.querySelector("#wmh-batch");
    const tick = panel.querySelector("#wmh-tick");
    const enabled = panel.querySelector("#wmh-enabled");

    tornKey.value = state.cfg.tornApiKey || "";
    ffKey.value = state.cfg.ffApiKey || "";
    threshold.value = state.cfg.statThresholdText || "";
    batch.value = String(state.cfg.batchSize || 10);
    tick.value = String(state.cfg.tickMs || 8000);
    enabled.checked = !!state.cfg.enabled;

    panel.querySelector("#wmh-save").addEventListener("click", () => {
      state.cfg.tornApiKey = tornKey.value.trim();
      state.cfg.ffApiKey = ffKey.value.trim();
      state.cfg.statThresholdText = threshold.value.trim();
      state.cfg.batchSize = Math.max(1, Number(batch.value) || 10);
      state.cfg.tickMs = Math.max(1000, Number(tick.value) || 8000);
      state.cfg.enabled = !!enabled.checked;

      state.thresholdValue = parseHumanNumber(state.cfg.statThresholdText);
      saveConfig();

      // Requeue all visible sellers after config change
      for (const userId of state.sellers.keys()) {
        state.pendingTorn.add(userId);
        state.pendingFF.add(userId);
      }
      processQueues();
      startLoop();
    });

    panel.querySelector("#wmh-refresh").addEventListener("click", () => {
      for (const userId of state.sellers.keys()) {
        state.pendingTorn.add(userId);
        state.pendingFF.add(userId);
      }
      processQueues();
    });

    panel.querySelector("#wmh-head").addEventListener("click", () => {
      panel.classList.toggle("wmh-collapsed");
      panel.querySelector("#wmh-collapse-indicator").textContent =
        panel.classList.contains("wmh-collapsed") ? "▸" : "▾";
    });

    updateStatusLine();
  }

  function buildBazaarPanel() {
    const panel = document.createElement("div");
    panel.className = "wmh-panel";
    panel.id = "wmh-panel-bazaar";
    panel.innerHTML = `
      <div class="wmh-head" id="wmh-bazaar-head">
        <span>Torn Bazaar Tracker</span>
        <span id="wmh-bazaar-collapse-indicator">▾</span>
      </div>
      <div class="wmh-body">
        <div class="wmh-check">
          <input id="wmh-track-bazaar" type="checkbox">
          <label for="wmh-track-bazaar" style="margin:0;">Enable tracking</label>
        </div>
        <div class="wmh-inline">
          <div class="wmh-row">
            <label for="wmh-sold-threshold">Sold alert (units)</label>
            <input id="wmh-sold-threshold" type="number" min="1" step="1">
          </div>
          <div class="wmh-row">
            <label for="wmh-rapid-jump">Rapid jump (units/scan)</label>
            <input id="wmh-rapid-jump" type="number" min="1" step="1">
          </div>
        </div>
        <div class="wmh-actions">
          <button class="wmh-btn" id="wmh-save-bazaar">Save</button>
          <button class="wmh-btn wmh-secondary" id="wmh-reset-tracker">Reset</button>
        </div>
        <div class="wmh-tracker-stats" id="wmh-tracker-stats"></div>
        <ol class="wmh-tracker-top" id="wmh-tracker-top"></ol>
        <div class="wmh-alerts" id="wmh-alerts"></div>
      </div>
    `;
    document.body.appendChild(panel);

    const trackBazaar = panel.querySelector("#wmh-track-bazaar");
    const soldThreshold = panel.querySelector("#wmh-sold-threshold");
    const rapidJump = panel.querySelector("#wmh-rapid-jump");
    trackBazaar.checked = !!state.cfg.enableBazaarTracking;
    soldThreshold.value = String(state.cfg.soldAlertUnits || 250);
    rapidJump.value = String(state.cfg.rapidJumpUnits || 40);

    state.trackerEls = {
      stats: panel.querySelector("#wmh-tracker-stats"),
      top: panel.querySelector("#wmh-tracker-top"),
      alerts: panel.querySelector("#wmh-alerts"),
    };
    renderBazaarTracker();

    panel.querySelector("#wmh-save-bazaar").addEventListener("click", () => {
      state.cfg.enableBazaarTracking = !!trackBazaar.checked;
      state.cfg.soldAlertUnits = Math.max(1, Number(soldThreshold.value) || 250);
      state.cfg.rapidJumpUnits = Math.max(1, Number(rapidJump.value) || 40);
      saveConfig();
      resetBazaarTracker();
      runBazaarTracker();
    });

    panel.querySelector("#wmh-reset-tracker").addEventListener("click", () => {
      resetBazaarTracker();
      runBazaarTracker();
    });

    panel.querySelector("#wmh-bazaar-head").addEventListener("click", () => {
      panel.classList.toggle("wmh-collapsed");
      panel.querySelector("#wmh-bazaar-collapse-indicator").textContent =
        panel.classList.contains("wmh-collapsed") ? "▸" : "▾";
    });
  }

  function setupObserver() {
    const debouncedScan = debounce(scanPage, 500);

    state.observer = new MutationObserver((mutations) => {
      let shouldScan = false;
      for (const m of mutations) {
        if (m.addedNodes?.length || m.removedNodes?.length) {
          shouldScan = true;
          break;
        }
      }
      if (shouldScan) debouncedScan();
    });

    state.observer.observe(document.body, {
      childList: true,
      subtree: true,
    });

    state.scanTimer = setInterval(scanPage, 3000);
  }

  function setupBazaarObserver() {
    const debouncedTrack = debounce(runBazaarTracker, 250);
    state.observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (m.addedNodes?.length || m.removedNodes?.length) {
          debouncedTrack();
          break;
        }
      }
    });
    state.observer.observe(document.body, {
      childList: true,
      subtree: true,
    });
  }

  function startBazaarLoop() {
    if (state.scanTimer) clearInterval(state.scanTimer);
    state.scanTimer = setInterval(runBazaarTracker, Math.max(1000, Number(state.cfg.bazaarScanMs) || 1000));
    runBazaarTracker();
  }

  function init() {
    if (isTornBazaarPage()) {
      buildBazaarPanel();
      setupBazaarObserver();
      startBazaarLoop();
      return;
    }

    buildPanel();
    scanPage();
    setupObserver();
    startLoop();
  }

  init();
})();
