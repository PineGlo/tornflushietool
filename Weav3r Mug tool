// ==UserScript==
// @name         Weav3r Mugging Helper
// @namespace    Violentmonkey Scripts
// @version      1.1.0
// @description  Highlights sellers on weav3r.dev/item when Torn status is Okay and FF estimated stats are under your threshold. Adds Attack links.
// @match        https://weav3r.dev/item/*
// @match        https://www.torn.com/bazaar.php*
// @grant        GM_xmlhttpRequest
// @grant        GM_addStyle
// @connect      api.torn.com
// @connect      ffscouter.com
// @run-at       document-idle
// ==/UserScript==

(function () {
  "use strict";

  const STORAGE_KEY = "weav3r_mugging_helper_v1";
  const DEFAULTS = {
    enabled: true,
    enableBazaarTracking: true,
    bazaarScanMs: 1000,
    soldAlertUnits: 250,
    rapidJumpUnits: 40,
    tornApiKey: "",
    ffApiKey: "",
    statThresholdText: "500m",
    batchSize: 10,
    tickMs: 8000,
    tornTtlMs: 60 * 1000,
    ffTtlMs: 60 * 60 * 1000,
    debug: false,
  };

  const state = {
    cfg: loadConfig(),
    sellers: new Map(),      // userId -> seller object
    tornCache: new Map(),    // userId -> { status, ts, raw }
    ffCache: new Map(),      // userId -> { bs_estimate, bs_estimate_human, fair_fight, ts, raw }
    pendingTorn: new Set(),
    pendingFF: new Set(),
    observer: null,
    scanTimer: null,
    tickTimer: null,
    thresholdValue: 0,
    trackerEls: null,
    tracker: {
      mode: "idle", // idle | baseline | tracking | alert
      running: false,
      startedAt: 0,
      lastScanAt: 0,
      lastSnapshot: new Map(),
      totals: new Map(), // name -> { name, units, gross }
      totalUnits: 0,
      totalGross: 0,
      alerts: [],
      soldAlertTriggered: false,
    },
  };

  state.thresholdValue = parseHumanNumber(state.cfg.statThresholdText);

  GM_addStyle(`
    .wmh-panel {
      position: fixed;
      top: 88px;
