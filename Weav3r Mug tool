    panel.querySelector("#wmh-save").addEventListener("click", () => {
      state.cfg.statThresholdText = threshold.value.trim();
      state.cfg.batchSize = Math.max(1, Number(batch.value) || 15);
      state.cfg.tickMs = Math.max(1000, Number(tick.value) || 6000);
      state.cfg.enabled = !!enabled.checked;

      state.thresholdValue = parseHumanNumber(state.cfg.statThresholdText);
      saveConfig();

      processQueues();
      startLoop();
