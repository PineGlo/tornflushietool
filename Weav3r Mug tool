  function loadConfig() {
    try {
      const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
      return { ...DEFAULTS, ...parsed };
    } catch {
      return { ...DEFAULTS };
    }
  }

  function saveConfig() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.cfg));
  }

  function log(...args) {
    if (state.cfg.debug) console.log("[WMH]", ...args);
  }

  function now() {
    return Date.now();
  }

  function normalizeText(text) {
    return String(text || "").replace(/\s+/g, " ").trim();
  }

  function debounce(fn, wait) {
    let t = null;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), wait);
    };
  }

  function parseHumanNumber(input) {
    if (typeof input === "number") return input;
    const raw = String(input || "").trim().toLowerCase().replace(/,/g, "");
    if (!raw) return 0;
    const match = raw.match(/^(\d+(?:\.\d+)?)([kmbt])?$/i);
    if (!match) {
      const asNum = Number(raw);
      return Number.isFinite(asNum) ? asNum : 0;
    }
    const value = Number(match[1]);
    const suffix = (match[2] || "").toLowerCase();
    const mult =
      suffix === "k" ? 1e3 :
      suffix === "m" ? 1e6 :
      suffix === "b" ? 1e9 :
      suffix === "t" ? 1e12 : 1;
    return value * mult;
  }

  function humanizeNumber(n) {
    if (n == null || !Number.isFinite(n)) return "?";
    const abs = Math.abs(n);
    if (abs >= 1e12) return (n / 1e12).toFixed(2).replace(/\.00$/, "") + "t";
    if (abs >= 1e9) return (n / 1e9).toFixed(2).replace(/\.00$/, "") + "b";
    if (abs >= 1e6) return (n / 1e6).toFixed(2).replace(/\.00$/, "") + "m";
    if (abs >= 1e3) return (n / 1e3).toFixed(1).replace(/\.0$/, "") + "k";
    return String(Math.round(n));
  }

  function parseMoney(text) {
    const m = String(text || "").match(/\$([\d,]+(?:\.\d+)?)/);
    if (!m) return null;
    const n = Number(m[1].replace(/,/g, ""));
    return Number.isFinite(n) ? n : null;
  }

  function parseInteger(text) {
    const n = Number(String(text || "").replace(/[^\d]/g, ""));
    return Number.isFinite(n) ? n : null;
  }

  function parseStock(text) {
    const m = String(text || "").match(/\(([\d,]+)\s+in stock\)/i);
    if (m) return parseInteger(m[1]);
    return parseInteger(text);
  }

  function isTornBazaarPage() {
    return location.hostname === "www.torn.com" && location.pathname.includes("bazaar.php");
  }

  function isTornAttackPage() {
    if (location.hostname !== "www.torn.com") return false;
    const href = location.href.toLowerCase();
    return href.includes("sid=attack");
  }

  function parseUserIdFromHref(href) {
    if (!href) return null;
    const match = href.match(/(?:userId=|XID=)(\d+)/i);
    return match ? Number(match[1]) : null;
  }

  function parseAttackTargetUserIdFromHref(href) {
    if (!href) return null;
    const match = String(href).match(/user2id=(\d+)/i);
    return match ? Number(match[1]) : null;
  }

  function extractTornBazaarRowsFromRoot(rootNode) {
    const rows = Array.from(rootNode.querySelectorAll('[data-testid="description"], .description___Y2Nrl'));
    const snapshot = new Map();

    for (const row of rows) {
      const nameEl = row.querySelector('[data-testid="name"], .name___B0RW3');
      const priceEl = row.querySelector('[data-testid="price"], .price___dJqda');
      const qtyEl = row.querySelector('[data-testid="amount-value"], .amountValue___cSVqO');
      const stockEl = row.querySelector('.amount___K8sOQ');

      const name = (nameEl?.textContent || "").replace(/\s+/g, " ").trim();
      const price = parseMoney(priceEl?.textContent || row.textContent);
      const qty = parseStock(qtyEl?.textContent || stockEl?.textContent || row.textContent);
      if (!name || !Number.isFinite(price) || !Number.isFinite(qty)) continue;

      snapshot.set(name, { name, price, qty });
    }

    return snapshot;
  }

  function extractTornBazaarRows() {
    return extractTornBazaarRowsFromRoot(document);
  }

  function resetBazaarTracker() {
    state.tracker.mode = "idle";
    state.tracker.running = false;
    state.tracker.startedAt = 0;
    state.tracker.lastScanAt = 0;
    state.tracker.lastSnapshot = new Map();
    state.tracker.totals = new Map();
    state.tracker.totalUnits = 0;
    state.tracker.totalGross = 0;
    state.tracker.alerts = [];
    state.tracker.soldAlertTriggered = false;
    state.tracker.latestSource = "dom";
    renderBazaarTracker();
  }

  function saveBazaarSessionState() {
    if (!isTornBazaarPage()) return;
    const data = {
      startedAt: state.tracker.startedAt,
      totalUnits: state.tracker.totalUnits,
      totalGross: state.tracker.totalGross,
      totals: Array.from(state.tracker.totals.entries()),
      alerts: state.tracker.alerts.slice(-20),
      soldAlertTriggered: state.tracker.soldAlertTriggered,
    };
    sessionStorage.setItem("wmh_bazaar_session_v1", JSON.stringify(data));
  }

  function loadBazaarSessionState() {
    try {
      const raw = sessionStorage.getItem("wmh_bazaar_session_v1");
      if (!raw) return;
      const data = JSON.parse(raw);
      state.tracker.startedAt = Number(data.startedAt) || 0;
      state.tracker.totalUnits = Number(data.totalUnits) || 0;
      state.tracker.totalGross = Number(data.totalGross) || 0;
      state.tracker.totals = new Map(Array.isArray(data.totals) ? data.totals : []);
      state.tracker.alerts = Array.isArray(data.alerts) ? data.alerts : [];
      state.tracker.soldAlertTriggered = !!data.soldAlertTriggered;
      if (state.tracker.startedAt) state.tracker.mode = "tracking";
    } catch {}
  }

  function scheduleBazaarRefresh() {
    if (state.tracker.refreshTimer) clearTimeout(state.tracker.refreshTimer);
    if (!state.cfg.bazaarAutoRefresh || !isTornBazaarPage()) return;
    const baseMs = Math.max(5000, Number(state.cfg.bazaarRefreshMs) || 45000);
    const jitterPct = Math.max(0, Math.min(80, Number(state.cfg.bazaarRefreshJitterPct) || 20));
    const jitterWindow = baseMs * (jitterPct / 100);
    const offset = (Math.random() * 2 - 1) * jitterWindow;
    const delay = Math.max(5000, Math.round(baseMs + offset));
    state.tracker.refreshTimer = setTimeout(() => {
      saveBazaarSessionState();
      location.reload();
    }, delay);
  }

  function renderBazaarTracker(extra = "") {
    if (!state.trackerEls?.stats || !state.trackerEls?.top || !state.trackerEls?.alerts) return;
    if (!state.cfg.enableBazaarTracking) {
      state.trackerEls.stats.textContent = "Tracker disabled";
      state.trackerEls.top.innerHTML = "";
      state.trackerEls.alerts.innerHTML = "";
      return;
    }
    if (!isTornBazaarPage()) {
      state.trackerEls.stats.textContent = "Open a Torn bazaar page to track sales.";
      state.trackerEls.top.innerHTML = "";
      state.trackerEls.alerts.innerHTML = "";
      return;
    }

    const minutesLive = state.tracker.startedAt ? Math.max(1 / 60, (now() - state.tracker.startedAt) / 60000) : 0;
    const unitsPerMin = minutesLive ? (state.tracker.totalUnits / minutesLive) : 0;
    const grossPerMin = minutesLive ? (state.tracker.totalGross / minutesLive) : 0;
    state.trackerEls.stats.textContent =
      `State: ${state.tracker.mode} | Src: ${state.tracker.latestSource} | Sold: ${state.tracker.totalUnits} units | Gross: $${Math.round(state.tracker.totalGross).toLocaleString()} | U/min: ${unitsPerMin.toFixed(1)} | $/min: ${Math.round(grossPerMin).toLocaleString()}${extra ? ` • ${extra}` : ""}`;

    const top3 = Array.from(state.tracker.totals.values())
      .sort((a, b) => b.units - a.units)
      .slice(0, 3);

    if (!top3.length) {
      state.trackerEls.top.innerHTML = "<li>No sales tracked yet.</li>";
    } else {
      state.trackerEls.top.innerHTML = top3
        .map((item, i) => `<li>#${i + 1} ${item.name}: ${item.units} sold ($${Math.round(item.gross).toLocaleString()})</li>`)
        .join("");
    }

    const recentAlerts = state.tracker.alerts.slice(-3);
    state.trackerEls.alerts.innerHTML = recentAlerts.length
      ? recentAlerts.map((a) => `<div class="wmh-alert">${a}</div>`).join("")
      : "";
  }

  function runBazaarTracker() {
    if (!state.cfg.enableBazaarTracking || !isTornBazaarPage()) {
      renderBazaarTracker();
      return;
    }

    state.tracker.latestSource = "dom";
    const snapshot = extractTornBazaarRows();
    const scanTs = now();
    if (!snapshot.size) {
      renderBazaarTracker("No bazaar rows detected.");
      return;
    }

    if (!state.tracker.running) {
      state.tracker.mode = "baseline";
      state.tracker.running = true;
      state.tracker.startedAt = scanTs;
      state.tracker.lastScanAt = scanTs;
      state.tracker.lastSnapshot = snapshot;
      renderBazaarTracker(`Tracking ${snapshot.size} items.`);
      return;
    }

    let deltaUnits = 0;
    for (const [name, prev] of state.tracker.lastSnapshot.entries()) {
      const curr = snapshot.get(name);
      if (!curr) continue;
      const sold = Math.max(0, prev.qty - curr.qty);
      if (!sold) continue;
      deltaUnits += sold;
      const gross = sold * prev.price;
      const entry = state.tracker.totals.get(name) || { name, units: 0, gross: 0 };
      entry.units += sold;
      entry.gross += gross;
      state.tracker.totals.set(name, entry);
      state.tracker.totalUnits += sold;
      state.tracker.totalGross += gross;
    }

    state.tracker.mode = "tracking";
    if (!state.tracker.soldAlertTriggered && state.tracker.totalUnits >= (Number(state.cfg.soldAlertUnits) || 250)) {
      state.tracker.soldAlertTriggered = true;
      state.tracker.mode = "alert";
      state.tracker.alerts.push(`Threshold alert: ${state.tracker.totalUnits} total units sold.`);
    }
    if (deltaUnits >= (Number(state.cfg.rapidJumpUnits) || 40)) {
      state.tracker.mode = "alert";
      state.tracker.alerts.push(`Rapid jump alert: ${deltaUnits} units sold in ~${Math.max(1, Math.round((scanTs - state.tracker.lastScanAt) / 1000))}s.`);
    }
    state.tracker.lastScanAt = scanTs;
    state.tracker.lastSnapshot = snapshot;
    saveBazaarSessionState();
    renderBazaarTracker(`Tracking ${snapshot.size} items. Last scan delta: ${deltaUnits}`);
  }

  function findSellerAnchors() {
    return Array.from(document.querySelectorAll('a[href*="bazaar.php?userId="]'));
  }

  function findRowForAnchor(anchor) {
    return (
      anchor.closest("tr") ||
      anchor.closest('[role="row"]') ||
      anchor.closest(".grid") ||
      anchor.closest("li") ||
      anchor.parentElement?.parentElement ||
      anchor.parentElement
    );
  }

  function ensureSeller(userId, anchor) {
    let seller = state.sellers.get(userId);
    if (!seller) {
      seller = {
        userId,
        anchor,
        row: findRowForAnchor(anchor),
        metaEl: null,
        badgeEl: null,
        attackEl: null,
      };
      state.sellers.set(userId, seller);
    } else {
      seller.anchor = anchor;
      seller.row = findRowForAnchor(anchor);
    }
    ensureSellerUi(seller);
    return seller;
  }

  function ensureSellerUi(seller) {
    if (!seller.anchor || !seller.anchor.isConnected) return;

    let meta = seller.anchor.parentElement?.querySelector(`.wmh-meta[data-wmh-id="${seller.userId}"]`);
    if (!meta) {
      meta = document.createElement("div");
      meta.className = "wmh-meta";
      meta.dataset.wmhId = String(seller.userId);

      const badge = document.createElement("span");
      badge.className = "wmh-badge neutral";
      badge.textContent = "Checking...";

      const attack = document.createElement("a");
      attack.className = "wmh-attack";
      attack.href = `https://www.torn.com/loader.php?sid=attack&user2ID=${seller.userId}`;
      attack.target = "_blank";
      attack.rel = "noopener noreferrer";
      attack.textContent = "Attack";

      meta.appendChild(badge);
      meta.appendChild(attack);

      seller.anchor.insertAdjacentElement("afterend", meta);

      seller.metaEl = meta;
      seller.badgeEl = badge;
      seller.attackEl = attack;
    } else {
      seller.metaEl = meta;
      seller.badgeEl = meta.querySelector(".wmh-badge");
      seller.attackEl = meta.querySelector(".wmh-attack");
      if (seller.attackEl) {
        seller.attackEl.href = `https://www.torn.com/loader.php?sid=attack&user2ID=${seller.userId}`;
      }
    }
  }

  function scanPage() {
    const anchors = findSellerAnchors();
    for (const anchor of anchors) {
      const userId = parseUserIdFromHref(anchor.href);
      if (!userId) continue;
      ensureSeller(userId, anchor);
      renderSeller(userId);
    }
    runBazaarTracker();
    updateStatusLine();
  }

  function getCoreState() {
    try {
      return window.TornCore?.getState?.() || null;
    } catch {
      return null;
    }
  }

  function getProtectedMapFromCore() {
    const coreState = getCoreState() || state.domBridgeSnapshot || null;
    if (!coreState || typeof coreState !== "object") return {};

    if (coreState.protectedMembers?.byUserId && typeof coreState.protectedMembers.byUserId === "object") {
      return coreState.protectedMembers.byUserId;
    }

    if (coreState.allianceProtection?.protectedMembers?.byUserId && typeof coreState.allianceProtection.protectedMembers.byUserId === "object") {
      return coreState.allianceProtection.protectedMembers.byUserId;
    }

    if (coreState.protectedMembers && typeof coreState.protectedMembers === "object") {
      return coreState.protectedMembers;
    }

    return {};
  }

  function getProtectedMemberInfo(userId) {
    const map = getProtectedMapFromCore();
    return map?.[String(userId)] || map?.[Number(userId)] || null;
  }

  function mapCoreUserToSellerTruth(userId) {
    const coreUser = state.coreClient?.getUser?.(userId) || null;
    const torn = coreUser?.torn || null;
    const ff = coreUser?.ff || null;
    const tornAt = Number(torn?.lastRefreshAt) || 0;
    const ffAt = Number(ff?.lastRefreshAt) || 0;
    const tornFresh = tornAt && (now() - tornAt) <= CORE_STALE.tornMs;
    const ffFresh = ffAt && (now() - ffAt) <= CORE_STALE.ffMs;
    const protectedInfo = getProtectedMemberInfo(userId);

    return {
      status: torn?.status || "",
      estimatedStats: Number.isFinite(ff?.estimatedStats) ? ff.estimatedStats : null,
      estimatedStatsHuman: ff?.estimatedStatsHuman || "",
      tornFresh: !!tornFresh,
      ffFresh: !!ffFresh,
      stale: !tornFresh || !ffFresh,
      protectedInfo,
      isProtected: !!protectedInfo,
    };
  }

  function isUnderThreshold(truth) {
    return Number.isFinite(truth?.estimatedStats) && truth.estimatedStats <= state.thresholdValue;
  }

  function formatCountdownMs(ms) {
    if (!Number.isFinite(ms) || ms <= 0) return "0m";

    const totalSeconds = Math.floor(ms / 1000);
    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.ceil((totalSeconds % 3600) / 60);

    if (hours > 0) {
      return `${hours}h ${String(minutes).padStart(2, "0")}m`;
    }
    return `${Math.max(0, minutes)}m`;
  }

  function getHospitalCountdownText(userId) {
    const coreUser = state.coreClient?.getUser?.(userId) || null;
    const torn = coreUser?.torn || null;
    const hospitalUntil = Number(torn?.hospitalUntil) || 0;
    const hospitalEtaText = String(torn?.hospitalEtaText || "").trim();

    if (!hospitalUntil) {
      return hospitalEtaText ? `Hosp ${hospitalEtaText}` : "";
    }
    const remainingMs = hospitalUntil - now();
    if (remainingMs <= 0) return "Hosp 0m";

    return `Hosp ${formatCountdownMs(remainingMs)}`;
  }

  function parseEtaTextToMs(etaText) {
    const raw = String(etaText || "").toLowerCase();
    if (!raw) return null;

    let totalMs = 0;
    const hMatch = raw.match(/(\d+)\s*h/);
    const mMatch = raw.match(/(\d+)\s*m/);
    const sMatch = raw.match(/(\d+)\s*s/);
    if (hMatch) totalMs += Number(hMatch[1]) * 60 * 60 * 1000;
    if (mMatch) totalMs += Number(mMatch[1]) * 60 * 1000;
    if (sMatch) totalMs += Number(sMatch[1]) * 1000;

    if (totalMs > 0) return totalMs;
    return null;
  }

  function getAttackHospitalTimerText(userId) {
    const coreUser = state.coreClient?.getUser?.(userId) || null;
    const torn = coreUser?.torn || null;
    const hospitalUntil = Number(torn?.hospitalUntil) || 0;
    const hospitalEtaText = String(torn?.hospitalEtaText || "").trim();
    const refreshedAt = Number(torn?.lastRefreshAt) || now();

    if (hospitalUntil > 0) {
      return formatCountdownMs(hospitalUntil - now());
    }

    const etaMs = parseEtaTextToMs(hospitalEtaText);
    if (etaMs != null) {
      const estUntil = refreshedAt + etaMs;
      return formatCountdownMs(estUntil - now());
    }

    return hospitalEtaText || "Unknown";
  }

  function readAttackHospitalFromDom() {
    const text = normalizeText(document.body?.innerText || "");
    if (!text) return null;
    const etaMatch = text.match(/leave hospital in\s*([0-9hms\s]+)/i);
    const etaText = etaMatch ? normalizeText(etaMatch[1]) : "";
    const isHospital = /\bhospital\b/i.test(text) || !!etaText;
    return { isHospital, etaText };
  }

  function beepAttackAlarm() {
    try {
      const Ctx = window.AudioContext || window.webkitAudioContext;
      if (!Ctx) return;
      if (!state.attackMonitor.audioCtx || state.attackMonitor.audioCtx.state === "closed") {
        state.attackMonitor.audioCtx = new Ctx();
      }
      const ctx = state.attackMonitor.audioCtx;
      const pattern = [1046.5, 1318.5, 1568];
      const start = ctx.currentTime + 0.03;
      pattern.forEach((freq, idx) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = "sine";
        osc.frequency.value = freq;
        gain.gain.value = 0.0001;
        osc.connect(gain);
        gain.connect(ctx.destination);
        const t0 = start + (idx * 0.18);
        gain.gain.exponentialRampToValueAtTime(0.15, t0 + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.16);
        osc.start(t0);
        osc.stop(t0 + 0.17);
      });
    } catch (err) {
      log("Alarm beep failed", err);
    }
  }

  function tryAutoStartAttack() {
    const candidates = Array.from(document.querySelectorAll("button, input[type='button'], input[type='submit'], a"));
    const scoreFor = (el) => {
      if (!el || typeof el !== "object") return 0;
      const txt = normalizeText(el.innerText || el.textContent || el.value || "").toLowerCase();
      const cls = String(el.className || "").toLowerCase();
      const aria = String(el.getAttribute?.("aria-label") || "").toLowerCase();
      const href = String(el.getAttribute?.("href") || "").toLowerCase();
      let score = 0;
      if (txt === "attack" || txt === "start fight" || txt === "start attack") score += 100;
      if (txt.includes("attack")) score += 30;
      if (txt.includes("start fight")) score += 30;
      if (aria.includes("attack")) score += 20;
      if (cls.includes("attack")) score += 15;
      if (href.includes("sid=attack")) score -= 25;
      if (el.disabled) score -= 100;
      if (el.offsetParent == null) score -= 20;
      return score;
    };

    const best = candidates
      .map((el) => ({ el, score: scoreFor(el) }))
      .sort((a, b) => b.score - a.score)[0];

    if (!best || best.score < 30) return false;
    best.el.click();
    return true;
  }

  function handleAttackReleaseTransition(userId, status, isHospital) {
    const prev = state.attackMonitor.previousHospital;
    const changedToReleased = prev === true && isHospital === false;
    state.attackMonitor.previousHospital = isHospital;
    const prevStatus = String(state.attackMonitor.previousStatus || "");
    const normalizedStatus = String(status || "").trim();
    const changedToOkay = prevStatus !== "Okay" && normalizedStatus === "Okay";
    state.attackMonitor.previousStatus = normalizedStatus;
    if (!changedToReleased && !changedToOkay) return;

    const nowMs = now();
    if (state.cfg.attackAlarmEnabled && (nowMs - state.attackMonitor.alarmedAt) >= 5000) {
      state.attackMonitor.alarmedAt = nowMs;
      if (changedToOkay) {
        beepAttackAlarm();
        alert(`Target ${userId} has landed (Okay).`);
      } else {
        beepAttackAlarm();
        alert(`Target ${userId} is out of hospital.`);
      }
    }

    if (state.cfg.attackAutoStartEnabled && changedToOkay && !state.attackMonitor.autoAttackStarted) {
      const clicked = tryAutoStartAttack();
      if (clicked) {
        state.attackMonitor.autoAttackStarted = true;
      }
    }
  }

