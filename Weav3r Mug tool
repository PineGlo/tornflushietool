    }
    .wmh-tracker-stats {
      margin-top: 8px;
      color: #bfdbfe;
      font-size: 11px;
      line-height: 1.4;
    }
    .wmh-tracker-top {
      margin-top: 4px;
      padding-left: 16px;
      font-size: 11px;
    }
    .wmh-tracker-top li {
      margin: 3px 0;
      color: #e2e8f0;
    }
